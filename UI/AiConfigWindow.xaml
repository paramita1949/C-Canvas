<Window x:Class="ImageColorChanger.UI.AiConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI配置"
        Height="600"
        Width="760"
        MinHeight="600"
        MinWidth="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F7F9FC"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#2C3A4B"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>
        <Style x:Key="FieldInputStyle" TargetType="Control">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>
        <Style x:Key="ModeSegmentStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#5F6B7A"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#1F7AE0"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#1E4F8F"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsChecked" Value="True"/>
                        <Condition Property="IsMouseOver" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Foreground" Value="White"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FieldComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource FieldInputStyle}">
            <Setter Property="Background" Value="#FBFCFE"/>
            <Setter Property="BorderBrush" Value="#DCE5EE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,0,36,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FieldTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource FieldInputStyle}">
            <Setter Property="Background" Value="#FBFCFE"/>
            <Setter Property="BorderBrush" Value="#DCE5EE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,0,14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
        </Style>
        <Style x:Key="ComboBoxItemFixStyle" TargetType="ComboBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E7EDF3" BorderThickness="1" CornerRadius="16" Padding="28">
            <ScrollViewer VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False"
                          PanningMode="VerticalOnly">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0"
                        Grid.ColumnSpan="2"
                        Margin="0,0,0,24"
                        Background="#F1F5F9"
                        BorderBrush="#DEE7EF"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <RadioButton x:Name="RealtimeSpeechModeToggle"
                                     Content="实时语音"
                                     GroupName="AiSpeechMode"
                                     Style="{StaticResource ModeSegmentStyle}"
                                     Checked="SpeechModeToggle_Checked"/>

                        <Border Grid.Column="1" Background="#DEE7EF"/>

                        <RadioButton x:Name="ShortSpeechModeToggle"
                                     Grid.Column="2"
                                     Content="经文识别"
                                     GroupName="AiSpeechMode"
                                     Style="{StaticResource ModeSegmentStyle}"
                                     Checked="SpeechModeToggle_Checked"/>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="语音平台"/>
                <ComboBox x:Name="ProviderComboBox"
                          Grid.Row="1" Grid.Column="1"
                          Style="{StaticResource FieldComboBoxStyle}"
                          ItemContainerStyle="{StaticResource ComboBoxItemFixStyle}"
                          SelectionChanged="ProviderComboBox_SelectionChanged"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,18,0,0" Style="{StaticResource FieldLabelStyle}" Text="连接地址"/>
                <TextBox x:Name="BaseUrlTextBox" Grid.Row="2" Grid.Column="1" Margin="0,18,0,0" Style="{StaticResource FieldTextBoxStyle}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,18,0,0" Style="{StaticResource FieldLabelStyle}" Text="模型选择"/>
                <Grid Grid.Row="3" Grid.Column="1" Margin="0,18,0,0">
                    <ComboBox x:Name="ModelSelectComboBox"
                              Style="{StaticResource FieldComboBoxStyle}"
                              ItemContainerStyle="{StaticResource ComboBoxItemFixStyle}"
                              SelectionChanged="ModelSelectComboBox_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DisplayText}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Button Grid.Column="1"
                                            Width="22"
                                            Height="22"
                                            Margin="8,0,0,0"
                                            Content="−"
                                            FontSize="14"
                                            FontWeight="Bold"
                                            Foreground="#C0392B"
                                            Background="Transparent"
                                            BorderBrush="#E6E6E6"
                                            BorderThickness="1"
                                            Padding="0"
                                            Cursor="Hand"
                                            Click="ModelItemDeleteButton_Click">
                                        <Button.Tag>
                                            <Binding Path="ModelId"/>
                                        </Button.Tag>
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsCustom}" Value="True"/>
                                                            <Condition Binding="{Binding IsDropDownOpen, RelativeSource={RelativeSource AncestorType=ComboBox}}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,18,0,0" Style="{StaticResource FieldLabelStyle}" Text="方言模型"/>
                <ComboBox x:Name="DialectSelectComboBox"
                          Grid.Row="4" Grid.Column="1"
                          Margin="0,18,0,0"
                          Style="{StaticResource FieldComboBoxStyle}"
                          ItemContainerStyle="{StaticResource ComboBoxItemFixStyle}"
                          SelectionChanged="DialectSelectComboBox_SelectionChanged"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,18,0,0" Style="{StaticResource FieldLabelStyle}" Text="模型ID（自动）"/>
                <TextBox x:Name="ModelTextBox" Grid.Row="5" Grid.Column="1" Margin="0,18,0,0" Style="{StaticResource FieldTextBoxStyle}" IsReadOnly="True" Background="#F3F6F9" BorderBrush="#E1E8EF"/>

                <TextBlock x:Name="Credential1Label" Grid.Row="6" Grid.Column="0" Margin="0,18,0,0" Style="{StaticResource FieldLabelStyle}" Text="凭证1"/>
                <TextBox x:Name="Credential1TextBox" Grid.Row="6" Grid.Column="1" Margin="0,18,0,0" Style="{StaticResource FieldTextBoxStyle}"/>

                <TextBlock x:Name="Credential2Label" Grid.Row="7" Grid.Column="0" Margin="0,18,0,0" Style="{StaticResource FieldLabelStyle}" Text="凭证2"/>
                <TextBox x:Name="Credential2TextBox" Grid.Row="7" Grid.Column="1" Margin="0,18,0,0" Style="{StaticResource FieldTextBoxStyle}"/>

                <TextBlock x:Name="Credential3Label" Grid.Row="8" Grid.Column="0" Margin="0,18,0,0" Style="{StaticResource FieldLabelStyle}" Text="凭证3"/>
                <TextBox x:Name="Credential3TextBox" Grid.Row="8" Grid.Column="1" Margin="0,18,0,0" Style="{StaticResource FieldTextBoxStyle}"/>

                <TextBlock x:Name="DoubaoHotwordLabel" Grid.Row="9" Grid.Column="0" Margin="0,18,0,0" Style="{StaticResource FieldLabelStyle}" Text="豆包热词表" Visibility="Collapsed"/>
                <Grid x:Name="DoubaoHotwordPanel" Grid.Row="9" Grid.Column="1" Margin="0,18,0,0" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="DoubaoHotwordComboBox"
                              Grid.Column="0"
                              Style="{StaticResource FieldComboBoxStyle}"
                              ItemContainerStyle="{StaticResource ComboBoxItemFixStyle}"
                              SelectionChanged="DoubaoHotwordComboBox_SelectionChanged"/>
                    <Button x:Name="RefreshDoubaoHotwordButton"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            Width="120"
                            Height="44"
                            Content="刷新列表"
                            Click="RefreshDoubaoHotwordButton_Click"/>
                </Grid>

                <TextBlock x:Name="DoubaoHotwordAkLabel" Grid.Row="10" Grid.Column="0" Margin="0,18,0,0" Style="{StaticResource FieldLabelStyle}" Text="热词管理 AK" Visibility="Collapsed"/>
                <TextBox x:Name="DoubaoHotwordAkTextBox" Grid.Row="10" Grid.Column="1" Margin="0,18,0,0" Style="{StaticResource FieldTextBoxStyle}" Visibility="Collapsed"/>

                <TextBlock x:Name="DoubaoHotwordSkLabel" Grid.Row="11" Grid.Column="0" Margin="0,18,0,0" Style="{StaticResource FieldLabelStyle}" Text="热词管理 SK" Visibility="Collapsed"/>
                <TextBox x:Name="DoubaoHotwordSkTextBox" Grid.Row="11" Grid.Column="1" Margin="0,18,0,0" Style="{StaticResource FieldTextBoxStyle}" Visibility="Collapsed"/>

                <TextBlock Grid.Row="12" Grid.Column="0" Margin="0,18,0,0" Style="{StaticResource FieldLabelStyle}" Text="经文识别来源"/>
                <ComboBox x:Name="VerseSourceComboBox"
                          Grid.Row="12" Grid.Column="1"
                          Margin="0,18,0,0"
                          Style="{StaticResource FieldComboBoxStyle}"
                          ItemContainerStyle="{StaticResource ComboBoxItemFixStyle}"
                          SelectionChanged="VerseSourceComboBox_SelectionChanged"/>

                <TextBlock x:Name="HintTextBlock"
                           Grid.Row="13" Grid.ColumnSpan="2"
                           Margin="0,22,0,0"
                           Foreground="#66758A"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Text="保存后将写入 config.json。当前识别引擎已接入百度，腾讯云/阿里云界面已预留。"/>
            </Grid>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="CancelButton" Content="取消" Width="120" Height="40" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button x:Name="SaveButton" Content="保存" Width="120" Height="40" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
