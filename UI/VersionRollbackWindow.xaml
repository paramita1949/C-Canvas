<Window x:Class="ImageColorChanger.UI.VersionRollbackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="版本回退"
        Height="560"
        Width="560"
        MinHeight="560"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        FontFamily="Microsoft YaHei UI"
        Loaded="Window_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1976D2" CornerRadius="8" Padding="16,12">
            <StackPanel>
                <TextBlock Text="版本管理 / 回退" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock x:Name="CurrentVersionText"
                           Margin="0,6,0,0"
                           Foreground="#E3F2FD"
                           FontSize="13"
                           Text="当前版本：-"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1"
                   Margin="2,12,2,8"
                   Foreground="#555555"
                   FontSize="13"
                   Text="选择要安装的版本（只显示可用且不高于当前版本）："/>

        <Border Grid.Row="2" Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="8">
            <ListBox x:Name="VersionsListBox"
                     Margin="8"
                     BorderThickness="0"
                     FontSize="14"
                     Background="White"
                     Foreground="#222222"
                     SelectionMode="Single"
                     SelectionChanged="VersionsListBox_SelectionChanged"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="RowBorder" Padding="10,8" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="CheckMark"
                                           Grid.Column="0"
                                           Text="✓"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#2E7D32"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Visibility="Collapsed"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding}"
                                           Foreground="#222222"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="RowBorder" Property="Background" Value="#E8F4FF"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border Grid.Row="3" Margin="0,10,0,0" Background="#FFFFFF" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="8">
            <StackPanel Margin="10">
                <TextBlock Text="更新说明" Foreground="#555555" FontSize="12" FontWeight="SemiBold"/>
                <TextBox x:Name="ReadmeTextBox"
                         Margin="0,6,0,0"
                         Height="90"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="#333333"
                         Text="选择版本后显示说明..."/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" Foreground="#444444" FontSize="12" Text="准备就绪"/>
            <ProgressBar x:Name="DownloadProgress" Height="14" Margin="0,8,0,0" Minimum="0" Maximum="100"/>
            <TextBlock x:Name="ProgressDetailText" Margin="0,4,0,0" Foreground="#666666" FontSize="12" Text=""/>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="RefreshButton"
                    Content="刷新列表"
                    Width="96"
                    Height="34"
                    Margin="0,0,8,0"
                    Click="RefreshButton_Click"/>
            <Button x:Name="RollbackButton"
                    Content="开始回退"
                    Width="96"
                    Height="34"
                    Margin="0,0,8,0"
                    Click="RollbackButton_Click"/>
            <Button x:Name="CloseButton"
                    Content="关闭"
                    Width="96"
                    Height="34"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
