<UserControl x:Class="ImageColorChanger.UI.Controls.BorderSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="287"
             Background="#F7F7F7">
    <UserControl.Resources>
        <Geometry x:Key="IconLocalPipette">M14.5 4.5L19.5 9.5L17 12L12 7L14.5 4.5 M11.3 7.7L16.3 12.7L8.8 20.2H4V15.4L11.3 7.7</Geometry>
        <Style x:Key="ColorPanelFlatIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#15000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#22000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BorderLinePreviewButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,0,4,4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#D2D2D2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#12000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1F000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border BorderBrush="#E0E0E0"
            BorderThickness="1,0,0,0"
            CornerRadius="8,0,0,8"
            Background="#F7F7F7">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="7">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="纯浅色"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#2F2F2F"
                               VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right"
                               Text="✎"
                               FontSize="16"
                               Foreground="#555555"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <WrapPanel x:Name="QuickColorPanel"
                               Grid.Row="0"
                               ItemWidth="24"
                               ItemHeight="24"
                               Margin="0,0,0,12"/>

                    <Separator Grid.Row="1" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="2"
                               Text="自定义"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#2F2F2F"
                               Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,14">
                        <Border x:Name="RecentColorPreview1"
                                Width="22"
                                Height="22"
                                Margin="0,0,7,0"
                                CornerRadius="11"
                                BorderBrush="#C6C6C6"
                                BorderThickness="1"
                                Background="#EBEFF3"/>
                        <Border x:Name="RecentColorPreview2"
                                Width="22"
                                Height="22"
                                Margin="0,0,7,0"
                                CornerRadius="11"
                                BorderBrush="#C6C6C6"
                                BorderThickness="1"
                                Background="#8B4747"/>
                        <Button x:Name="BtnOpenCustomColor"
                                Style="{StaticResource ColorPanelFlatIconButtonStyle}"
                                Margin="0,0,7,0"
                                Click="BtnOpenCustomColor_Click"
                                ToolTip="自定义颜色">
                            <Viewbox Width="20" Height="20" Stretch="Uniform">
                                <Grid Width="24" Height="24">
                                    <Ellipse Width="22"
                                             Height="22"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Stroke="{DynamicResource BrushIconDefault}"
                                             StrokeThickness="2"
                                             Fill="Transparent"/>
                                    <Path Data="{StaticResource IconLucidePlus}"
                                          Width="12"
                                          Height="12"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Stretch="Uniform"
                                          Stroke="{DynamicResource BrushIconDefault}"
                                          StrokeThickness="2.4"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Fill="Transparent"/>
                                </Grid>
                            </Viewbox>
                        </Button>
                        <Button x:Name="BtnPicker"
                                Style="{StaticResource ColorPanelFlatIconButtonStyle}"
                                Margin="0,0,7,0"
                                ToolTip="吸管（预留）">
                            <Viewbox Width="14" Height="14" Stretch="Uniform">
                                <Path Data="{StaticResource IconLocalPipette}"
                                      Width="24"
                                      Height="24"
                                      Stretch="Uniform"
                                      Stroke="{DynamicResource BrushIconDefault}"
                                      StrokeThickness="2.1"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>

                    <Separator Grid.Row="4" Margin="0,0,0,10" VerticalAlignment="Top"/>
                </Grid>

                <UniformGrid x:Name="PaletteGrid"
                             Grid.Row="2"
                             Margin="0,0,0,10"
                             Columns="10"/>

                <StackPanel Grid.Row="3" Margin="0,0,0,8">
                    <TextBlock x:Name="TxtWidthLabel"
                               Text="边框 2 px"
                               Foreground="#666666"
                               FontSize="12"
                               Margin="0,0,0,6"/>
                    <Slider x:Name="WidthSlider"
                            Minimum="0"
                            Maximum="20"
                            Value="2"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Margin="0,0,0,10"
                            ValueChanged="WidthSlider_ValueChanged"/>

                    <TextBlock x:Name="TxtCornerRadiusLabel"
                               Text="圆角 0 px"
                               Foreground="#666666"
                               FontSize="12"
                               Margin="0,0,0,6"/>
                    <Slider x:Name="CornerRadiusSlider"
                            Minimum="0"
                            Maximum="100"
                            Value="0"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Margin="0,0,0,10"
                            ValueChanged="CornerRadiusSlider_ValueChanged"/>

                    <TextBlock x:Name="TxtOpacityLabel"
                               Text="透明度 0%"
                               Foreground="#666666"
                               FontSize="12"
                               Margin="0,0,0,6"/>
                    <Slider x:Name="OpacitySlider"
                            Minimum="0"
                            Maximum="100"
                            Value="0"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Margin="0,0,0,10"
                            ValueChanged="OpacitySlider_ValueChanged"/>

                    <TextBlock Text="边框样式"
                               Foreground="#666666"
                               FontSize="12"
                               Margin="0,0,0,6"/>
                    <WrapPanel>
                        <Button x:Name="BtnBorderStyleSolid"
                                Style="{StaticResource BorderLinePreviewButtonStyle}"
                                ToolTip="实线"
                                Click="BtnBorderStyleSolid_Click">
                            <Canvas Width="28" Height="12">
                                <Line X1="2" Y1="6" X2="26" Y2="6"
                                      Stroke="#2F2F2F"
                                      StrokeThickness="2.4"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Button>
                        <Button x:Name="BtnBorderStyleDashed"
                                Style="{StaticResource BorderLinePreviewButtonStyle}"
                                ToolTip="虚线"
                                Click="BtnBorderStyleDashed_Click">
                            <Canvas Width="28" Height="12">
                                <Line X1="2" Y1="6" X2="26" Y2="6"
                                      Stroke="#2F2F2F"
                                      StrokeThickness="2.4"
                                      StrokeDashArray="4,3"
                                      StrokeDashCap="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Button>
                        <Button x:Name="BtnBorderStyleDotted"
                                Style="{StaticResource BorderLinePreviewButtonStyle}"
                                ToolTip="点线"
                                Click="BtnBorderStyleDotted_Click">
                            <Canvas Width="28" Height="12">
                                <Line X1="2" Y1="6" X2="26" Y2="6"
                                      Stroke="#2F2F2F"
                                      StrokeThickness="2.4"
                                      StrokeDashArray="0.5,3.2"
                                      StrokeDashCap="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Button>
                        <Button x:Name="BtnBorderStyleDashDot"
                                Style="{StaticResource BorderLinePreviewButtonStyle}"
                                ToolTip="点划线"
                                Click="BtnBorderStyleDashDot_Click">
                            <Canvas Width="28" Height="12">
                                <Line X1="2" Y1="6" X2="26" Y2="6"
                                      Stroke="#2F2F2F"
                                      StrokeThickness="2.4"
                                      StrokeDashArray="4,2.6,0.8,2.6"
                                      StrokeDashCap="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Button>
                        <Button x:Name="BtnBorderStyleLongDash"
                                Style="{StaticResource BorderLinePreviewButtonStyle}"
                                Margin="0,0,0,4"
                                ToolTip="长虚线"
                                Click="BtnBorderStyleLongDash_Click">
                            <Canvas Width="28" Height="12">
                                <Line X1="2" Y1="6" X2="26" Y2="6"
                                      Stroke="#2F2F2F"
                                      StrokeThickness="2.4"
                                      StrokeDashArray="7,3.6"
                                      StrokeDashCap="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Button>
                    </WrapPanel>
                </StackPanel>

                <Button x:Name="BtnNoBorder"
                        Grid.Row="4"
                        Height="32"
                        Margin="0,6,0,0"
                        Padding="0"
                        BorderBrush="#CFCFCF"
                        BorderThickness="1"
                        Background="#F7F7F7"
                        Cursor="Hand"
                        Click="BtnNoBorder_Click"
                        ToolTip="清除边框（透明）">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="16">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#F0F0F0"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#E8E8E8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Data="M12 3C9 7 6.5 9.8 6.5 13A5.5 5.5 0 0 0 17.5 13C17.5 9.8 15 7 12 3 M4 4L20 20"
                              Width="16"
                              Height="16"
                              Margin="0,0,8,0"
                              Stretch="Uniform"
                              Stroke="{DynamicResource BrushIconDefault}"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Fill="Transparent"/>
                        <TextBlock Text="透明" FontSize="16" Foreground="#3F3F3F" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
