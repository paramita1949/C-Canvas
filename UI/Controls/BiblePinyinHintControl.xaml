<UserControl x:Class="ImageColorChanger.UI.Controls.BiblePinyinHintControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="Auto"
             Visibility="Collapsed">
    <Border Background="#DD000000"
            BorderBrush="#FF5722"
            BorderThickness="2"
            CornerRadius="8"
            Padding="12">
        <StackPanel>
            <!-- 输入显示 -->
            <TextBlock x:Name="InputText" 
                       Text="" 
                       Foreground="#FFD700" 
                       FontSize="18" 
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0,0,0,6"/>
            
            <!-- 匹配结果（每行最多6个，行内居中） -->
            <StackPanel x:Name="MatchResultsPanel"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,0">
                <!-- 动态添加候选行 -->
            </StackPanel>

            <!-- 经文预览 -->
            <Border x:Name="PreviewPanel"
                    Visibility="Collapsed"
                    Margin="0,8,0,0"
                    Padding="8"
                    CornerRadius="6"
                    BorderBrush="#66FFFFFF"
                    BorderThickness="1"
                    Background="#33000000">
                <StackPanel>
                    <TextBlock x:Name="PreviewReferenceText"
                               Text=""
                               Foreground="#FF80CBC4"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,0,0,0"
                               Visibility="Collapsed"/>
                    <ScrollViewer x:Name="PreviewScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="220">
                        <TextBlock x:Name="PreviewContentText"
                                   Text=""
                                   Foreground="#FFF5F5F5"
                                   FontSize="15"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>

