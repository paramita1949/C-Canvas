<UserControl x:Class="ImageColorChanger.UI.Controls.BiblePinyinHintControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="Auto"
             Visibility="Collapsed">
    <UserControl.Resources>
        <Style x:Key="PreviewVerseListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Margin" Value="0,1,0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource BrushBiblePinyinPreviewSelection}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="Transparent" />
                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="0" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource BrushBiblePinyinPreviewHover}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource BrushBiblePinyinPreviewHoverBorder}" />
                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="1" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource BrushBiblePinyinPreviewSelection}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="Transparent" />
                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="0" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushBiblePinyinPreviewHover}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushBiblePinyinPreviewSelection}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Border Background="#DD000000"
            BorderBrush="#FF5722"
            BorderThickness="2"
            CornerRadius="8"
            Padding="12">
        <StackPanel>
            <!-- 输入显示 -->
            <TextBlock x:Name="InputText" 
                       Text="" 
                       Foreground="#FFD700" 
                       FontSize="18" 
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0,0,0,6"/>
            
            <!-- 匹配结果（每行最多6个，行内居中） -->
            <StackPanel x:Name="MatchResultsPanel"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,0">
                <!-- 动态添加候选行 -->
            </StackPanel>

            <!-- 经文预览 -->
            <Border x:Name="PreviewPanel"
                    Visibility="Collapsed"
                    Margin="0,8,0,0"
                    Padding="8"
                    CornerRadius="6"
                    BorderBrush="#66FFFFFF"
                    BorderThickness="1"
                    Background="#33000000">
                <StackPanel>
                    <TextBlock x:Name="PreviewReferenceText"
                               Text=""
                               Foreground="#FF80CBC4"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,0,0,0"
                               Visibility="Collapsed"/>
                    <ScrollViewer x:Name="PreviewScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="220">
                        <ScrollViewer.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource CompactScrollBarStyleDark}"/>
                        </ScrollViewer.Resources>
                        <ListBox x:Name="PreviewVerseList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemContainerStyle="{StaticResource PreviewVerseListItemStyle}"
                                  SelectionMode="Single"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 PreviewMouseWheel="PreviewVerseList_PreviewMouseWheel"
                                 PreviewMouseLeftButtonUp="PreviewVerseList_PreviewMouseLeftButtonUp">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayText}"
                                               Foreground="{Binding Foreground}"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>

