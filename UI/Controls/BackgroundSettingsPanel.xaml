<UserControl x:Class="ImageColorChanger.UI.Controls.BackgroundSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="287"
             Background="#F7F7F7">
    <UserControl.Resources>
        <Geometry x:Key="IconLocalPipette">M14.5 4.5L19.5 9.5L17 12L12 7L14.5 4.5 M11.3 7.7L16.3 12.7L8.8 20.2H4V15.4L11.3 7.7</Geometry>
        <Style x:Key="ColorPanelFlatIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#15000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#22000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border BorderBrush="#E0E0E0"
            BorderThickness="1,0,0,0"
            CornerRadius="8,0,0,8"
            Background="#F7F7F7">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="7">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnSolidTab"
                            Grid.Column="0"
                            Height="34"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnSolidTab_Click">
                        <StackPanel>
                            <TextBlock x:Name="TxtSolidTab"
                                       Text="纯色"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#222222"
                                       HorizontalAlignment="Center"/>
                            <Border x:Name="SolidTabUnderline"
                                    Height="3"
                                    Margin="8,4,8,0"
                                    Background="#F7C100"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnGradientTab"
                            Grid.Column="1"
                            Height="34"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnGradientTab_Click">
                        <StackPanel>
                            <TextBlock x:Name="TxtGradientTab"
                                       Text="渐变"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#666666"
                                       HorizontalAlignment="Center"/>
                            <Border x:Name="GradientTabUnderline"
                                    Height="3"
                                    Margin="8,4,8,0"
                                    Background="#F7C100"
                                    Visibility="Collapsed"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid x:Name="SolidView" Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="纯浅色"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#2F2F2F"
                                   VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="✎"
                                   FontSize="16"
                                   Foreground="#555555"
                                   VerticalAlignment="Center"/>
                    </DockPanel>

                    <WrapPanel x:Name="SolidQuickColorPanel"
                               Grid.Row="1"
                               ItemWidth="24"
                               ItemHeight="24"
                               Margin="0,0,0,12"/>

                    <Separator Grid.Row="2" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="3"
                               Text="自定义"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#2F2F2F"
                               Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal"
                                Margin="0,0,0,14">
                        <Border x:Name="SolidRecentColorPreview1"
                                Width="22"
                                Height="22"
                                Margin="0,0,7,0"
                                CornerRadius="16"
                                BorderBrush="#C6C6C6"
                                BorderThickness="1"
                                Background="#EBEFF3"/>
                        <Border x:Name="SolidRecentColorPreview2"
                                Width="22"
                                Height="22"
                                Margin="0,0,7,0"
                                CornerRadius="16"
                                BorderBrush="#C6C6C6"
                                BorderThickness="1"
                                Background="#8B4747"/>
                        <Button x:Name="BtnOpenSolidCustomColor"
                                Style="{StaticResource ColorPanelFlatIconButtonStyle}"
                                Width="22"
                                Height="22"
                                Margin="0,0,7,0"
                                Cursor="Hand"
                                Click="BtnOpenSolidCustomColor_Click"
                                ToolTip="自定义颜色">
                            <Viewbox Width="16" Height="16" Stretch="Uniform">
                                <Grid Width="24" Height="24">
                                    <Ellipse Width="20"
                                             Height="20"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Stroke="{DynamicResource BrushIconDefault}"
                                             StrokeThickness="2"
                                             Fill="Transparent"/>
                                    <Path Data="{StaticResource IconLucidePlus}"
                                          Width="10"
                                          Height="10"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Stretch="Uniform"
                                          Stroke="{DynamicResource BrushIconDefault}"
                                          StrokeThickness="2.1"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Fill="Transparent"/>
                                </Grid>
                            </Viewbox>
                        </Button>
                        <Button x:Name="BtnSolidPicker"
                                Style="{StaticResource ColorPanelFlatIconButtonStyle}"
                                Width="22"
                                Height="22"
                                Margin="0,0,7,0"
                                Cursor="Hand"
                                ToolTip="吸管（预留）"
                                >
                            <Viewbox Width="14" Height="14" Stretch="Uniform">
                                <Path Data="{StaticResource IconLocalPipette}"
                                      Width="24"
                                      Height="24"
                                      Stretch="Uniform"
                                      Stroke="{DynamicResource BrushIconDefault}"
                                      StrokeThickness="2.1"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>

                    <Separator Grid.Row="5" Margin="0,0,0,10" VerticalAlignment="Top"/>

                    <UniformGrid x:Name="SolidPaletteGrid"
                                 Grid.Row="6"
                                 Margin="0,18,0,0"
                                 Columns="10"/>
                </Grid>

                <Grid x:Name="GradientView" Grid.Row="1" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="纯浅色"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#2F2F2F"
                                   VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="✎"
                                   FontSize="16"
                                   Foreground="#555555"
                                   VerticalAlignment="Center"/>
                    </DockPanel>

                    <WrapPanel x:Name="GradientQuickPanel"
                               Grid.Row="1"
                               ItemWidth="24"
                               ItemHeight="24"
                               Margin="0,0,0,12"/>

                    <Separator Grid.Row="2" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="3"
                               Text="自定义"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#2F2F2F"
                               Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal"
                                Margin="0,0,0,14">
                        <Border x:Name="GradientRecentColorPreview1"
                                Width="22"
                                Height="22"
                                Margin="0,0,7,0"
                                CornerRadius="16"
                                BorderBrush="#C6C6C6"
                                BorderThickness="1"
                                Background="#EBEFF3"/>
                        <Button x:Name="BtnOpenGradientCustomColor"
                                Style="{StaticResource ColorPanelFlatIconButtonStyle}"
                                Width="22"
                                Height="22"
                                Margin="0,0,7,0"
                                Cursor="Hand"
                                Click="BtnOpenGradientCustomColor_Click"
                                ToolTip="自定义渐变">
                            <Viewbox Width="16" Height="16" Stretch="Uniform">
                                <Grid Width="24" Height="24">
                                    <Ellipse Width="20"
                                             Height="20"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Stroke="{DynamicResource BrushIconDefault}"
                                             StrokeThickness="2"
                                             Fill="Transparent"/>
                                    <Path Data="{StaticResource IconLucidePlus}"
                                          Width="10"
                                          Height="10"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Stretch="Uniform"
                                          Stroke="{DynamicResource BrushIconDefault}"
                                          StrokeThickness="2.1"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Fill="Transparent"/>
                                </Grid>
                            </Viewbox>
                        </Button>
                        <Button x:Name="BtnGradientPicker"
                                Style="{StaticResource ColorPanelFlatIconButtonStyle}"
                                Width="22"
                                Height="22"
                                Margin="0,0,7,0"
                                Cursor="Hand"
                                ToolTip="吸管（预留）"
                                >
                            <Viewbox Width="14" Height="14" Stretch="Uniform">
                                <Path Data="{StaticResource IconLocalPipette}"
                                      Width="24"
                                      Height="24"
                                      Stretch="Uniform"
                                      Stroke="{DynamicResource BrushIconDefault}"
                                      StrokeThickness="2.1"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"/>
                            </Viewbox>
                        </Button>

                        <Border Width="1"
                                Height="18"
                                Margin="2,0,6,0"
                                VerticalAlignment="Center"
                                Background="#D0D0D0"/>

                        <Button x:Name="BtnGradientDirTopToBottom"
                                Style="{StaticResource ColorPanelFlatIconButtonStyle}"
                                Width="24"
                                Height="22"
                                Margin="0,0,2,0"
                                ToolTip="上渐变"
                                Click="BtnGradientDirection_Click"
                                Tag="TopToBottom">
                            <TextBlock Text="上" FontSize="11" Foreground="#444444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnGradientDirBottomToTop"
                                Style="{StaticResource ColorPanelFlatIconButtonStyle}"
                                Width="24"
                                Height="22"
                                Margin="0,0,2,0"
                                ToolTip="下渐变"
                                Click="BtnGradientDirection_Click"
                                Tag="BottomToTop">
                            <TextBlock Text="下" FontSize="11" Foreground="#444444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnGradientDirLeftToRight"
                                Style="{StaticResource ColorPanelFlatIconButtonStyle}"
                                Width="24"
                                Height="22"
                                Margin="0,0,2,0"
                                ToolTip="左到右"
                                Click="BtnGradientDirection_Click"
                                Tag="LeftToRight">
                            <TextBlock Text="左" FontSize="11" Foreground="#444444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnGradientDirRadialCenter"
                                Style="{StaticResource ColorPanelFlatIconButtonStyle}"
                                Width="24"
                                Height="22"
                                ToolTip="中间渐变"
                                Click="BtnGradientDirection_Click"
                                Tag="RadialCenter">
                            <TextBlock Text="中" FontSize="11" Foreground="#444444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>

                    <Separator Grid.Row="5" Margin="0,0,0,10" VerticalAlignment="Top"/>

                    <UniformGrid x:Name="GradientPaletteGrid"
                                 Grid.Row="6"
                                 Margin="0,18,0,0"
                                 Columns="7"/>
                </Grid>

                <Separator Grid.Row="2" Margin="0,8,0,12"/>

                <StackPanel Grid.Row="3">
                    <TextBlock x:Name="TxtCornerRadiusLabel"
                               Text="圆角 0 px"
                               Foreground="#666666"
                               FontSize="12"
                               Margin="0,0,0,8"/>
                    <Slider x:Name="CornerRadiusSlider"
                            Minimum="0"
                            Maximum="100"
                            Value="0"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Margin="0,0,0,16"
                            ValueChanged="CornerRadiusSlider_ValueChanged"/>

                    <TextBlock x:Name="TxtOpacityLabel"
                               Text="透明度 100%"
                               Foreground="#666666"
                               FontSize="12"
                               Margin="0,0,0,8"/>
                    <Slider x:Name="OpacitySlider"
                            Minimum="0"
                            Maximum="100"
                            Value="100"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Margin="0,0,0,10"
                            ValueChanged="OpacitySlider_ValueChanged"/>
                </StackPanel>

                <Button x:Name="BtnNoFill"
                        Grid.Row="4"
                        Height="32"
                        Margin="0,8,0,0"
                        Padding="0"
                        BorderBrush="#CFCFCF"
                        BorderThickness="1"
                        Background="#F7F7F7"
                        Cursor="Hand"
                        Click="BtnNoFill_Click"
                        ToolTip="清除填充（透明）">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="24">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#F0F0F0"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#E8E8E8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Path Data="M12 3C9 7 6.5 9.8 6.5 13A5.5 5.5 0 0 0 17.5 13C17.5 9.8 15 7 12 3 M4 4L20 20"
                              Width="16"
                              Height="16"
                              Margin="0,0,10,0"
                              Stretch="Uniform"
                              Stroke="{DynamicResource BrushIconDefault}"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Fill="Transparent"/>
                        <TextBlock Text="透明"
                                   FontSize="16"
                                   Foreground="#3F3F3F"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>

