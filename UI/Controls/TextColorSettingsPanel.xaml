<UserControl x:Class="ImageColorChanger.UI.Controls.TextColorSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="287"
             Background="#F7F7F7">
    <UserControl.Resources>
        <Geometry x:Key="IconLocalPipette">M14.5 4.5L19.5 9.5L17 12L12 7L14.5 4.5 M11.3 7.7L16.3 12.7L8.8 20.2H4V15.4L11.3 7.7</Geometry>
        <Style x:Key="ColorPanelFlatIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#15000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#22000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#F7F7F7" CornerRadius="10">
        <Grid Margin="7">
            <Grid x:Name="PaletteView">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnSolidTab"
                                Grid.Column="0"
                                Height="34"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnSolidTab_Click">
                            <StackPanel>
                                <TextBlock x:Name="TxtSolidTab"
                                           Text="纯色"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#222222"
                                           HorizontalAlignment="Center"/>
                                <Border x:Name="SolidTabUnderline"
                                        Height="3"
                                        Margin="8,4,8,0"
                                        Background="#F7C100"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnGradientTab"
                                Grid.Column="1"
                                Height="34"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnGradientTab_Click">
                            <StackPanel>
                                <TextBlock x:Name="TxtGradientTab"
                                           Text="渐变"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#666666"
                                           HorizontalAlignment="Center"/>
                                <Border x:Name="GradientTabUnderline"
                                        Height="3"
                                        Margin="8,4,8,0"
                                        Background="#F7C100"
                                        Visibility="Collapsed"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <DockPanel Grid.Row="1">
                        <TextBlock x:Name="TxtPaletteTitle"
                                   Text="纯浅色"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#2F2F2F"
                                   VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="✎"
                                   FontSize="16"
                                   Foreground="#555555"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Grid>

                <WrapPanel x:Name="QuickColorPanel"
                           Grid.Row="1"
                           ItemWidth="24"
                           ItemHeight="24"
                           Margin="0,0,0,12"/>

                <Separator Grid.Row="2" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="3"
                           Text="自定义"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#2F2F2F"
                           Margin="0,0,0,10"/>

                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,14">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="RecentColorPreview1"
                                Width="22"
                                Height="22"
                                Margin="0,0,7,0"
                                CornerRadius="16"
                                BorderBrush="#C6C6C6"
                                BorderThickness="1"
                                Background="#EBEFF3"/>
                        <Border x:Name="RecentColorPreview2"
                                Width="22"
                                Height="22"
                                Margin="0,0,7,0"
                                CornerRadius="16"
                                BorderBrush="#C6C6C6"
                                BorderThickness="1"
                                Background="#8B4747"/>
                        <Button x:Name="BtnOpenCustomEditor"
                                Style="{StaticResource ColorPanelFlatIconButtonStyle}"
                                Width="22"
                                Height="22"
                                Margin="0,0,7,0"
                                Cursor="Hand"
                                Click="BtnOpenCustomEditor_Click"
                                ToolTip="自定义颜色">
                            <Viewbox Width="20" Height="20" Stretch="Uniform">
                                <Grid Width="24" Height="24">
                                    <Ellipse Width="22"
                                             Height="22"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Stroke="{DynamicResource BrushIconDefault}"
                                             StrokeThickness="2"
                                             Fill="Transparent"/>
                                    <Path Data="{StaticResource IconLucidePlus}"
                                          Width="12"
                                          Height="12"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Stretch="Uniform"
                                          Stroke="{DynamicResource BrushIconDefault}"
                                          StrokeThickness="2.4"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Fill="Transparent"/>
                                </Grid>
                            </Viewbox>
                        </Button>
                        <Button x:Name="BtnPicker"
                                Style="{StaticResource ColorPanelFlatIconButtonStyle}"
                                Width="22"
                                Height="22"
                                Cursor="Hand"
                                ToolTip="吸管（预留）">
                            <Viewbox Width="14" Height="14" Stretch="Uniform">
                                <Path Data="{StaticResource IconLocalPipette}"
                                      Width="24"
                                      Height="24"
                                      Stretch="Uniform"
                                      Stroke="{DynamicResource BrushIconDefault}"
                                      StrokeThickness="2.1"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>

                    <StackPanel x:Name="GradientDirectionPanel"
                                Orientation="Horizontal"
                                Visibility="Collapsed">
                        <Border Width="1"
                                Height="18"
                                Margin="2,0,6,0"
                                VerticalAlignment="Center"
                                Background="#D0D0D0"/>
                        <Button x:Name="BtnGradientDirTopToBottom"
                                Style="{StaticResource ColorPanelFlatIconButtonStyle}"
                                Width="28"
                                Height="24"
                                Margin="0,0,3,0"
                                ToolTip="上渐变"
                                Click="BtnGradientDirection_Click"
                                Tag="TopToBottom">
                            <TextBlock Text="上" FontSize="14" FontWeight="SemiBold" Foreground="#444444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnGradientDirBottomToTop"
                                Style="{StaticResource ColorPanelFlatIconButtonStyle}"
                                Width="28"
                                Height="24"
                                Margin="0,0,3,0"
                                ToolTip="下渐变"
                                Click="BtnGradientDirection_Click"
                                Tag="BottomToTop">
                            <TextBlock Text="下" FontSize="14" FontWeight="SemiBold" Foreground="#444444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnGradientDirLeftToRight"
                                Style="{StaticResource ColorPanelFlatIconButtonStyle}"
                                Width="28"
                                Height="24"
                                Margin="0,0,3,0"
                                ToolTip="左到右"
                                Click="BtnGradientDirection_Click"
                                Tag="LeftToRight">
                            <TextBlock Text="左" FontSize="14" FontWeight="SemiBold" Foreground="#444444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnGradientDirRightToLeft"
                                Style="{StaticResource ColorPanelFlatIconButtonStyle}"
                                Width="28"
                                Height="24"
                                Margin="0,0,3,0"
                                ToolTip="右到左"
                                Click="BtnGradientDirection_Click"
                                Tag="RightToLeft">
                            <TextBlock Text="右" FontSize="14" FontWeight="SemiBold" Foreground="#444444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnGradientDirRadialCenter"
                                Style="{StaticResource ColorPanelFlatIconButtonStyle}"
                                Width="28"
                                Height="24"
                                ToolTip="中间渐变"
                                Click="BtnGradientDirection_Click"
                                Tag="RadialCenter">
                            <TextBlock Text="中" FontSize="14" FontWeight="SemiBold" Foreground="#444444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <Separator Grid.Row="5" Margin="0,0,0,10" VerticalAlignment="Top"/>

                <UniformGrid x:Name="PaletteGrid"
                             Grid.Row="5"
                             Margin="0,18,0,0"
                             Columns="10"/>

                <StackPanel Grid.Row="6" Margin="0,12,0,0">
                    <TextBlock x:Name="TxtOpacityLabel"
                               Text="透明度 0%"
                               Foreground="#666666"
                               FontSize="12"
                               Margin="0,0,0,6"/>
                    <Slider x:Name="OpacitySlider"
                            Minimum="0"
                            Maximum="100"
                            Value="0"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            ValueChanged="OpacitySlider_ValueChanged"/>
                </StackPanel>

                <Button x:Name="BtnHighlightTransparent"
                        Grid.Row="7"
                        Height="32"
                        Margin="0,12,0,0"
                        Padding="0"
                        Visibility="Collapsed"
                        BorderBrush="#CFCFCF"
                        BorderThickness="1"
                        Background="#F7F7F7"
                        Cursor="Hand"
                        Click="BtnHighlightTransparent_Click"
                        ToolTip="清除高亮（透明）">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="24">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#F0F0F0"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#E8E8E8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Data="M12 3C9 7 6.5 9.8 6.5 13A5.5 5.5 0 0 0 17.5 13C17.5 9.8 15 7 12 3 M4 4L20 20"
                              Width="16"
                              Height="16"
                              Margin="0,0,10,0"
                              Stretch="Uniform"
                              Stroke="{DynamicResource BrushIconDefault}"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Fill="Transparent"/>
                        <TextBlock Text="透明"
                                   FontSize="16"
                                   Foreground="#3F3F3F"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Grid x:Name="CustomEditorView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Height="290"
                        Margin="0,0,0,12"
                        BorderBrush="#D1D1D1"
                        BorderThickness="1"
                        CornerRadius="8"
                        Background="#000000">
                    <Grid x:Name="SvPickerHost"
                          ClipToBounds="True"
                          MouseLeftButtonDown="SvPickerHost_MouseLeftButtonDown"
                          MouseMove="SvPickerHost_MouseMove"
                          MouseLeftButtonUp="SvPickerHost_MouseLeftButtonUp"
                          SizeChanged="SvPickerHost_SizeChanged">
                        <Rectangle x:Name="SvHueBaseRect"/>
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                    <GradientStop Color="#00000000" Offset="0"/>
                                    <GradientStop Color="#FF000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Canvas IsHitTestVisible="False">
                            <Ellipse x:Name="SvSelector"
                                     Width="24"
                                     Height="24"
                                     Stroke="#F2F2F2"
                                     StrokeThickness="4"
                                     Fill="Transparent">
                                <Ellipse.Effect>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="6" Opacity="0.35" Color="#000000"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Canvas>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="86"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="76"
                            Height="76"
                            CornerRadius="38"
                            BorderBrush="#D1D1D1"
                            BorderThickness="1"
                            Background="{Binding ElementName=CurrentColorPreview, Path=Fill}"/>

                    <Button Grid.Column="2"
                            Width="70"
                            Height="70"
                            BorderBrush="#C9C9C9"
                            BorderThickness="1"
                            Background="#F7F7F7"
                            Cursor="Hand"
                            ToolTip="吸管（预留）">
                        <Viewbox Width="32" Height="32" Stretch="Uniform">
                            <Path Data="{StaticResource IconLocalPipette}"
                                  Width="24"
                                  Height="24"
                                  Stretch="Uniform"
                                  Stroke="{DynamicResource BrushIconDefault}"
                                  StrokeThickness="2.2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent"/>
                        </Viewbox>
                    </Button>

                    <Grid Grid.Column="4" VerticalAlignment="Center">
                        <Border Height="18" CornerRadius="9">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#FF0000" Offset="0"/>
                                    <GradientStop Color="#FFFF00" Offset="0.17"/>
                                    <GradientStop Color="#00FF00" Offset="0.33"/>
                                    <GradientStop Color="#00FFFF" Offset="0.5"/>
                                    <GradientStop Color="#0000FF" Offset="0.67"/>
                                    <GradientStop Color="#FF00FF" Offset="0.83"/>
                                    <GradientStop Color="#FF0000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Slider x:Name="HueSlider"
                                Minimum="0"
                                Maximum="360"
                                ValueChanged="HueSlider_ValueChanged"
                                Background="Transparent"
                                Foreground="Transparent"/>
                    </Grid>
                </Grid>

                <Grid Grid.Row="2" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="十六进制颜色值"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#666666"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtHex"
                                 Height="38"
                                 FontSize="14"
                                 Padding="10,0"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TxtHex_TextChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="红" FontSize="14" FontWeight="SemiBold" Foreground="#666666" Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtR"
                                 Height="38"
                                 FontSize="14"
                                 Padding="10,0"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TxtRgb_TextChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="绿" FontSize="14" FontWeight="SemiBold" Foreground="#666666" Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtG"
                                 Height="38"
                                 FontSize="14"
                                 Padding="10,0"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TxtRgb_TextChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="良" FontSize="14" FontWeight="SemiBold" Foreground="#666666" Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtB"
                                 Height="38"
                                 FontSize="14"
                                 Padding="10,0"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TxtRgb_TextChanged"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="3" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1"
                            Height="40"
                            FontSize="14"
                            Content="取消"
                            BorderBrush="#CACACA"
                            BorderThickness="1"
                            Background="#F7F7F7"
                            Foreground="#2F2F2F"
                            Cursor="Hand"
                            Click="BtnCustomCancel_Click"/>
                    <Button Grid.Column="3"
                            Height="40"
                            FontSize="14"
                            Content="确定"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Background="#F7C100"
                            Foreground="#1D1D1D"
                            Cursor="Hand"
                            Click="BtnCustomConfirm_Click"/>
                </Grid>

                <Ellipse x:Name="CurrentColorPreview" Visibility="Collapsed"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
