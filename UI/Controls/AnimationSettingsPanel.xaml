<UserControl x:Class="ImageColorChanger.UI.Controls.AnimationSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="360" Background="White">

    <Border BorderBrush="#E0E0E0" BorderThickness="1,0,0,0" CornerRadius="8,0,0,8">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,20,20,20">

                <!-- 标题 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Viewbox Width="24" Height="24" Margin="0,0,8,0">
                        <Path Data="{StaticResource IconLucideClapperboard}"
                              Style="{StaticResource LucideIconPathStyle}"
                              Stroke="{StaticResource BrushBrandPrimary}"/>
                    </Viewbox>
                    <TextBlock Text="动画设置"
                               Foreground="#333333"
                               FontSize="16"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 1. 动画开关 -->
                <TextBlock Text="1. 动画开关"
                           Foreground="#666666"
                           FontSize="12"
                           Margin="0,0,0,8"/>

                <CheckBox x:Name="AnimationEnabledCheckBox"
                          Content="启用动画"
                          FontSize="14"
                          Foreground="#333333"
                          Margin="0,0,0,20"
                          VerticalContentAlignment="Center"
                          Checked="AnimationEnabledCheckBox_Checked"
                          Unchecked="AnimationEnabledCheckBox_Unchecked">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="CheckBox">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border x:Name="CheckBoxBorder"
                                                    Grid.Column="0"
                                                    Width="18"
                                                    Height="18"
                                                    BorderBrush="#999999"
                                                    BorderThickness="2"
                                                    Background="White"
                                                    CornerRadius="2"
                                                    Margin="0,0,8,0"
                                                    VerticalAlignment="Center">
                                                <Path x:Name="CheckMark"
                                                      Data="M 0 5 L 5 10 L 12 0"
                                                      Stroke="#2196F3"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      Stretch="Uniform"
                                                      Margin="2"
                                                      Visibility="Collapsed"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"/>
                                            </Border>
                                            <ContentPresenter Grid.Column="1"
                                                            Content="{TemplateBinding Content}"
                                                            VerticalAlignment="Center"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="#E3F2FD"/>
                                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#2196F3"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#2196F3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>

                <!-- 2. 透明度 -->
                <TextBlock Text="2. 透明度"
                           Foreground="#666666"
                           FontSize="12"
                           Margin="0,0,0,8"/>

                <UniformGrid x:Name="OpacityGrid"
                             Columns="5"
                             Rows="2"
                             Margin="0,0,0,20">
                    <!-- 透明度按钮将在代码中动态生成 -->
                </UniformGrid>

                <!-- 3. 动画时长 -->
                <TextBlock Text="3. 动画时长（毫秒）"
                           Foreground="#666666"
                           FontSize="12"
                           Margin="0,0,0,8"/>

                <UniformGrid x:Name="AnimationDurationGrid"
                             Columns="4"
                             Rows="2"
                             Margin="0,0,0,20">
                    <!-- 动画时长按钮将在代码中动态生成 -->
                </UniformGrid>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>

