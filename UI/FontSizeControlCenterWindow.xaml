<Window x:Class="ImageColorChanger.UI.FontSizeControlCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="字体与字号"
        Width="680"
        Height="500"
        MinWidth="660"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BrushControlPanelBackground}"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushControlPanelBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushControlPanelTextStrong}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushControlPanelTextMuted}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ModernInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="72"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushControlPanelInputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushControlPanelTextStrong}"/>
        </Style>

        <Style x:Key="StepButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="{DynamicResource BrushControlPanelStepBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushControlPanelStepText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushControlPanelStepBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="12"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="108"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushControlPanelSecondaryText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushControlPanelInputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="14"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource BrushControlPanelAccent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushControlPanelAccent}"/>
        </Style>

        <Style x:Key="ModernSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Track x:Name="PART_Track" Minimum="{TemplateBinding Minimum}" Maximum="{TemplateBinding Maximum}" Value="{TemplateBinding Value}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton IsEnabled="False" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="7" CornerRadius="999" Background="{DynamicResource BrushControlPanelAccent}" VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="16" Height="16" Background="{DynamicResource BrushControlPanelAccent}" BorderBrush="White" BorderThickness="2">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="{TemplateBinding Background}"
                                                         Stroke="{TemplateBinding BorderBrush}"
                                                         StrokeThickness="{TemplateBinding BorderThickness}">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.2"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton IsEnabled="False" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="7" CornerRadius="999" Background="{DynamicResource BrushControlPanelAccentSoft}" VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="字体与字号" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource BrushControlPanelTextStrong}"/>
            <TextBlock Text="拖动滑条或输入数值，步长 0.5。"
                       Margin="0,6,0,0"
                       FontSize="13"
                       Foreground="{DynamicResource BrushControlPanelTextMuted}"/>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Background="{DynamicResource BrushControlPanelCardBackground}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Background="{DynamicResource BrushControlPanelSubCardA}"
                            BorderBrush="{DynamicResource BrushControlPanelBorder}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="文件区" Style="{StaticResource SectionTitleStyle}"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="86"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="文件夹字号" Style="{StaticResource FieldLabelStyle}"/>
                                <Slider x:Name="FolderFontSizeSlider" Grid.Column="1" Style="{StaticResource ModernSliderStyle}" Minimum="8" Maximum="40" TickFrequency="0.5" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="FontSizeSlider_ValueChanged"/>
                                <Button x:Name="FolderFontSizeMinusButton" Grid.Column="3" Content="−" Style="{StaticResource StepButtonStyle}" Click="FontSizeStepButton_Click"/>
                                <TextBox x:Name="FolderFontSizeTextBox" Grid.Column="5" Style="{StaticResource ModernInputStyle}" TextChanged="FontSizeTextBox_TextChanged" LostFocus="FontSizeTextBox_LostFocus" KeyDown="FontSizeTextBox_KeyDown"/>
                                <Button x:Name="FolderFontSizePlusButton" Grid.Column="7" Content="+" Style="{StaticResource StepButtonStyle}" Click="FontSizeStepButton_Click"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="86"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="文件字号" Style="{StaticResource FieldLabelStyle}"/>
                                <Slider x:Name="FileFontSizeSlider" Grid.Column="1" Style="{StaticResource ModernSliderStyle}" Minimum="8" Maximum="40" TickFrequency="0.5" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="FontSizeSlider_ValueChanged"/>
                                <Button x:Name="FileFontSizeMinusButton" Grid.Column="3" Content="−" Style="{StaticResource StepButtonStyle}" Click="FontSizeStepButton_Click"/>
                                <TextBox x:Name="FileFontSizeTextBox" Grid.Column="5" Style="{StaticResource ModernInputStyle}" TextChanged="FontSizeTextBox_TextChanged" LostFocus="FontSizeTextBox_LostFocus" KeyDown="FontSizeTextBox_KeyDown"/>
                                <Button x:Name="FileFontSizePlusButton" Grid.Column="7" Content="+" Style="{StaticResource StepButtonStyle}" Click="FontSizeStepButton_Click"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="86"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="标签字号" Style="{StaticResource FieldLabelStyle}"/>
                                <Slider x:Name="FolderTagFontSizeSlider" Grid.Column="1" Style="{StaticResource ModernSliderStyle}" Minimum="8" Maximum="28" TickFrequency="0.5" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="FontSizeSlider_ValueChanged"/>
                                <Button x:Name="FolderTagFontSizeMinusButton" Grid.Column="3" Content="−" Style="{StaticResource StepButtonStyle}" Click="FontSizeStepButton_Click"/>
                                <TextBox x:Name="FolderTagFontSizeTextBox" Grid.Column="5" Style="{StaticResource ModernInputStyle}" TextChanged="FontSizeTextBox_TextChanged" LostFocus="FontSizeTextBox_LostFocus" KeyDown="FontSizeTextBox_KeyDown"/>
                                <Button x:Name="FolderTagFontSizePlusButton" Grid.Column="7" Content="+" Style="{StaticResource StepButtonStyle}" Click="FontSizeStepButton_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource BrushControlPanelSubCardB}"
                            BorderBrush="{DynamicResource BrushControlPanelBorder}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="菜单区" Style="{StaticResource SectionTitleStyle}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="86"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="菜单字号" Style="{StaticResource FieldLabelStyle}"/>
                                <Slider x:Name="TopMenuFontSizeSlider" Grid.Column="1" Style="{StaticResource ModernSliderStyle}" Minimum="12" Maximum="40" TickFrequency="0.5" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="FontSizeSlider_ValueChanged"/>
                                <Button x:Name="TopMenuFontSizeMinusButton" Grid.Column="3" Content="−" Style="{StaticResource StepButtonStyle}" Click="FontSizeStepButton_Click"/>
                                <TextBox x:Name="TopMenuFontSizeTextBox" Grid.Column="5" Style="{StaticResource ModernInputStyle}" TextChanged="FontSizeTextBox_TextChanged" LostFocus="FontSizeTextBox_LostFocus" KeyDown="FontSizeTextBox_KeyDown"/>
                                <Button x:Name="TopMenuFontSizePlusButton" Grid.Column="7" Content="+" Style="{StaticResource StepButtonStyle}" Click="FontSizeStepButton_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <DockPanel Grid.Row="4" LastChildFill="False">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button Content="恢复默认" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Click="ResetButton_Click"/>
                <Button Content="关闭" Style="{StaticResource PrimaryButtonStyle}" Click="CloseButton_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
