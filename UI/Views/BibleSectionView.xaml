<UserControl x:Class="ImageColorChanger.UI.Views.BibleSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ImageColorChanger.UI.Controls">
    <Grid x:Name="BibleDisplayContainer" x:FieldModifier="public" Visibility="Collapsed">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                x:Name="BibleChapterTitleBorder"
                x:FieldModifier="public"
                Background="#000000"
                Margin="0,0,24,0"
                Padding="20,15"
                Panel.ZIndex="10">
            <TextBlock x:Name="BibleChapterTitle"
                       x:FieldModifier="public"
                       Text=""
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#FF5722"/>
        </Border>

        <ScrollViewer Grid.Row="0"
                      Grid.RowSpan="2"
                      x:Name="BibleVerseScrollViewer"
                      x:FieldModifier="public"
                      Background="#000000"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0"
                      Focusable="True"
                      InputMethod.PreferredImeState="Off"
                      InputMethod.IsInputMethodEnabled="False">
            <ScrollViewer.Resources>
                <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource CompactScrollBarStyleDark}"/>
            </ScrollViewer.Resources>
            <ScrollViewer.ContextMenu>
                <ContextMenu Style="{StaticResource NoBorderContextMenuStyle}">
                    <MenuItem x:Name="MenuBibleCopyVerses"
                              x:FieldModifier="public"
                              Header="复制经文"/>
                    <MenuItem Header="复制样式">
                        <MenuItem x:Name="MenuBibleCopyStyleShort"
                                  x:FieldModifier="public"
                                  Header="简称样式  示例：[约1:1-2]"
                                  Tag="Short"
                                  IsCheckable="True"
                                  IsChecked="True"
                                  Style="{StaticResource NoCheckMarkMenuItemStyle}"/>
                        <MenuItem x:Name="MenuBibleCopyStyleFull"
                                  x:FieldModifier="public"
                                  Header="全称样式  示例：[约翰福音1:1-2]"
                                  Tag="Full"
                                  IsCheckable="True"
                                  Style="{StaticResource NoCheckMarkMenuItemStyle}"/>
                        <MenuItem x:Name="MenuBibleCopyStyleChapter"
                                  x:FieldModifier="public"
                                  Header="章节样式  示例：[约翰福音1章1-2节]"
                                  Tag="Chapter"
                                  IsCheckable="True"
                                  Style="{StaticResource NoCheckMarkMenuItemStyle}"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem x:Name="MenuBibleClearScreen"
                              x:FieldModifier="public"
                              Header="清屏经文"/>
                </ContextMenu>
            </ScrollViewer.ContextMenu>
            <StackPanel>
                <Border x:Name="BibleChapterTitleScrollBorder"
                        x:FieldModifier="public"
                        Background="#000000"
                        Padding="20,15"
                        Visibility="Collapsed">
                    <TextBlock x:Name="BibleChapterTitleScrollText"
                               x:FieldModifier="public"
                               Text="{Binding ElementName=BibleChapterTitle, Path=Text}"
                               FontFamily="{Binding ElementName=BibleChapterTitle, Path=FontFamily}"
                               FontSize="{Binding ElementName=BibleChapterTitle, Path=FontSize}"
                               FontWeight="{Binding ElementName=BibleChapterTitle, Path=FontWeight}"
                               Foreground="{Binding ElementName=BibleChapterTitle, Path=Foreground}"/>
                </Border>

                <Border Height="20"/>

                <ItemsControl x:Name="BibleVerseList"
                              x:FieldModifier="public"
                              Margin="20,0,20,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="Transparent"
                                    Padding="2"
                                    Cursor="Hand"
                                    Tag="{Binding}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2D2D30"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock x:Name="VerseTextBlock"
                                           FontSize="20"
                                           Foreground="White"
                                           TextWrapping="Wrap"
                                           IsHitTestVisible="False"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Height="20"/>

                <Border x:Name="BibleBottomExtension"
                        x:FieldModifier="public"
                        Height="0"
                        Background="Transparent"/>
            </StackPanel>
        </ScrollViewer>

        <controls:BiblePinyinHintControl Grid.Row="1"
                                         x:Name="BiblePinyinHintControl"
                                         x:FieldModifier="public"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Panel.ZIndex="1000"/>

        <Border Grid.RowSpan="3"
                x:Name="BibleVersionTriggerArea"
                x:FieldModifier="public"
                Height="20"
                VerticalAlignment="Top"
                Background="Transparent"
                Panel.ZIndex="999"/>

        <Border Grid.RowSpan="3"
                x:Name="BibleVersionToolbar"
                x:FieldModifier="public"
                Background="#2D2D30"
                BorderBrush="#3E3E42"
                BorderThickness="0,0,0,1"
                Padding="10,8"
                VerticalAlignment="Top"
                Visibility="Collapsed"
                Panel.ZIndex="1000">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="译本:" Foreground="#A0A0A0" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>

                <RadioButton x:Name="RadioBibleVersionSimplified"
                             x:FieldModifier="public"
                             Content="和合本"
                             Tag="bible.db"
                             GroupName="BibleVersion"
                             IsChecked="True"
                             Foreground="White"
                             FontSize="12"
                             VerticalAlignment="Center"
                             Margin="0,0,15,0"
                             Style="{StaticResource BibleVersionRadioStyle}"/>

                <RadioButton x:Name="RadioBibleVersionTraditional"
                             x:FieldModifier="public"
                             Content="和合本繁体"
                             Tag="hehebenfanti.db"
                             GroupName="BibleVersion"
                             Foreground="White"
                             FontSize="12"
                             VerticalAlignment="Center"
                             Margin="0,0,0,0"
                             Style="{StaticResource BibleVersionRadioStyle}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                x:Name="BibleEmbeddedSearchResultsContainer"
                x:FieldModifier="public"
                Visibility="Collapsed"
                Background="#F7F7F7"
                BorderBrush="#E2E2E2"
                BorderThickness="1,1,0,0"
                Padding="8,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="72"/>
                    <RowDefinition Height="420"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="BibleEmbeddedSearchResultStatus"
                           x:FieldModifier="public"
                           Foreground="#666666"
                           FontSize="13"
                           Margin="2,0,2,4"/>

                <Grid Grid.Row="1"
                      x:Name="BibleEmbeddedSearchFilterTagsPanel"
                      x:FieldModifier="public"
                      Margin="0,0,0,4"/>

                <ListBox Grid.Row="2"
                         x:Name="BibleEmbeddedSearchResultsList"
                         x:FieldModifier="public"
                         Background="Transparent"
                         BorderThickness="0"
                         Height="420"
                         ScrollViewer.VerticalScrollBarVisibility="Hidden"
                         ScrollViewer.HorizontalScrollBarVisibility="Hidden">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="2,2"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Foreground="#111111"
                                       FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                       TextWrapping="Wrap">
                                <Run Text="{Binding RowNumber}"/>
                                <Run Text=". "/>
                                <Run Text="["/>
                                <Run Text="{Binding Reference}"/>
                                <Run Text="] "/>
                                <Run Text="{Binding FullPrefix}"/>
                                <Run Text="{Binding FullMatch}"
                                     Foreground="#1E88E5"
                                     FontWeight="Bold"/>
                                <Run Text="{Binding FullSuffix}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="0,6,0,0">
                    <Button x:Name="BibleEmbeddedSearchPrevPageButton"
                            x:FieldModifier="public"
                            Content="上一页"
                            Padding="8,2"
                            Margin="0,0,8,0"/>
                    <TextBlock x:Name="BibleEmbeddedSearchPageInfoText"
                               x:FieldModifier="public"
                               VerticalAlignment="Center"
                               Foreground="#666666"
                               Margin="0,0,8,0"/>
                    <Button x:Name="BibleEmbeddedSearchNextPageButton"
                            x:FieldModifier="public"
                            Content="下一页"
                            Padding="8,2"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
