<UserControl x:Class="ImageColorChanger.UI.Views.LyricsSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<Grid x:Name="LyricsEditorPanel" 
                      Visibility="Collapsed" 
                      Background="#000000" 
                      Panel.ZIndex="100">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- 工具栏 -->
                        <RowDefinition Height="*"/>     <!-- 编辑区域 -->
                    </Grid.RowDefinitions>

                    <!-- 极简工具栏 -->
                    <Border Grid.Row="0" 
                            Background="#1A1A1A" 
                            BorderBrush="#333333" 
                            BorderThickness="0,0,0,1" 
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Left">
                            
                            <!-- 退出按钮 -->
                            <Button x:Name="BtnCloseLyricsEditor" 
                                    Content="❌ 退出"
                                    Width="100" Height="40"
                                    Margin="0,0,12,0"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Style="{StaticResource MenuButtonStyle}"
                                   
                                    ToolTip="退出歌词模式"/>

                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" 
                                       Margin="0,0,12,0"/>

                            <!-- 字号显示和滚轮调整 -->
                            <Border Background="#2D2D2D" 
                                    BorderBrush="#555555" 
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12,6"
                                    Margin="0,0,8,0"
                                    ToolTip="鼠标滚轮调整字号（Ctrl+滚轮快速缩放）">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="字号:" 
                                               Foreground="#AAAAAA"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"
                                               FontSize="14"/>
                                    <TextBlock x:Name="LyricsFontSizeDisplay" 
                                               Text="88" 
                                               Width="40" 
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#FFFFFF"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                              />
                                </StackPanel>
                            </Border>

                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" 
                                       Margin="0,0,12,0"/>

                            <!-- 文字颜色 -->
                            <Button x:Name="BtnLyricsTextColor" 
                                    Content="🎨 颜色"
                                    Width="110" Height="40"
                                    Margin="0,0,12,0"
                                    FontSize="18"
                                    Style="{StaticResource MenuButtonStyle}"
                                   
                                    ToolTip="选择文字颜色"/>

                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" 
                                       Margin="0,0,12,0"/>

                            <!-- 对齐方式 - 重新设计的按钮 -->
                            <Button x:Name="BtnLyricsAlignLeft" 
                                    Width="56" Height="40"
                                    Margin="0,0,8,0"
                                   
                                    ToolTip="左对齐"
                                    Background="#2C2C2C"
                                    BorderBrush="#444"
                                    BorderThickness="1">
                                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                    <Line X1="3" Y1="0" X2="22" Y2="0" Stroke="#AAA" StrokeThickness="2.5"/>
                                    <Line X1="3" Y1="6" X2="17" Y2="6" Stroke="#AAA" StrokeThickness="2.5"/>
                                    <Line X1="3" Y1="12" X2="22" Y2="12" Stroke="#AAA" StrokeThickness="2.5"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnLyricsAlignCenter" 
                                    Width="56" Height="40"
                                    Margin="0,0,8,0"
                                   
                                    ToolTip="居中对齐"
                                    Background="#2C2C2C"
                                    BorderBrush="#444"
                                    BorderThickness="1">
                                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                    <Line X1="3" Y1="0" X2="22" Y2="0" Stroke="#AAA" StrokeThickness="2.5"/>
                                    <Line X1="6" Y1="6" X2="19" Y2="6" Stroke="#AAA" StrokeThickness="2.5"/>
                                    <Line X1="3" Y1="12" X2="22" Y2="12" Stroke="#AAA" StrokeThickness="2.5"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnLyricsAlignRight" 
                                    Width="56" Height="40"
                                    Margin="0,0,12,0"
                                   
                                    ToolTip="右对齐"
                                    Background="#2C2C2C"
                                    BorderBrush="#444"
                                    BorderThickness="1">
                                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                    <Line X1="3" Y1="0" X2="22" Y2="0" Stroke="#AAA" StrokeThickness="2.5"/>
                                    <Line X1="8" Y1="6" X2="22" Y2="6" Stroke="#AAA" StrokeThickness="2.5"/>
                                    <Line X1="3" Y1="12" X2="22" Y2="12" Stroke="#AAA" StrokeThickness="2.5"/>
                                </StackPanel>
                            </Button>

                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" 
                                       Margin="0,0,12,0"/>

                            <!-- 清空内容 -->
                            <Button x:Name="BtnLyricsClear" 
                                    Content="🗑 清空"
                                    Width="100" Height="40"
                                    Margin="0,0,12,0"
                                    FontSize="18"
                                    FontWeight="Bold"
                                   
                                    Style="{StaticResource RecordButtonStyle}"
                                    ToolTip="清空所有内容"/>

                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" 
                                       Margin="0,0,12,0"/>

                            <StackPanel x:Name="LyricsSliceToolbar"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button x:Name="BtnLyricsSliceToggle"
                                        Content="切片"
                                        Width="82" Height="40"
                                        Margin="0,0,8,0"
                                        FontSize="16"
                                        Foreground="White"
                                        Background="#2C2C2C"
                                        BorderBrush="#444444"
                                        BorderThickness="1"
                                        ToolTip="启用/关闭切片模式"/>
                                <Button x:Name="BtnLyricsSliceRule1"
                                        Content="1行"
                                        Width="56" Height="40"
                                        Margin="0,0,6,0"
                                        FontSize="15"
                                        Foreground="White"
                                        Background="#2C2C2C"
                                        BorderBrush="#444444"
                                        BorderThickness="1"
                                        ToolTip="每1行切片"/>
                                <Button x:Name="BtnLyricsSliceRule2"
                                        Content="2行"
                                        Width="56" Height="40"
                                        Margin="0,0,6,0"
                                        FontSize="15"
                                        Foreground="White"
                                        Background="#2C2C2C"
                                        BorderBrush="#444444"
                                        BorderThickness="1"
                                        ToolTip="每2行切片"/>
                                <Button x:Name="BtnLyricsSliceRule3"
                                        Content="3行"
                                        Width="56" Height="40"
                                        Margin="0,0,6,0"
                                        FontSize="15"
                                        Foreground="White"
                                        Background="#2C2C2C"
                                        BorderBrush="#444444"
                                        BorderThickness="1"
                                        ToolTip="每3行切片"/>
                            </StackPanel>

                            <StackPanel x:Name="LyricsPageNavPanel"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <Button x:Name="BtnLyricsPagingToggle"
                                        Content="分页"
                                        Width="82" Height="40"
                                        Margin="0,0,8,0"
                                        FontSize="16"
                                        Foreground="White"
                                        Background="#2C2C2C"
                                        BorderBrush="#444444"
                                        BorderThickness="1"
                                       
                                        ToolTip="进入/退出分页"/>
                                <Button x:Name="BtnLyricsPageUp"
                                        Content="◀"
                                        Width="56" Height="40"
                                        Margin="0,0,6,0"
                                        FontSize="18"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Background="#2C2C2C"
                                        BorderBrush="#444444"
                                        BorderThickness="1"
                                       
                                        ToolTip="上一项"/>
                                <Border Background="#2D2D2D"
                                        BorderBrush="#555555"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="8,0"
                                        Height="40"
                                        MinWidth="70"
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="LyricsPagingStateText"
                                               Text="1/2"
                                               Foreground="White"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"/>
                                </Border>
                                <Button x:Name="BtnLyricsPageDown"
                                        Content="▶"
                                        Width="56" Height="40"
                                        FontSize="18"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Background="#2C2C2C"
                                        BorderBrush="#444444"
                                        BorderThickness="1"
                                       
                                        ToolTip="下一项"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 编辑区域 - 黑色背景，白色文字 -->
                    <Grid Grid.Row="1" Background="#000000">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>

                        <!-- 可滚动的编辑区域 -->
                        <ScrollViewer x:Name="LyricsScrollViewer"
                                      Grid.Column="0"
                                      VerticalScrollBarVisibility="Disabled"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Background="#000000"
                                      Padding="60,40"
                                     
                                     >
                            <ScrollViewer.Resources>
                                <Style TargetType="{x:Type ScrollBar}" 
                                       BasedOn="{StaticResource FixedScrollBarStyle}"/>
                            </ScrollViewer.Resources>
                            <Grid>
                                <TextBox x:Name="LyricsTextBox"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="88"
                                         FontFamily="Microsoft YaHei UI"
                                         Foreground="White"
                                         TextAlignment="Center"
                                         MinHeight="600"
                                         CaretBrush="White"
                                         VerticalAlignment="Top"
                                        
                                        
                                        
                                        >
                                    <TextBox.Resources>
                                        <VisualBrush x:Key="HintBrush" 
                                                     TileMode="None" 
                                                     Opacity="0.3" 
                                                     Stretch="None" 
                                                     AlignmentX="Left" 
                                                     AlignmentY="Top">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="在此粘贴或输入歌谱文字内容...&#x0a;&#x0a;支持 Ctrl+V 粘贴"
                                                           FontSize="28"
                                                           FontStyle="Italic"
                                                           Foreground="#666666"
                                                           TextAlignment="Left"
                                                           Margin="0,20,0,0"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </TextBox.Resources>
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <ScrollViewer x:Name="PART_ContentHost" 
                                                                      Focusable="False"
                                                                      HorizontalScrollBarVisibility="Disabled"
                                                                      VerticalScrollBarVisibility="Disabled"/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background" 
                                                            Value="{StaticResource HintBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <Grid x:Name="LyricsSplitGrid"
                                      MinHeight="600"
                                      Visibility="Collapsed"
                                      Background="Transparent">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="LyricsSplitRegion1" Grid.Row="0" Grid.Column="0" BorderBrush="#FF3B30" BorderThickness="0">
                                        <Grid>
                                            <TextBox x:Name="LyricsSplitTextBox1"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     FontSize="88"
                                                     FontFamily="Microsoft YaHei UI"
                                                     Foreground="White"
                                                     TextAlignment="Center"
                                                     CaretBrush="White"
                                                     Padding="10,30,10,10"
                                                     VerticalContentAlignment="Center"
                                                    
                                                    
                                                    
                                                    />
                                            <Border Background="#CCFF6600"
                                                    CornerRadius="0,0,10,0"
                                                    Padding="12,5,12,5"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    IsHitTestVisible="False">
                                                <TextBlock Text="1"
                                                           FontSize="24"
                                                           FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <Border x:Name="LyricsSplitRegion2" Grid.Row="0" Grid.Column="1" BorderBrush="#FF3B30" BorderThickness="0">
                                        <Grid>
                                            <TextBox x:Name="LyricsSplitTextBox2"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     FontSize="88"
                                                     FontFamily="Microsoft YaHei UI"
                                                     Foreground="White"
                                                     TextAlignment="Center"
                                                     CaretBrush="White"
                                                     Padding="10,30,10,10"
                                                     VerticalContentAlignment="Center"
                                                    
                                                    
                                                    
                                                    />
                                            <Border Background="#CCFF6600"
                                                    CornerRadius="0,0,10,0"
                                                    Padding="12,5,12,5"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    IsHitTestVisible="False">
                                                <TextBlock Text="2"
                                                           FontSize="24"
                                                           FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <Border x:Name="LyricsSplitRegion3" Grid.Row="1" Grid.Column="0" BorderBrush="#FF3B30" BorderThickness="0">
                                        <Grid>
                                            <TextBox x:Name="LyricsSplitTextBox3"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     FontSize="88"
                                                     FontFamily="Microsoft YaHei UI"
                                                     Foreground="White"
                                                     TextAlignment="Center"
                                                     CaretBrush="White"
                                                     Padding="10,30,10,10"
                                                     VerticalContentAlignment="Center"
                                                    
                                                    
                                                    
                                                    />
                                            <Border Background="#CCFF6600"
                                                    CornerRadius="0,0,10,0"
                                                    Padding="12,5,12,5"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    IsHitTestVisible="False">
                                                <TextBlock Text="3"
                                                           FontSize="24"
                                                           FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <Border x:Name="LyricsSplitRegion4" Grid.Row="1" Grid.Column="1" BorderBrush="#FF3B30" BorderThickness="0">
                                        <Grid>
                                            <TextBox x:Name="LyricsSplitTextBox4"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     FontSize="88"
                                                     FontFamily="Microsoft YaHei UI"
                                                     Foreground="White"
                                                     TextAlignment="Center"
                                                     CaretBrush="White"
                                                     Padding="10,30,10,10"
                                                     VerticalContentAlignment="Center"
                                                    
                                                    
                                                    
                                                    />
                                            <Border Background="#CCFF6600"
                                                    CornerRadius="0,0,10,0"
                                                    Padding="12,5,12,5"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    IsHitTestVisible="False">
                                                <TextBlock Text="4"
                                                           FontSize="24"
                                                           FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </ScrollViewer>

                        <Border x:Name="LyricsSlicePanel"
                                Grid.Column="1"
                                Background="#161616"
                                BorderBrush="#2F2F2F"
                                BorderThickness="1,0,0,0"
                                Padding="10"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="切片列表"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="White"/>
                                <StackPanel Grid.Row="2"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Left">
                                    <Button x:Name="BtnLyricsSlicePrev"
                                            Content="◀"
                                            Width="56" Height="34"
                                            Margin="0,0,6,0"
                                            FontSize="16"
                                            Foreground="White"
                                            Background="#2C2C2C"
                                            BorderBrush="#444444"
                                            BorderThickness="1"
                                            ToolTip="上一片"/>
                                    <Button x:Name="BtnLyricsSliceNext"
                                            Content="▶"
                                            Width="56" Height="34"
                                            FontSize="16"
                                            Foreground="White"
                                            Background="#2C2C2C"
                                            BorderBrush="#444444"
                                            BorderThickness="1"
                                            ToolTip="下一片"/>
                                </StackPanel>

                                <ListBox x:Name="LyricsSliceList"
                                         Grid.Row="4"
                                         Background="#1F1F1F"
                                         BorderBrush="#333333"
                                         BorderThickness="1"
                                         Foreground="White"
                                         FontSize="14"
                                         ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Header}"
                                                           FontWeight="Bold"
                                                           Foreground="#E0E0E0"
                                                           Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding Text}"
                                                           TextWrapping="Wrap"
                                                           Foreground="White"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="8,6"/>
                                            <Setter Property="Margin" Value="0,0,0,4"/>
                                            <Setter Property="Background" Value="#252525"/>
                                            <Setter Property="BorderBrush" Value="#333333"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#2F5D2F"/>
                                                    <Setter Property="BorderBrush" Value="#66BB6A"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
</UserControl>
