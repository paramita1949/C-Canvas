                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0"
                                                Background="#2E7D32"
                                                Cursor="SizeAll"
                                                Tag="ShadowSettingsPopup"
                                                MouseLeftButtonDown="SidePanelDragHandle_MouseLeftButtonDown"
                                                MouseMove="SidePanelDragHandle_MouseMove"
                                                MouseLeftButtonUp="SidePanelDragHandle_MouseLeftButtonUp">
                                            <Grid>
                                                <Button Content="X"
                                                        Style="{StaticResource SidePanelHeaderCloseButtonStyle}"
                                                        Tag="ShadowSettingsPopup"
                                                        Click="SidePanelHeaderClose_Click"/>
                                            </Grid>
                                        </Border>
                                        <controls:ShadowSettingsPanel x:Name="ShadowSettingsPanel" Grid.Row="1"/>
                                    </Grid>
                                </Border>
                            </Popup>

                            <!--  间距设置侧边面板 -->
                            <Popup x:Name="SpacingSettingsPopup"
                                   AllowsTransparency="True"
                                   StaysOpen="True"
                                   Placement="Relative"
                                   PlacementTarget="{Binding ElementName=SlidePanelBorder}"
                                   HorizontalOffset="0"
                                   VerticalOffset="0"
                                   IsOpen="False">
                                <Border Background="#2D2D30"
                                        BorderBrush="#3F3F46"
                                        BorderThickness="1,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.3" Color="#000000"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="20"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0"
                                                Background="#2E7D32"
                                                Cursor="SizeAll"
                                                Tag="SpacingSettingsPopup"
                                                MouseLeftButtonDown="SidePanelDragHandle_MouseLeftButtonDown"
                                                MouseMove="SidePanelDragHandle_MouseMove"
                                                MouseLeftButtonUp="SidePanelDragHandle_MouseLeftButtonUp">
                                            <Grid>
                                                <Button Content="X"
                                                        Style="{StaticResource SidePanelHeaderCloseButtonStyle}"
                                                        Tag="SpacingSettingsPopup"
                                                        Click="SidePanelHeaderClose_Click"/>
                                            </Grid>
                                        </Border>
                                        <controls:SpacingSettingsPanel x:Name="SpacingSettingsPanel" Grid.Row="1"/>
                                    </Grid>
                                </Border>
                            </Popup>

                            <!--  动画设置侧边面板 -->
                            <Popup x:Name="AnimationSettingsPopup"
                                   AllowsTransparency="True"
                                   StaysOpen="True"
                                   Placement="Relative"
                                   PlacementTarget="{Binding ElementName=SlidePanelBorder}"
                                   HorizontalOffset="0"
                                   VerticalOffset="0"
                                   IsOpen="False">
                                <Border Background="#2D2D30"
                                        BorderBrush="#3F3F46"
                                        BorderThickness="1,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.3" Color="#000000"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="20"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0"
                                                Background="#2E7D32"
                                                Cursor="SizeAll"
                                                Tag="AnimationSettingsPopup"
                                                MouseLeftButtonDown="SidePanelDragHandle_MouseLeftButtonDown"
                                                MouseMove="SidePanelDragHandle_MouseMove"
                                                MouseLeftButtonUp="SidePanelDragHandle_MouseLeftButtonUp">
                                            <Grid>
                                                <Button Content="X"
                                                        Style="{StaticResource SidePanelHeaderCloseButtonStyle}"
                                                        Tag="AnimationSettingsPopup"
                                                        Click="SidePanelHeaderClose_Click"/>
                                            </Grid>
                                        </Border>
                                        <controls:AnimationSettingsPanel x:Name="AnimationSettingsPanel" Grid.Row="1"/>
                                    </Grid>
                                </Border>
                            </Popup>

                            <!-- 辅助线（叠加在Canvas上方）-->
                            <Canvas x:Name="AlignmentGuidesCanvas" 
                                    Width="1080" Height="700"
                                    IsHitTestVisible="False"
                                    Panel.ZIndex="1000">
                                <!-- 垂直中心线 -->
                                <Line x:Name="VerticalCenterLine" 
                                      X1="540" Y1="0" X2="540" Y2="700"
                                      Stroke="#FF2196F3" StrokeThickness="2" 
                                      StrokeDashArray="8,4"
                                      Visibility="Collapsed">
                                    <Line.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.5" Color="#2196F3"/>
                                    </Line.Effect>
                                </Line>
                                
                                <!-- 水平中心线 -->
                                <Line x:Name="HorizontalCenterLine" 
                                      X1="0" Y1="350" X2="1080" Y2="350"
                                      Stroke="#FF2196F3" StrokeThickness="2" 
                                      StrokeDashArray="8,4"
                                      Visibility="Collapsed">
                                    <Line.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.5" Color="#2196F3"/>
                                    </Line.Effect>
                                </Line>
                                
                                <!-- 垂直对齐线（与其他文本框对齐）-->
                                <Line x:Name="VerticalAlignLine" 
                                      X1="0" Y1="0" X2="0" Y2="700"
                                      Stroke="#FFFF9800" StrokeThickness="1.5" 
                                      StrokeDashArray="4,2"
                                      Visibility="Collapsed"/>
                                
                                <!-- 水平对齐线（与其他文本框对齐）-->
                                <Line x:Name="HorizontalAlignLine" 
                                      X1="0" Y1="0" X2="1080" Y2="0"
                                      Stroke="#FFFF9800" StrokeThickness="1.5" 
                                      StrokeDashArray="4,2"
                                      Visibility="Collapsed"/>
                            </Canvas>
                        </Grid>
                    </Viewbox>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>


</UserControl>


