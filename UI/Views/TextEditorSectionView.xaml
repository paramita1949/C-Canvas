<UserControl x:Class="ImageColorChanger.UI.Views.TextEditorSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ImageColorChanger.UI.Controls">
                <Grid x:Name="TextEditorPanel" Visibility="Collapsed" Background="#F0F0F0"
                      Focusable="True" PreviewKeyDown="TextEditorPanel_KeyDown"
                      PreviewMouseWheel="TextEditorPanel_PreviewMouseWheel"
                      PreviewMouseDown="TextEditorPanel_PreviewMouseDown"
                      Panel.ZIndex="100">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- 工具栏 -->
                        <RowDefinition Height="Auto"/>  <!--  圣经经文工具栏 -->
                        <RowDefinition Height="*"/>     <!-- 主内容区 -->
                    </Grid.RowDefinitions>

                    <!-- 工具栏 -->
                    <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E0E0E0" 
                            BorderThickness="0,0,0,2" Padding="8">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.08" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <!-- 菜单按钮 -->
                            <Button x:Name="BtnToolbarMenu"
                                    Style="{StaticResource MenuButtonStyle}"
                                    MinWidth="{Binding ElementName=BtnSplitStretchMode, Path=ActualWidth}"
                                    Height="{Binding ElementName=BtnSplitStretchMode, Path=ActualHeight}"
                                    ToolTip="菜单"
                                    Click="BtnToolbarMenu_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideFolderOpen}"
                                          Style="{StaticResource LucideIconPathStyle}"
                                          Width="16"
                                          Height="16"
                                          Margin="0,0,6,0"/>
                                    <TextBlock Text="菜单"
                                               VerticalAlignment="Center"
                                               FontSize="{Binding ElementName=BtnSplitStretchMode, Path=FontSize}"/>
                                </StackPanel>
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="ToolbarMenuContext"
                                                 Style="{StaticResource NoBorderContextMenuStyle}">
                                        <MenuItem Header="NDI网络"
                                                  SubmenuOpened="MenuNdiOutput_SubmenuOpened">
                                            <MenuItem Header="完整画面"
                                                      Tag="Normal"
                                                      IsCheckable="True"
                                                      Click="BtnMenuNdiComplete_Click"/>
                                            <MenuItem Header="透明画面"
                                                      Tag="Transparent"
                                                      IsCheckable="True"
                                                      Click="BtnMenuNdiTransparent_Click"/>
                                        </MenuItem>
                                        <MenuItem Header="主题"
                                                  SubmenuOpened="MenuSlideTheme_SubmenuOpened">
                                            <MenuItem Header="黑底白字"
                                                      Tag="Dark"
                                                      IsCheckable="True"
                                                      Click="BtnMenuSlideThemeDark_Click"/>
                                            <MenuItem Header="白底黑字"
                                                      Tag="Light"
                                                      IsCheckable="True"
                                                      Click="BtnMenuSlideThemeLight_Click"/>
                                        </MenuItem>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>

                            <!-- 文本和背景操作 -->
                            <Button x:Name="BtnAddText"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    ToolTip="添加文本框"
                                    Visibility="Collapsed"
                                    Click="BtnAddText_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideTextCompact}" Style="{StaticResource LucideIconPathStyle}" Width="13" Height="13" Margin="0,0,6,0"/>
                                    <TextBlock Text="文本" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnBackgroundImage"
                                    Style="{StaticResource MenuButtonStyle}"
                                    ToolTip="插入素材到幻灯片"
                                    Click="BtnBackgroundImage_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideUpload}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                                    <TextBlock Text="插入" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="InsertMenuContext"
                                                 Style="{StaticResource NoBorderContextMenuStyle}">
                                        <MenuItem Header="插入单图"
                                                  Click="BtnMenuImportSingle_Click"/>
                                        <MenuItem Header="插入多图"
                                                  Click="BtnMenuImportMulti_Click"/>
                                        <MenuItem Header="插入视频"
                                                  Click="BtnMenuImportVideo_Click"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>

                            <!-- 背景颜色按钮 -->
                            <Button x:Name="BtnBackgroundColor"
                                    Style="{StaticResource MenuButtonStyle}"
                                    ToolTip="选择背景颜色"
                                    Visibility="Collapsed"
                                    Click="BtnBackgroundColor_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucidePalette}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                                    <TextBlock Text="背景" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnSplitView"
                                    Style="{StaticResource MenuButtonStyle}"
                                    ToolTip="画面分割设置"
                                    Click="BtnSplitView_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideImage}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                                    <TextBlock Text="分割" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="SplitMenuContext"
                                                 Style="{StaticResource NoBorderContextMenuStyle}">
                                        <MenuItem Header="单画面"
                                                  Tag="Single"
                                                  Click="BtnMenuSplitSingle_Click"/>
                                        <MenuItem Header="左右分割"
                                                  Tag="Horizontal"
                                                  Click="BtnMenuSplitHorizontal_Click"/>
                                        <MenuItem Header="上下分割"
                                                  Tag="Vertical"
                                                  Click="BtnMenuSplitVertical_Click"/>
                                        <MenuItem Header="三分割"
                                                  Tag="TripleSplit"
                                                  Click="BtnMenuSplitTriple_Click"/>
                                        <MenuItem Header="四宫格"
                                                  Tag="Quad"
                                                  Click="BtnMenuSplitQuad_Click"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>

                            <!-- 原图模式切换按钮 -->
                            <Button x:Name="BtnSplitStretchMode"
                                    Style="{StaticResource MenuButtonStyle}"
                                    ToolTip="切换图片显示模式（适中/拉伸/置顶）"
                                    Click="BtnSplitStretchMode_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideMinimize}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                                    <TextBlock Text="适中" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnSlideOutputMode"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Width="{Binding ElementName=BtnSplitStretchMode, Path=ActualWidth}"
                                    Height="{Binding ElementName=BtnSplitStretchMode, Path=ActualHeight}"
                                    ToolTip="切换当前幻灯片输出模式（普通/透明）"
                                    Visibility="Collapsed"
                                    Click="BtnSlideOutputMode_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideSparkles}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                                    <TextBlock Text="普通" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnComponent"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Height="{Binding ElementName=BtnSplitStretchMode, Path=ActualHeight}"
                                    ToolTip="组件功能入口"
                                    Click="BtnComponent_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideComponentBlocks}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                                    <TextBlock Text="组件" VerticalAlignment="Center" FontSize="{Binding ElementName=BtnSplitStretchMode, Path=FontSize}"/>
                                </StackPanel>
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="ComponentMenuContext"
                                                 Style="{StaticResource NoBorderContextMenuStyle}">
                                        <MenuItem Header="通知"
                                                  Click="BtnComponentNotice_Click">
                                            <MenuItem.Icon>
                                                <Path Data="{StaticResource IconLucideFileText}"
                                                      Style="{StaticResource LucideIconPathStyle}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="时钟"
                                                  IsEnabled="False">
                                            <MenuItem.Icon>
                                                <Path Data="{StaticResource IconLucideClock3}"
                                                      Style="{StaticResource LucideIconPathStyle}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="倒计时"
                                                  IsEnabled="False">
                                            <MenuItem.Icon>
                                                <Path Data="{StaticResource IconLucideTimerReset}"
                                                      Style="{StaticResource LucideIconPathStyle}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>

                            <Button x:Name="BtnBibleStyleTopEntry"
                                    Style="{StaticResource MenuButtonStyle}"
                                    MinWidth="{Binding ElementName=BtnSplitStretchMode, Path=ActualWidth}"
                                    Height="{Binding ElementName=BtnSplitStretchMode, Path=ActualHeight}"
                                    ToolTip="样式设置"
                                    Click="BtnBibleInsertStyleSettings_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideBookPlus}"
                                          Style="{StaticResource LucideIconPathStyle}"
                                          Margin="0,0,6,0"/>
                                    <TextBlock Text="样式"
                                               VerticalAlignment="Center"
                                               FontSize="{Binding ElementName=BtnSplitStretchMode, Path=FontSize}"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnAnimationTopEntry"
                                    Style="{StaticResource MenuButtonStyle}"
                                    MinWidth="{Binding ElementName=BtnSplitStretchMode, Path=ActualWidth}"
                                    Height="{Binding ElementName=BtnSplitStretchMode, Path=ActualHeight}"
                                    ToolTip="动画设置"
                                    Click="BtnFloatingAnimation_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideSparkles}"
                                          Style="{StaticResource LucideIconPathStyle}"
                                          Margin="0,0,6,0"/>
                                    <TextBlock Text="动画"
                                               VerticalAlignment="Center"
                                               FontSize="{Binding ElementName=BtnSplitStretchMode, Path=FontSize}"/>
                                </StackPanel>
                            </Button>

                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0" Visibility="Collapsed"/>

                            <!-- 字体设置 -->
                            <ComboBox x:Name="FontFamilySelector" Width="150" Height="32"
                                      SelectedIndex="0"
                                      SelectionChanged="FontFamily_Changed"
                                      MaxDropDownHeight="400"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      GotFocus="FontFamilySelector_GotFocus"
                                      VerticalContentAlignment="Center"
                                      HorizontalContentAlignment="Left"
                                      Padding="8,0,0,0"
                                      FontSize="13"
                                      Visibility="Collapsed"
                                      Style="{StaticResource WhiteComboBoxPopup}"
                                      ItemContainerStyle="{StaticResource WhiteComboBoxItem}">
                                <ComboBox.Resources>
                                    <!-- 深灰色滚动条样式 -->
                                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{x:Null}">
                                        <Setter Property="Background" Value="#E0E0E0"/>
                                        <Setter Property="Width" Value="12"/>
                                        <Setter Property="MinWidth" Value="12"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ScrollBar}">
                                                    <Grid>
                                                        <Border Background="#E0E0E0" CornerRadius="6"/>
                                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                            <Track.Thumb>
                                                                <Thumb>
                                                                    <Thumb.Style>
                                                                        <Style TargetType="Thumb">
                                                                            <Setter Property="Background" Value="#5C5C5C"/>
                                                                            <Setter Property="Template">
                                                                                <Setter.Value>
                                                                                    <ControlTemplate TargetType="Thumb">
                                                                                        <Border Background="{TemplateBinding Background}"
                                                                                                CornerRadius="6"
                                                                                                Margin="2"/>
                                                                                    </ControlTemplate>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                            <Style.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter Property="Background" Value="#7C7C7C"/>
                                                                                </Trigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Thumb.Style>
                                                                </Thumb>
                                                            </Track.Thumb>
                                                        </Track>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ComboBox.Resources>
                                <!-- 字体将在代码中动态加载 -->
                            </ComboBox>

                            <!-- 字号选择框 -->
                            <ComboBox x:Name="FontSizeSelector" Width="80" Height="32"
                                      SelectedIndex="5"
                                      SelectionChanged="FontSize_Changed"
                                      MouseWheel="FontSizeSelector_MouseWheel"
                                      IsEditable="True"
                                      VerticalContentAlignment="Center"
                                      HorizontalContentAlignment="Center"
                                      FontSize="13"
                                      FontWeight="Bold"
                                      Visibility="Collapsed"
                                      Style="{StaticResource WhiteComboBoxPopup}"
                                      ItemContainerStyle="{StaticResource WhiteComboBoxItem}">
                                <ComboBox.Resources>
                                    <!-- 深灰色滚动条样式 -->
                                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{x:Null}">
                                        <Setter Property="Background" Value="#E0E0E0"/>
                                        <Setter Property="Width" Value="12"/>
                                        <Setter Property="MinWidth" Value="12"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ScrollBar}">
                                                    <Grid>
                                                        <Border Background="#E0E0E0" CornerRadius="6"/>
                                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                            <Track.Thumb>
                                                                <Thumb>
                                                                    <Thumb.Style>
                                                                        <Style TargetType="Thumb">
                                                                            <Setter Property="Background" Value="#5C5C5C"/>
                                                                            <Setter Property="Template">
                                                                                <Setter.Value>
                                                                                    <ControlTemplate TargetType="Thumb">
                                                                                        <Border Background="{TemplateBinding Background}"
                                                                                                CornerRadius="6"
                                                                                                Margin="2"/>
                                                                                    </ControlTemplate>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                            <Style.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter Property="Background" Value="#7C7C7C"/>
                                                                                </Trigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Thumb.Style>
                                                                </Thumb>
                                                            </Track.Thumb>
                                                        </Track>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ComboBox.Resources>
                                <ComboBoxItem Content="10"/>
                                <ComboBoxItem Content="12"/>
                                <ComboBoxItem Content="14"/>
                                <ComboBoxItem Content="16"/>
                                <ComboBoxItem Content="18"/>
                                <ComboBoxItem Content="20"/>
                                <ComboBoxItem Content="24"/>
                                <ComboBoxItem Content="28"/>
                                <ComboBoxItem Content="30"/>
                                <ComboBoxItem Content="32"/>
                                <ComboBoxItem Content="36"/>
                                <ComboBoxItem Content="40"/>
                                <ComboBoxItem Content="48"/>
                                <ComboBoxItem Content="56"/>
                                <ComboBoxItem Content="64"/>
                                <ComboBoxItem Content="72"/>
                                <ComboBoxItem Content="80"/>
                                <ComboBoxItem Content="88"/>
                                <ComboBoxItem Content="96"/>
                                <ComboBoxItem Content="104"/>
                                <ComboBoxItem Content="112"/>
                                <ComboBoxItem Content="120"/>
                                <ComboBoxItem Content="128"/>
                                <ComboBoxItem Content="144"/>
                                <ComboBoxItem Content="160"/>
                                <ComboBoxItem Content="176"/>
                                <ComboBoxItem Content="192"/>
                                <ComboBoxItem Content="208"/>
                                <ComboBoxItem Content="224"/>
                                <ComboBoxItem Content="240"/>
                            </ComboBox>
                            
                            <!-- 字号增大按钮 -->
                            <Button x:Name="BtnIncreaseFontSize"
                                    Width="40" Height="32"
                                    Padding="2"
                                    Visibility="Collapsed"
                                    Style="{StaticResource CompactButtonStyle}"
                                    Click="BtnIncreaseFontSize_Click"
                                    ToolTip="字体变大">
                                <Path Data="{StaticResource IconLucideTextIncrease}"
                                      Style="{StaticResource LucideIconPathStyle}"/>
                            </Button>

                            <!-- 字号减小按钮 -->
                            <Button x:Name="BtnDecreaseFontSize"
                                    Width="40" Height="32"
                                    Padding="2"
                                    Visibility="Collapsed"
                                    Style="{StaticResource CompactButtonStyle}"
                                    Click="BtnDecreaseFontSize_Click"
                                    ToolTip="字体变小">
                                <Path Data="{StaticResource IconLucideTextDecrease}"
                                      Style="{StaticResource LucideIconPathStyle}"/>
                            </Button>

                            <!-- 加粗按钮 -->
                            <Button x:Name="BtnBold"
                                    Width="40" Height="32"
                                    Padding="2"
                                    Visibility="Collapsed"
                                    Style="{StaticResource CompactButtonStyle}"
                                    ToolTip="加粗" Click="BtnBold_Click">
                                <Path Data="{StaticResource IconLucideBold}"
                                      Style="{StaticResource LucideIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Width="14" Height="14"/>
                            </Button>

                            <!-- 文字颜色按钮 -->
                            <Button x:Name="BtnTextColor"
                                    Width="40" Height="32"
                                    Padding="2"
                                    Visibility="Collapsed"
                                    Style="{StaticResource CompactButtonStyle}"
                                    ToolTip="颜色" Click="BtnTextColor_Click">
                                <Path Data="{StaticResource IconLucidePalette}"
                                      Style="{StaticResource LucideIconPathStyle}"/>
                            </Button>

                            <!-- 保存和投影 -->
                            <Button x:Name="BtnSaveTextProject"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Foreground="#333333"
                                    ToolTip="保存项目" Click="BtnSaveTextProject_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideSave}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                                    <TextBlock Text="保存" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <Button x:Name="BtnLockProjection"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    ToolTip="锁定投影：开启后切换幻灯片不会自动更新投影" Click="BtnLockProjection_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideUnlock}" Style="{StaticResource LucideIconPathStyle}" Stroke="White" Margin="0,0,6,0"/>
                                    <TextBlock Text="锁定" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <Button x:Name="BtnUpdateProjection"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    ToolTip="立即更新投影内容" Click="BtnUpdateProjection_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideRefreshCw}" Style="{StaticResource LucideIconPathStyle}" Stroke="White" Margin="0,0,6,0"/>
                                    <TextBlock Text="更新" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border x:Name="TextEditorMiniToolbar"
                            Grid.Row="1"
                            Background="#F0F0F0"
                            BorderBrush="#E0E0E0"
                            BorderThickness="0,0,0,1"
                            Margin="0"
                            Padding="8,4"
                            Visibility="Visible">
                        <Border.Resources>
                            <Style x:Key="SecondLayerFlatButtonStyle" TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Foreground" Value="{DynamicResource BrushIconDefault}"/>
                                <Setter Property="Width" Value="32"/>
                                <Setter Property="Height" Value="30"/>
                                <Setter Property="Padding" Value="2"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Root"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Root" Property="Background" Value="#E3E7EA"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Root" Property="Background" Value="#D7DCE0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <Style x:Key="SecondLayerToolComboStyle" TargetType="ComboBox">
                                <Setter Property="Height" Value="30"/>
                                <Setter Property="Foreground" Value="#3C4043"/>
                                <Setter Property="Background" Value="#DDE2E6"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="8,0,8,0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ComboBox">
                                            <Grid>
                                                <Border x:Name="ComboBorder"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6"/>
                                                <Grid Margin="8,0,8,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="16"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ContentPresenter Grid.Column="0"
                                                                      VerticalAlignment="Center"
                                                                      RecognizesAccessKey="True"/>
                                                    <Path Grid.Column="1"
                                                          Data="M4 6L8 10L12 6"
                                                          Stroke="#5F6368"
                                                          StrokeThickness="1.6"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                </Grid>
                                                <Popup x:Name="Popup"
                                                       Placement="Bottom"
                                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                                       AllowsTransparency="True"
                                                       Focusable="False"
                                                       PopupAnimation="Slide">
                                                    <Border Background="White"
                                                            BorderBrush="#D0D4D8"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                                        <ScrollViewer>
                                                            <StackPanel IsItemsHost="True"/>
                                                        </ScrollViewer>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <Style x:Key="SecondLayerToolComboItemStyle" TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ComboBoxItem">
                                            <Border x:Name="ItemRoot" Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsHighlighted" Value="True">
                                                    <Setter TargetName="ItemRoot" Property="Background" Value="#EEF2F5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <Style x:Key="SecondLayerSlimComboStyle"
                                   TargetType="ComboBox"
                                   BasedOn="{StaticResource WhiteComboBoxPopup}">
                                <Setter Property="Height" Value="30"/>
                                <Setter Property="MinHeight" Value="30"/>
                                <Setter Property="Padding" Value="8,0,8,0"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Foreground" Value="{DynamicResource BrushIconDefault}"/>
                                <Setter Property="Background" Value="#ECEFF1"/>
                                <Setter Property="BorderBrush" Value="#B4BAC0"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            </Style>

                            <Style x:Key="SecondLayerSlimComboItemStyle"
                                   TargetType="ComboBoxItem"
                                   BasedOn="{StaticResource WhiteComboBoxItem}">
                                <Setter Property="Padding" Value="8,4"/>
                            </Style>
                        </Border.Resources>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0"
                                  Margin="-14,0,0,0"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Stretch">
                                <Button x:Name="BtnCloseTextEditorInPanel"
                                        Width="80"
                                        Height="34"
                                        Margin="0,0,0,0"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource SecondLayerFlatButtonStyle}"
                                        Click="BtnCloseTextEditor_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconLucideX}"
                                              Style="{StaticResource LucideIconPathStyle}"
                                              Width="13"
                                              Height="13"
                                              Stroke="#D32F2F"
                                              Margin="0,0,4,0"/>
