<UserControl x:Class="ImageColorChanger.UI.Views.TextEditorSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ImageColorChanger.UI.Controls">
                <Grid x:Name="TextEditorPanel" Visibility="Collapsed" Background="#F0F0F0"
                      Focusable="True" PreviewKeyDown="TextEditorPanel_KeyDown"
                      PreviewMouseWheel="TextEditorPanel_PreviewMouseWheel"
                      PreviewMouseDown="TextEditorPanel_PreviewMouseDown"
                      Panel.ZIndex="100">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- 工具栏 -->
                        <RowDefinition Height="Auto"/>  <!--  圣经经文工具栏 -->
                        <RowDefinition Height="*"/>     <!-- 主内容区 -->
                    </Grid.RowDefinitions>

                    <!-- 工具栏 -->
                    <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E0E0E0" 
                            BorderThickness="0,0,0,2" Padding="8">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.08" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <!-- 文本和背景操作 -->
                            <Button x:Name="BtnAddText"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    ToolTip="添加文本框" Click="BtnAddText_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideTextCompact}" Style="{StaticResource LucideIconPathStyle}" Width="13" Height="13" Margin="0,0,6,0"/>
                                    <TextBlock Text="文本" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- 导入按钮 -->
                            <Button x:Name="BtnBackgroundImage"
                                    Style="{StaticResource MenuButtonStyle}"
                                    ToolTip="导入图片为幻灯片"
                                    Click="BtnBackgroundImage_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideUpload}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                                    <TextBlock Text="导入" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- 背景颜色按钮 -->
                            <Button x:Name="BtnBackgroundColor"
                                    Style="{StaticResource MenuButtonStyle}"
                                    ToolTip="选择背景颜色"
                                    Click="BtnBackgroundColor_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucidePalette}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                                    <TextBlock Text="背景" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- 分割按钮 -->
                            <Button x:Name="BtnSplitView"
                                    Style="{StaticResource MenuButtonStyle}"
                                    ToolTip="画面分割设置"
                                    Click="BtnSplitView_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideImage}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                                    <TextBlock Text="分割" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- 原图模式切换按钮 -->
                            <Button x:Name="BtnSplitStretchMode"
                                    Style="{StaticResource MenuButtonStyle}"
                                    ToolTip="切换图片显示模式（适中/拉伸/置顶）"
                                    Click="BtnSplitStretchMode_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideMinimize}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                                    <TextBlock Text="适中" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnSlideOutputMode"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Width="{Binding ElementName=BtnSplitStretchMode, Path=ActualWidth}"
                                    Height="{Binding ElementName=BtnSplitStretchMode, Path=ActualHeight}"
                                    ToolTip="切换当前幻灯片输出模式（普通/透明）"
                                    Click="BtnSlideOutputMode_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideSparkles}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                                    <TextBlock Text="普通" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0"/>

                            <!-- 字体设置 -->
                            <ComboBox x:Name="FontFamilySelector" Width="150" Height="32"
                                      SelectedIndex="0"
                                      SelectionChanged="FontFamily_Changed"
                                      MaxDropDownHeight="400"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      GotFocus="FontFamilySelector_GotFocus"
                                      VerticalContentAlignment="Center"
                                      HorizontalContentAlignment="Left"
                                      Padding="8,0,0,0"
                                      FontSize="13"
                                      Style="{StaticResource WhiteComboBoxPopup}"
                                      ItemContainerStyle="{StaticResource WhiteComboBoxItem}">
                                <ComboBox.Resources>
                                    <!-- 深灰色滚动条样式 -->
                                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{x:Null}">
                                        <Setter Property="Background" Value="#E0E0E0"/>
                                        <Setter Property="Width" Value="12"/>
                                        <Setter Property="MinWidth" Value="12"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ScrollBar}">
                                                    <Grid>
                                                        <Border Background="#E0E0E0" CornerRadius="6"/>
                                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                            <Track.Thumb>
                                                                <Thumb>
                                                                    <Thumb.Style>
                                                                        <Style TargetType="Thumb">
                                                                            <Setter Property="Background" Value="#5C5C5C"/>
                                                                            <Setter Property="Template">
                                                                                <Setter.Value>
                                                                                    <ControlTemplate TargetType="Thumb">
                                                                                        <Border Background="{TemplateBinding Background}"
                                                                                                CornerRadius="6"
                                                                                                Margin="2"/>
                                                                                    </ControlTemplate>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                            <Style.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter Property="Background" Value="#7C7C7C"/>
                                                                                </Trigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Thumb.Style>
                                                                </Thumb>
                                                            </Track.Thumb>
                                                        </Track>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ComboBox.Resources>
                                <!-- 字体将在代码中动态加载 -->
                            </ComboBox>

                            <!-- 字号选择框 -->
                            <ComboBox x:Name="FontSizeSelector" Width="80" Height="32"
                                      SelectedIndex="5"
                                      SelectionChanged="FontSize_Changed"
                                      MouseWheel="FontSizeSelector_MouseWheel"
                                      IsEditable="True"
                                      VerticalContentAlignment="Center"
                                      HorizontalContentAlignment="Center"
                                      FontSize="13"
                                      FontWeight="Bold"
                                      Style="{StaticResource WhiteComboBoxPopup}"
                                      ItemContainerStyle="{StaticResource WhiteComboBoxItem}">
                                <ComboBox.Resources>
                                    <!-- 深灰色滚动条样式 -->
                                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{x:Null}">
                                        <Setter Property="Background" Value="#E0E0E0"/>
                                        <Setter Property="Width" Value="12"/>
                                        <Setter Property="MinWidth" Value="12"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ScrollBar}">
                                                    <Grid>
                                                        <Border Background="#E0E0E0" CornerRadius="6"/>
                                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                            <Track.Thumb>
                                                                <Thumb>
                                                                    <Thumb.Style>
                                                                        <Style TargetType="Thumb">
                                                                            <Setter Property="Background" Value="#5C5C5C"/>
                                                                            <Setter Property="Template">
                                                                                <Setter.Value>
                                                                                    <ControlTemplate TargetType="Thumb">
                                                                                        <Border Background="{TemplateBinding Background}"
                                                                                                CornerRadius="6"
                                                                                                Margin="2"/>
                                                                                    </ControlTemplate>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                            <Style.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter Property="Background" Value="#7C7C7C"/>
                                                                                </Trigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Thumb.Style>
                                                                </Thumb>
                                                            </Track.Thumb>
                                                        </Track>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ComboBox.Resources>
                                <ComboBoxItem Content="10"/>
                                <ComboBoxItem Content="12"/>
                                <ComboBoxItem Content="14"/>
                                <ComboBoxItem Content="16"/>
                                <ComboBoxItem Content="18"/>
                                <ComboBoxItem Content="20"/>
                                <ComboBoxItem Content="24"/>
                                <ComboBoxItem Content="28"/>
                                <ComboBoxItem Content="30"/>
                                <ComboBoxItem Content="32"/>
                                <ComboBoxItem Content="36"/>
                                <ComboBoxItem Content="40"/>
                                <ComboBoxItem Content="48"/>
                                <ComboBoxItem Content="56"/>
                                <ComboBoxItem Content="64"/>
                                <ComboBoxItem Content="72"/>
                                <ComboBoxItem Content="80"/>
                                <ComboBoxItem Content="88"/>
                                <ComboBoxItem Content="96"/>
                                <ComboBoxItem Content="104"/>
                                <ComboBoxItem Content="112"/>
                                <ComboBoxItem Content="120"/>
                                <ComboBoxItem Content="128"/>
                                <ComboBoxItem Content="144"/>
                                <ComboBoxItem Content="160"/>
                                <ComboBoxItem Content="176"/>
                                <ComboBoxItem Content="192"/>
                                <ComboBoxItem Content="208"/>
                                <ComboBoxItem Content="224"/>
                                <ComboBoxItem Content="240"/>
                            </ComboBox>
                            
                            <!-- 字号增大按钮 -->
                            <Button x:Name="BtnIncreaseFontSize"
                                    Width="40" Height="32"
                                    Padding="2"
                                    Style="{StaticResource CompactButtonStyle}"
                                    Click="BtnIncreaseFontSize_Click"
                                    ToolTip="字体变大">
                                <Path Data="{StaticResource IconLucideTextIncrease}"
                                      Style="{StaticResource LucideIconPathStyle}"/>
                            </Button>

                            <!-- 字号减小按钮 -->
                            <Button x:Name="BtnDecreaseFontSize"
                                    Width="40" Height="32"
                                    Padding="2"
                                    Style="{StaticResource CompactButtonStyle}"
                                    Click="BtnDecreaseFontSize_Click"
                                    ToolTip="字体变小">
                                <Path Data="{StaticResource IconLucideTextDecrease}"
                                      Style="{StaticResource LucideIconPathStyle}"/>
                            </Button>

                            <!-- 加粗按钮 -->
                            <Button x:Name="BtnBold"
                                    Width="40" Height="32"
                                    Padding="2"
                                    Style="{StaticResource CompactButtonStyle}"
                                    ToolTip="加粗" Click="BtnBold_Click">
                                <Path Data="{StaticResource IconLucideBold}"
                                      Style="{StaticResource LucideIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Width="14" Height="14"/>
                            </Button>

                            <!-- 文字颜色按钮 -->
                            <Button x:Name="BtnTextColor"
                                    Width="40" Height="32"
                                    Padding="2"
                                    Style="{StaticResource CompactButtonStyle}"
                                    ToolTip="颜色" Click="BtnTextColor_Click">
                                <Path Data="{StaticResource IconLucidePalette}"
                                      Style="{StaticResource LucideIconPathStyle}"/>
                            </Button>

                            <!-- 保存和投影 -->
                            <Button x:Name="BtnSaveTextProject"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Foreground="#333333"
                                    ToolTip="保存项目" Click="BtnSaveTextProject_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideSave}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                                    <TextBlock Text="保存" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <Button x:Name="BtnLockProjection"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    ToolTip="锁定投影：开启后切换幻灯片不会自动更新投影" Click="BtnLockProjection_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideUnlock}" Style="{StaticResource LucideIconPathStyle}" Stroke="White" Margin="0,0,6,0"/>
                                    <TextBlock Text="锁定" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <Button x:Name="BtnUpdateProjection"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    ToolTip="立即更新投影内容" Click="BtnUpdateProjection_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconLucideRefreshCw}" Style="{StaticResource LucideIconPathStyle}" Stroke="White" Margin="0,0,6,0"/>
                                    <TextBlock Text="更新" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!--  圣经导航面板（在幻灯片编辑模式下显示，与主界面共享同一个面板） -->
                    <!-- 通过代码动态移动 BibleNavigationPanel 到这里 -->

                    <!-- 主内容区：左侧幻灯片列表 + 右侧编辑区 -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190"/>  <!-- 左侧幻灯片列表 -->
                            <ColumnDefinition Width="Auto"/> <!-- 分隔线 -->
                            <ColumnDefinition Width="*"/>    <!-- 右侧编辑区 -->
                        </Grid.ColumnDefinitions>

                        <!-- 左侧：幻灯片列表面板 -->
                        <Border x:Name="SlidePanelBorder" Grid.Column="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>  <!-- 标题栏 -->
                                    <RowDefinition Height="*"/>     <!-- 幻灯片列表 -->
                                </Grid.RowDefinitions>

                                <!-- 标题栏 - 退出编辑按钮和画布比例按钮 -->
                                <Border Grid.Row="0" Background="#FAFAFA" Padding="8" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="BtnCloseTextEditorInPanel"
                                                Height="36"
                                                Width="80"
                                                FontSize="14"
                                                FontWeight="SemiBold"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#D32F2F"
                                                HorizontalAlignment="Left"
                                                HorizontalContentAlignment="Left"
                                                Cursor="Hand"
                                                Click="BtnCloseTextEditor_Click"
                                                ToolTip="退出文本编辑器，返回图片/视频浏览">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="{StaticResource IconLucideX}" Style="{StaticResource LucideIconPathStyle}" Stroke="#D32F2F" Margin="0,0,5,0"/>
                                                <TextBlock Text="退出" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        Padding="4,0">
                                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                    VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Foreground" Value="#F44336"/>
                                                                        <Setter Property="FontSize" Value="15"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- 画布比例切换按钮 -->
                                        <Button x:Name="BtnCanvasAspectRatioInPanel"
                                                Content="宽屏幕"
                                                Height="36"
                                                Width="80"
                                                FontSize="14"
                                                FontWeight="SemiBold"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#666666"
                                                HorizontalAlignment="Left"
                                                HorizontalContentAlignment="Center"
                                                Margin="8,0,0,0"
                                                Cursor="Hand"
                                                Click="BtnCanvasAspectRatio_Click"
                                                ToolTip="切换画布比例">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        Padding="4,0">
                                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                    VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Foreground" Value="#2196F3"/>
                                                                        <Setter Property="FontSize" Value="15"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <!-- 幻灯片列表 -->
                                <ScrollViewer x:Name="SlideScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                              PreviewMouseWheel="SlideScrollViewer_PreviewMouseWheel">
                                    <ScrollViewer.Resources>
                                        <!-- 深灰色滚动条样式（覆盖全局样式） -->
                                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{x:Null}">
                                            <Setter Property="Background" Value="#2C2C2C"/>
                                            <Setter Property="Foreground" Value="#5C5C5C"/>
                                            <Setter Property="Width" Value="12"/>
                                            <Setter Property="MinWidth" Value="12"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                                                        <Grid>
                                                            <Border Background="#2C2C2C" CornerRadius="6"/>
                                                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                                <Track.Thumb>
                                                                    <Thumb>
                                                                        <Thumb.Style>
                                                                            <Style TargetType="Thumb">
                                                                                <Setter Property="Background" Value="#5C5C5C"/>
                                                                                <Setter Property="Template">
                                                                                    <Setter.Value>
                                                                                        <ControlTemplate TargetType="Thumb">
                                                                                            <Border Background="{TemplateBinding Background}"
                                                                                                    CornerRadius="6"
                                                                                                    Margin="2"/>
                                                                                        </ControlTemplate>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                                <Style.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter Property="Background" Value="#7C7C7C"/>
                                                                                    </Trigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Thumb.Style>
                                                                    </Thumb>
                                                                </Track.Thumb>
                                                            </Track>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ScrollViewer.Resources>
                                    <ListBox x:Name="SlideListBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="0"
                                             SelectionMode="Single"
                                             AllowDrop="True"
                                             SelectionChanged="SlideListBox_SelectionChanged"
                                             MouseRightButtonUp="SlideListBox_RightClick"
                                             PreviewMouseLeftButtonDown="SlideListBox_PreviewMouseLeftButtonDown"
                                             PreviewMouseMove="SlideListBox_PreviewMouseMove"
                                             Drop="SlideListBox_Drop"
                                             DragOver="SlideListBox_DragOver"
                                             DragLeave="SlideListBox_DragLeave"
                                             KeyDown="SlideListBox_KeyDown">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Margin" Value="0,0,0,8"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderBrush" Value="#2196F3"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <!-- 缩略图预览区域 -->
                                                <Border Background="White" 
                                                        BorderBrush="#CCCCCC" 
                                                        BorderThickness="1"
                                                        Width="180"
                                                        Height="120"
                                                        HorizontalAlignment="Center">
                                                    <Grid>
                                                        <!-- 背景色 -->
                                                        <Rectangle Fill="{Binding BackgroundColor, TargetNullValue=#FFFFFF}"/>
                                                        
                                                        <!-- 缩略图图片（如果有） -->
                                                        <Image Source="{Binding ThumbnailPath, Converter={StaticResource ThumbnailPathToImageSourceConverter}}" 
                                                               Stretch="Uniform"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"/>
                                                        
                                                        <!-- 占位符（如果没有缩略图） - 已隐藏 -->
                                                        <!--
                                                        <StackPanel HorizontalAlignment="Center" 
                                                                   VerticalAlignment="Center">
                                                            <StackPanel.Style>
                                                                <Style TargetType="StackPanel">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ThumbnailPath}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>
                                                            <TextBlock Text="" 
                                                                       FontSize="32" 
                                                                       HorizontalAlignment="Center" 
                                                                       Foreground="#666666"
                                                                       Margin="0,0,0,4"/>
                                                            <TextBlock Text="{Binding DisplayInfo}" 
                                                                       FontSize="11" 
                                                                       HorizontalAlignment="Center" 
                                                                       Foreground="#999999"/>
                                                        </StackPanel>
                                                        -->
                                                        
                                                        <!-- 序号标签（左下角，贴在内容区域内） -->
                                                        <Border Background="#FF6600" 
                                                                CornerRadius="0,4,0,0"
                                                                Padding="6,2"
                                                                Margin="1,0,0,1"
                                                                HorizontalAlignment="Left" 
                                                                VerticalAlignment="Bottom">
                                                            <TextBlock Text="{Binding SortOrder}" 
                                                                       FontSize="12" 
                                                                       FontWeight="Bold"
                                                                       Foreground="White"/>
                                                        </Border>

                                                        <!-- 透明输出标记（右上角） -->
                                                        <Border Background="#009688"
                                                                CornerRadius="0,0,0,4"
                                                                Padding="6,2"
                                                                Margin="0,1,1,0"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Visibility="Collapsed">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsTransparentOutput}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="透明"
                                                                       FontSize="11"
                                                                       FontWeight="Bold"
                                                                       Foreground="White"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- 分隔线（可拖动调整大小） -->
                        <GridSplitter Grid.Column="1" 
                                      Width="5" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Stretch" 
                                      Background="Transparent"
                                      ShowsPreview="False"/>

                        <!-- 右侧：编辑画布区域 -->
                        <Grid Grid.Column="2" Background="#F5F5F5">
                            <Border Background="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                                <Viewbox Stretch="Uniform" StretchDirection="DownOnly" ClipToBounds="True">
                                    <Grid x:Name="EditorCanvasContainer" Width="1600" Height="900" Background="White" ClipToBounds="True">
                            <Canvas x:Name="EditorCanvas"
                                    Width="1600" Height="900"
                                    Background="White"
                                    MouseLeftButtonDown="EditorCanvas_MouseDown"
                                    KeyDown="EditorCanvas_KeyDown"
                                    Focusable="True"
                                    AllowDrop="True"
                                    ClipToBounds="True">

