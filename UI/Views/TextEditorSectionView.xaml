                    <!--  圣经导航面板（在幻灯片编辑模式下显示，与主界面共享同一个面板） -->
                    <!-- 通过代码动态移动 BibleNavigationPanel 到这里 -->

                    <!-- 主内容区：左侧幻灯片列表 + 右侧编辑区 -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190"/>  <!-- 左侧幻灯片列表 -->
                            <ColumnDefinition Width="Auto"/> <!-- 分隔线 -->
                            <ColumnDefinition Width="*"/>    <!-- 右侧编辑区 -->
                        </Grid.ColumnDefinitions>

                        <!-- 左侧：幻灯片列表面板 -->
                        <Border x:Name="SlidePanelBorder" Grid.Column="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>  <!-- 标题栏 -->
                                    <RowDefinition Height="*"/>     <!-- 幻灯片列表 -->
                                </Grid.RowDefinitions>

                                <!-- 标题栏 -->
                                <Border Grid.Row="0" Background="#FAFAFA" Padding="8" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="幻灯片列表"
                                                   Foreground="#5F6368"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- 幻灯片列表 -->
                                <ScrollViewer x:Name="SlideScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                              PreviewMouseWheel="SlideScrollViewer_PreviewMouseWheel">
                                    <ScrollViewer.Resources>
                                        <!-- 深灰色滚动条样式（覆盖全局样式） -->
                                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{x:Null}">
                                            <Setter Property="Background" Value="#2C2C2C"/>
                                            <Setter Property="Foreground" Value="#5C5C5C"/>
                                            <Setter Property="Width" Value="12"/>
                                            <Setter Property="MinWidth" Value="12"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                                                        <Grid>
                                                            <Border Background="#2C2C2C" CornerRadius="6"/>
                                                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                                <Track.Thumb>
                                                                    <Thumb>
                                                                        <Thumb.Style>
                                                                            <Style TargetType="Thumb">
                                                                                <Setter Property="Background" Value="#5C5C5C"/>
                                                                                <Setter Property="Template">
                                                                                    <Setter.Value>
                                                                                        <ControlTemplate TargetType="Thumb">
                                                                                            <Border Background="{TemplateBinding Background}"
                                                                                                    CornerRadius="6"
                                                                                                    Margin="2"/>
                                                                                        </ControlTemplate>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                                <Style.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter Property="Background" Value="#7C7C7C"/>
                                                                                    </Trigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Thumb.Style>
                                                                    </Thumb>
                                                                </Track.Thumb>
                                                            </Track>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ScrollViewer.Resources>
                                    <ListBox x:Name="SlideListBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="0"
                                             SelectionMode="Single"
                                             AllowDrop="True"
                                             SelectionChanged="SlideListBox_SelectionChanged"
                                             MouseRightButtonUp="SlideListBox_RightClick"
                                             PreviewMouseLeftButtonDown="SlideListBox_PreviewMouseLeftButtonDown"
                                             PreviewMouseMove="SlideListBox_PreviewMouseMove"
                                             Drop="SlideListBox_Drop"
                                             DragOver="SlideListBox_DragOver"
                                             DragLeave="SlideListBox_DragLeave"
                                             KeyDown="SlideListBox_KeyDown">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Margin" Value="0,0,0,8"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderBrush" Value="#2196F3"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <!-- 缩略图预览区域 -->
                                                <Border Background="White" 
                                                        BorderBrush="#CCCCCC" 
                                                        BorderThickness="1"
                                                        Width="180"
                                                        Height="120"
                                                        HorizontalAlignment="Center">
                                                    <Grid>
                                                        <!-- 背景色 -->
                                                        <Rectangle Fill="{Binding BackgroundColor, TargetNullValue=#FFFFFF}"/>
                                                        
                                                        <!-- 缩略图图片（如果有） -->
                                                        <Image Source="{Binding ThumbnailPath, Converter={StaticResource ThumbnailPathToImageSourceConverter}}" 
                                                               Stretch="Uniform"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"/>
                                                        
                                                        <!-- 占位符（如果没有缩略图） - 已隐藏 -->
                                                        <!--
                                                        <StackPanel HorizontalAlignment="Center" 
                                                                   VerticalAlignment="Center">
                                                            <StackPanel.Style>
                                                                <Style TargetType="StackPanel">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ThumbnailPath}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>
                                                            <TextBlock Text="" 
                                                                       FontSize="32" 
                                                                       HorizontalAlignment="Center" 
                                                                       Foreground="#666666"
                                                                       Margin="0,0,0,4"/>
                                                            <TextBlock Text="{Binding DisplayInfo}" 
                                                                       FontSize="11" 
                                                                       HorizontalAlignment="Center" 
                                                                       Foreground="#999999"/>
                                                        </StackPanel>
                                                        -->
                                                        
                                                        <!-- 序号标签（左下角，贴在内容区域内） -->
                                                        <Border Background="#FF6600" 
                                                                CornerRadius="0,4,0,0"
                                                                Padding="6,2"
                                                                Margin="1,0,0,1"
                                                                HorizontalAlignment="Left" 
                                                                VerticalAlignment="Bottom">
                                                            <TextBlock Text="{Binding SortOrder}" 
                                                                       FontSize="12" 
                                                                       FontWeight="Bold"
                                                                       Foreground="White"/>
                                                        </Border>

                                                        <!-- 透明输出标记（右上角） -->
                                                        <Border Background="#009688"
                                                                CornerRadius="0,0,0,4"
                                                                Padding="6,2"
                                                                Margin="0,1,1,0"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Visibility="Collapsed">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsTransparentOutput}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="透明"
                                                                       FontSize="11"
                                                                       FontWeight="Bold"
                                                                       Foreground="White"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- 分隔线（可拖动调整大小） -->
                        <GridSplitter Grid.Column="1" 
                                      Width="5" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Stretch" 
                                      Background="Transparent"
                                      ShowsPreview="False"/>

                        <!-- 右侧：编辑画布区域 -->
                        <Grid Grid.Column="2" Background="#F5F5F5">
                            <Border Background="White"
                                    BorderBrush="#D0D0D0"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="40">
                                <Viewbox Stretch="Uniform" StretchDirection="DownOnly" ClipToBounds="True">
                                    <Grid x:Name="EditorCanvasContainer" Width="1600" Height="900" Background="White" ClipToBounds="True">
                            <Canvas x:Name="EditorCanvas"
                                    Width="1600" Height="900"
                                    Background="White"
                                    MouseLeftButtonDown="EditorCanvas_MouseDown"
                                    KeyDown="EditorCanvas_KeyDown"
                                    Focusable="True"
                                    AllowDrop="True"
                                    ClipToBounds="True">

                                <!-- 背景图通过 Canvas.Background 的 ImageBrush 设置，不再使用 Image 控件 -->
                                <!-- 文本框将动态添加到这里 -->
                            </Canvas>

                            <!-- 圣经弹窗主屏预览层：与投影同源的 Skia 叠加位图 -->
                            <Image x:Name="MainBiblePopupOverlayImage"
                                   Visibility="Collapsed"
                                   Stretch="Fill"
                                   IsHitTestVisible="True"
                                   PreviewMouseLeftButtonDown="MainBiblePopupOverlayImage_PreviewMouseLeftButtonDown"
                                   PreviewMouseWheel="MainBiblePopupOverlayImage_PreviewMouseWheel"
                                   Panel.ZIndex="379"/>

                            <!-- 圣经弹窗关闭按钮（仅交互，不参与文字渲染） -->
                            <Button x:Name="MainBiblePopupOverlayCloseButton"
                                    Visibility="Collapsed"
                                    Width="36"
                                    Height="36"
                                    Padding="0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="0"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Panel.ZIndex="381"
                                    Click="MainBiblePopupClose_Click">
                                <Path Data="M18 6 L6 18 M6 6 L18 18"
                                      Stroke="White"
                                      StrokeThickness="2.2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Stretch="None"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Button>

                            <!-- 幻灯片界面的圣经拼音快速定位提示（复用圣经提示控件） -->
                            <controls:BiblePinyinHintControl x:Name="TextEditorBiblePinyinHintControl"
                                                             Visibility="Collapsed"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             Panel.ZIndex="382"/>

                            <!-- 圣经弹窗（主屏：严格限制在幻灯片画布内） -->
                            <Border x:Name="MainBiblePopupBorder"
                                    Visibility="Collapsed"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    Margin="30,0,30,40"
                                    MaxWidth="1500"
                                    Padding="36,24,16,24"
                                    Background="#FF000000"
                                    BorderBrush="#3CFFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Panel.ZIndex="380">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Vertical">
                                        <TextBlock x:Name="MainBiblePopupReferenceText"
                                                   Text=""
                                                   FontFamily="Microsoft YaHei UI"
                                                   FontSize="42"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFD54F"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,10"/>
                                        <ScrollViewer x:Name="MainBiblePopupContentScrollViewer"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      CanContentScroll="True"
                                                      MaxHeight="210">
                                            <TextBlock x:Name="MainBiblePopupContentText"
                                                       Text=""
                                                       FontFamily="Microsoft YaHei UI"
                                                       FontSize="56"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       TextWrapping="Wrap"
                                                       LineStackingStrategy="BlockLineHeight"
                                                       LineHeight="70"/>
                                        </ScrollViewer>
                                    </StackPanel>

                                    <Button x:Name="MainBiblePopupCloseButton"
                                            Grid.Column="1"
                                            Width="36"
                                            Height="36"
                                            Padding="0"
                                            Margin="12,0,0,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="MainBiblePopupClose_Click">
                                        <Path Data="M18 6 L6 18 M6 6 L18 18"
                                              Stroke="White"
                                              StrokeThickness="2.2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Stretch="None"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>
                            </Border>
                            
                            <!--  圣经经文工具栏（悬浮在画布上方中央） -->
                                                        <Popup x:Name="BibleToolbar"
                                   AllowsTransparency="True"
                                   StaysOpen="True"
                                   Placement="Center"
                                   PlacementTarget="{Binding ElementName=EditorCanvas}"
                                   HorizontalOffset="0"
                                   VerticalOffset="-495"
                                   IsOpen="False"/>

                            <!--  边框设置侧边面板 -->
                            <Popup x:Name="AlignmentSettingsPopup"
                                   AllowsTransparency="True"
                                   StaysOpen="False"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=BtnSecondLayerAlignPlaceholder}"
                                   HorizontalOffset="0"
                                   VerticalOffset="6"
                                   IsOpen="False">
                                <Border Background="#F7F7F7"
                                        BorderBrush="#D8D8D8"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="8">
                                    <StackPanel>
                                        <UniformGrid Rows="1" Columns="4" Margin="0,0,0,6">
                                            <Button x:Name="BtnSecondLayerAlignLeft"
                                                    Width="32" Height="30" Margin="2"
                                                    Style="{StaticResource CompactButtonStyle}"
                                                    ToolTip="左对齐"
                                                    Click="BtnAlignLeft_Click">
                                                <Path Data="{StaticResource IconLucideAlignLeft}"
                                                      Style="{StaticResource LucideIconPathStyle}"
                                                      Width="14"
                                                      Height="14"/>
                                            </Button>
                                            <Button x:Name="BtnSecondLayerAlignCenter"
                                                    Width="32" Height="30" Margin="2"
                                                    Style="{StaticResource CompactButtonStyle}"
                                                    ToolTip="居中对齐"
                                                    Click="BtnAlignCenter_Click">
                                                <Path Data="{StaticResource IconLucideAlignCenter}"
                                                      Style="{StaticResource LucideIconPathStyle}"
                                                      Width="14"
                                                      Height="14"/>
                                            </Button>
                                            <Button x:Name="BtnSecondLayerAlignRight"
                                                    Width="32" Height="30" Margin="2"
                                                    Style="{StaticResource CompactButtonStyle}"
                                                    ToolTip="右对齐"
                                                    Click="BtnAlignRight_Click">
                                                <Path Data="{StaticResource IconLucideAlignRight}"
                                                      Style="{StaticResource LucideIconPathStyle}"
                                                      Width="14"
                                                      Height="14"/>
                                            </Button>
                                            <Button x:Name="BtnSecondLayerAlignJustify"
                                                    Width="32" Height="30" Margin="2"
                                                    Style="{StaticResource CompactButtonStyle}"
                                                    ToolTip="两端对齐"
                                                    Click="BtnAlignJustify_Click">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Width="14">
                                                    <Rectangle Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Height="2" Margin="0,1" HorizontalAlignment="Stretch"/>
                                                    <Rectangle Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Height="2" Margin="0,1" HorizontalAlignment="Stretch"/>
                                                    <Rectangle Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Height="2" Margin="0,1" HorizontalAlignment="Stretch"/>
                                                </StackPanel>
                                            </Button>
                                        </UniformGrid>

                                        <UniformGrid Rows="1" Columns="3">
                                            <Button x:Name="BtnSecondLayerAlignTop"
                                                    Width="32" Height="30" Margin="2"
                                                    Style="{StaticResource CompactButtonStyle}"
                                                    ToolTip="上对齐"
                                                    Click="BtnAlignTop_Click">
                                                <Grid Width="16" Height="16">
                                                    <Rectangle Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                               Height="2"
                                                               Width="14"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Top"/>
                                                    <Path Data="M8 14V6 M5.2 8.8L8 6L10.8 8.8"
                                                          Width="8"
                                                          Height="8"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Bottom"
                                                          Stretch="Fill"
                                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="1.8"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round"
                                                          Fill="Transparent"/>
                                                </Grid>
                                            </Button>
                                            <Button x:Name="BtnSecondLayerAlignMiddle"
                                                    Width="32" Height="30" Margin="2"
                                                    Style="{StaticResource CompactButtonStyle}"
                                                    ToolTip="垂直居中"
                                                    Click="BtnAlignMiddle_Click">
                                                <Grid Width="16" Height="16">
                                                    <Rectangle Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                               Height="2"
                                                               Width="14"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                    <Path Data="M8 6V1.5 M5.5 4L8 1.5L10.5 4"
                                                          Width="8"
                                                          Height="5"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Top"
                                                          Stretch="Fill"
                                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="1.8"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round"
                                                          Fill="Transparent"/>
                                                    <Path Data="M8 10V14.5 M5.5 12L8 14.5L10.5 12"
                                                          Width="8"
                                                          Height="5"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Bottom"
                                                          Stretch="Fill"
                                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="1.8"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round"
                                                          Fill="Transparent"/>
                                                </Grid>
                                            </Button>
                                            <Button x:Name="BtnSecondLayerAlignBottom"
                                                    Width="32" Height="30" Margin="2"
                                                    Style="{StaticResource CompactButtonStyle}"
                                                    ToolTip="下对齐"
                                                    Click="BtnAlignBottom_Click">
                                                <Grid Width="16" Height="16">
                                                    <Rectangle Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                               Height="2"
                                                               Width="14"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Bottom"/>
                                                    <Path Data="M8 2V10 M5.2 7.2L8 10L10.8 7.2"
                                                          Width="8"
                                                          Height="8"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Top"
                                                          Stretch="Fill"
                                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="1.8"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round"
                                                          Fill="Transparent"/>
                                                </Grid>
                                            </Button>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </Popup>

                            <Popup x:Name="BorderSettingsPopup"
                                   AllowsTransparency="True"
                                   StaysOpen="False"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=BtnSecondLayerBorderWidthPlaceholder}"
                                   HorizontalOffset="0"
                                   VerticalOffset="6"
                                   IsOpen="False">
                                <Border Background="#F7F7F7"
                                        BorderBrush="#D8D8D8"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="6">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="16" Opacity="0.22" Color="#000000"/>
                                    </Border.Effect>
                                    <controls:BorderSettingsPanel x:Name="BorderSettingsPanel"/>
                                </Border>
                            </Popup>

                            <!--  背景设置侧边面板 -->
                            <Popup x:Name="BackgroundSettingsPopup"
                                   AllowsTransparency="True"
                                   StaysOpen="False"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=BtnSecondLayerFillColorPlaceholder}"
                                   HorizontalOffset="0"
                                   VerticalOffset="6"
                                   IsOpen="False">
                                <Border Background="#F7F7F7"
                                        BorderBrush="#D8D8D8"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="6">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="16" Opacity="0.22" Color="#000000"/>
                                    </Border.Effect>
                                    <controls:BackgroundSettingsPanel x:Name="BackgroundSettingsPanel"/>
                                </Border>
                            </Popup>

                            <!--  文本颜色设置侧边面板 -->
                            <Popup x:Name="TextColorSettingsPopup"
                                   AllowsTransparency="True"
                                   StaysOpen="False"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=BtnSecondLayerTextColor}"
                                   HorizontalOffset="0"
                                   VerticalOffset="6"
                                   IsOpen="False">
                                <Border Background="#F7F7F7"
                                        BorderBrush="#D8D8D8"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="6">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="16" Opacity="0.22" Color="#000000"/>
                                    </Border.Effect>
                                    <controls:TextColorSettingsPanel x:Name="TextColorSettingsPanel"/>
                                </Border>
                            </Popup>

                            <Popup x:Name="NoticeSettingsPopup"
                                   AllowsTransparency="True"
                                   StaysOpen="False"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=BtnSecondLayerNoticeSettings}"
                                   HorizontalOffset="0"
                                   VerticalOffset="6"
                                   IsOpen="False">
                                <Border Background="#F7F7F7"
                                        BorderBrush="#D8D8D8"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="6">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="16" Opacity="0.22" Color="#000000"/>
                                    </Border.Effect>
                                    <controls:NoticeSettingsPanel x:Name="NoticeSettingsPanel"/>
                                </Border>
                            </Popup>

                            <!--  阴影设置侧边面板 -->
                            <Popup x:Name="ShadowSettingsPopup"
                                   AllowsTransparency="True"
                                   StaysOpen="True"
                                   Placement="Relative"
                                   PlacementTarget="{Binding ElementName=SlidePanelBorder}"
                                   HorizontalOffset="0"
                                   VerticalOffset="0"
                                   IsOpen="False">
                                <Border Background="White"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.3" Color="#000000"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="20"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0"
                                                Background="#2E7D32"
                                                Cursor="SizeAll"
                                                Tag="ShadowSettingsPopup"
                                                MouseLeftButtonDown="SidePanelDragHandle_MouseLeftButtonDown"
                                                MouseMove="SidePanelDragHandle_MouseMove"
                                                MouseLeftButtonUp="SidePanelDragHandle_MouseLeftButtonUp">
                                            <Grid>
                                                <Button Content="X"
                                                        Style="{StaticResource SidePanelHeaderCloseButtonStyle}"
                                                        Tag="ShadowSettingsPopup"
                                                        Click="SidePanelHeaderClose_Click"/>
                                            </Grid>
                                        </Border>
                                        <controls:ShadowSettingsPanel x:Name="ShadowSettingsPanel" Grid.Row="1"/>
                                    </Grid>
                                </Border>
                            </Popup>

                            <!--  间距设置侧边面板 -->
                            <Popup x:Name="SpacingSettingsPopup"
                                   AllowsTransparency="True"
                                   StaysOpen="True"
                                   Placement="Relative"
                                   PlacementTarget="{Binding ElementName=SlidePanelBorder}"
                                   HorizontalOffset="0"
                                   VerticalOffset="0"
                                   IsOpen="False">
                                <Border Background="#2D2D30"
                                        BorderBrush="#3F3F46"
                                        BorderThickness="1,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.3" Color="#000000"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="20"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0"
                                                Background="#2E7D32"
                                                Cursor="SizeAll"
                                                Tag="SpacingSettingsPopup"
                                                MouseLeftButtonDown="SidePanelDragHandle_MouseLeftButtonDown"
                                                MouseMove="SidePanelDragHandle_MouseMove"
                                                MouseLeftButtonUp="SidePanelDragHandle_MouseLeftButtonUp">
                                            <Grid>
                                                <Button Content="X"
                                                        Style="{StaticResource SidePanelHeaderCloseButtonStyle}"
                                                        Tag="SpacingSettingsPopup"
                                                        Click="SidePanelHeaderClose_Click"/>
                                            </Grid>
                                        </Border>
                                        <controls:SpacingSettingsPanel x:Name="SpacingSettingsPanel" Grid.Row="1"/>
                                    </Grid>
                                </Border>
                            </Popup>

                            <!--  动画设置侧边面板 -->
                            <Popup x:Name="AnimationSettingsPopup"
                                   AllowsTransparency="True"
                                   StaysOpen="True"
                                   Placement="Relative"
                                   PlacementTarget="{Binding ElementName=SlidePanelBorder}"
                                   HorizontalOffset="0"
                                   VerticalOffset="0"
                                   IsOpen="False">
                                <Border Background="#2D2D30"
                                        BorderBrush="#3F3F46"
                                        BorderThickness="1,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.3" Color="#000000"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="20"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0"
                                                Background="#2E7D32"
                                                Cursor="SizeAll"
                                                Tag="AnimationSettingsPopup"
                                                MouseLeftButtonDown="SidePanelDragHandle_MouseLeftButtonDown"
                                                MouseMove="SidePanelDragHandle_MouseMove"
                                                MouseLeftButtonUp="SidePanelDragHandle_MouseLeftButtonUp">
                                            <Grid>
                                                <Button Content="X"
                                                        Style="{StaticResource SidePanelHeaderCloseButtonStyle}"
                                                        Tag="AnimationSettingsPopup"
                                                        Click="SidePanelHeaderClose_Click"/>
                                            </Grid>
                                        </Border>
                                        <controls:AnimationSettingsPanel x:Name="AnimationSettingsPanel" Grid.Row="1"/>
                                    </Grid>
                                </Border>
                            </Popup>

                            <!-- 辅助线（叠加在Canvas上方）-->
                            <Canvas x:Name="AlignmentGuidesCanvas" 
                                    Width="1080" Height="700"
                                    IsHitTestVisible="False"
                                    Panel.ZIndex="1000">
                                <!-- 垂直中心线 -->
                                <Line x:Name="VerticalCenterLine" 
                                      X1="540" Y1="0" X2="540" Y2="700"
                                      Stroke="#FF2196F3" StrokeThickness="2" 
                                      StrokeDashArray="8,4"
                                      Visibility="Collapsed">
                                    <Line.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.5" Color="#2196F3"/>
                                    </Line.Effect>
                                </Line>
                                
                                <!-- 水平中心线 -->
                                <Line x:Name="HorizontalCenterLine" 
                                      X1="0" Y1="350" X2="1080" Y2="350"
                                      Stroke="#FF2196F3" StrokeThickness="2" 
                                      StrokeDashArray="8,4"
                                      Visibility="Collapsed">
                                    <Line.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.5" Color="#2196F3"/>
                                    </Line.Effect>
                                </Line>
                                
                                <!-- 垂直对齐线（与其他文本框对齐）-->
                                <Line x:Name="VerticalAlignLine" 
                                      X1="0" Y1="0" X2="0" Y2="700"
                                      Stroke="#FFFF9800" StrokeThickness="1.5" 
                                      StrokeDashArray="4,2"
                                      Visibility="Collapsed"/>
                                
                                <!-- 水平对齐线（与其他文本框对齐）-->
                                <Line x:Name="HorizontalAlignLine" 
                                      X1="0" Y1="0" X2="1080" Y2="0"
                                      Stroke="#FFFF9800" StrokeThickness="1.5" 
                                      StrokeDashArray="4,2"
                                      Visibility="Collapsed"/>
                            </Canvas>
                        </Grid>
                    </Viewbox>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>


</UserControl>



