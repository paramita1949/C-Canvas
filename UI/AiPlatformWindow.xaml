<Window x:Class="ImageColorChanger.UI.AiPlatformWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI平台"
        Width="560"
        Height="470"
        MinWidth="460"
        MinHeight="470"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#EEF3F8"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="128"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="#1D6FE8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1D6FE8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#296FED"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#296FED"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#155DC8"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#155DC8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#19365B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Height" Value="42"/>
            <Setter Property="BorderBrush" Value="#BED0E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FDFEFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#0F2A47"
                BorderBrush="#2A5C8E"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18,14"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="AI平台"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#F3F8FF"/>
                    <TextBlock Text="集中管理 AI 模型与密钥配置"
                               Foreground="#B8CCE3"
                               FontSize="13"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#1D6FE8"
                        BorderBrush="#4F93F2"
                        BorderThickness="1"
                        CornerRadius="9"
                        Padding="12,6"
                        VerticalAlignment="Top">
                    <TextBlock Text="DeepSeek"
                               Foreground="#EAF3FF"
                               FontSize="12"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#F8FBFF"
                BorderBrush="#CCDAEA"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18">
            <StackPanel>
                <TextBlock Text="模型" Style="{StaticResource FieldLabelStyle}"/>
                <ComboBox x:Name="DeepSeekModelComboBox"
                          Style="{StaticResource InputStyle}"
                          VerticalContentAlignment="Center">
                    <ComboBoxItem Content="deepseek-v4-flash"/>
                    <ComboBoxItem Content="deepseek-v4-pro"/>
                </ComboBox>

                <TextBlock Text="密钥"
                           Style="{StaticResource FieldLabelStyle}"
                           Margin="0,14,0,8"/>
                <PasswordBox x:Name="DeepSeekApiKeyBox"
                             Style="{StaticResource InputStyle}"
                             VerticalContentAlignment="Center"/>

                <TextBlock Text="当前仅接入 DeepSeek。后续可在此扩展更多模型。"
                           Foreground="#5B728D"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="#F8FBFF"
                BorderBrush="#CCDAEA"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14,10"
                Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="DeepSeekConfigStatusText"
                           Text="尚未保存"
                           Foreground="#4E647D"
                           FontSize="13"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="保存配置"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="SaveDeepSeekConfigButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
