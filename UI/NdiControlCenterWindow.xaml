<Window x:Class="ImageColorChanger.UI.NdiControlCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="NDI网络流控制台"
        Height="700"
        Width="860"
        MinHeight="700"
        MinWidth="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F7FC"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E6EDF5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18,16,18,16"/>
        </Style>
        <Style x:Key="OptionRowStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#E5ECF4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FBFDFF"/>
            <Setter Property="Padding" Value="10,8,10,8"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="SwitchStyle" TargetType="primitives:ToggleButton">
            <Setter Property="Width" Value="54"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="primitives:ToggleButton">
                        <Grid>
                            <Border x:Name="Track" CornerRadius="15" Background="{TemplateBinding Background}"/>
                            <Border x:Name="Thumb"
                                    Width="24"
                                    Height="24"
                                    CornerRadius="12"
                                    Background="White"
                                    HorizontalAlignment="Left"
                                    Margin="3,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#2563EB"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="132"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22,18,22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="14"
                Padding="16,12,16,12"
                Background="#0F172A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="NDI网络流控制台"
                               FontSize="23"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="统一管理歌词、字幕、水印与连接状态"
                               Margin="0,3,0,0"
                               FontSize="13"
                               Foreground="#BFDBFE"/>
                </StackPanel>
                <Border x:Name="RuntimeBadge"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        CornerRadius="999"
                        BorderThickness="1"
                        Padding="12,6,12,6">
                    <TextBlock x:Name="RuntimeBadgeText"
                               FontSize="12"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="总开关" FontSize="13" Foreground="#64748B"/>
                    <TextBlock x:Name="MasterSummaryText"
                               Margin="0,6,0,0"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#0F172A"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="客户端连接数" FontSize="13" Foreground="#64748B"/>
                    <TextBlock x:Name="ConnectionSummaryText"
                               Margin="0,6,0,0"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#0F172A"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="通道状态" FontSize="13" Foreground="#64748B"/>
                    <TextBlock x:Name="ChannelSummaryText"
                               Margin="0,6,0,0"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#0F172A"/>
                </StackPanel>
            </Border>
        </Grid>

        <ScrollViewer Grid.Row="4"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="投放控制" FontSize="17" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <TextBlock Text="可先预配置全部选项，再统一开启 NDI"
                               Margin="0,4,0,14"
                               FontSize="12"
                               Foreground="#64748B"/>

                    <Border Style="{StaticResource OptionRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="⏻" FontSize="18" VerticalAlignment="Center" Foreground="#1D4ED8"/>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="启用 NDI 网络流" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBlock Text="控制网络推流总状态" FontSize="12" Foreground="#64748B"/>
                            </StackPanel>
                            <primitives:ToggleButton x:Name="MasterToggle" Grid.Column="2" Style="{StaticResource SwitchStyle}" Click="MasterToggle_Click"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource OptionRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="♪" FontSize="18" VerticalAlignment="Center" Foreground="#2563EB"/>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="启用歌词 NDI 输出" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBlock Text="将歌词内容推送到 NDI 网络流" FontSize="12" Foreground="#64748B"/>
                            </StackPanel>
                            <primitives:ToggleButton x:Name="LyricsToggle" Grid.Column="2" Style="{StaticResource SwitchStyle}" Click="LyricsToggle_Click"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource OptionRowStyle}" Margin="18,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="◌" FontSize="18" VerticalAlignment="Center" Foreground="#2563EB"/>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="启用歌词透明（NDI）" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBlock Text="仅影响歌词 NDI 输出画面的透明背景" FontSize="12" Foreground="#64748B"/>
                                <TextBlock x:Name="LyricsTransparentStateText"
                                           Margin="0,2,0,0"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#0EA5E9"/>
                            </StackPanel>
                            <primitives:ToggleButton x:Name="TransparentToggle" Grid.Column="2" Style="{StaticResource SwitchStyle}" Click="TransparentToggle_Click"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource OptionRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="CC" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Foreground="#2563EB"/>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="启用字幕 NDI 输出" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBlock Text="将 AI 字幕内容推送到 NDI 网络流" FontSize="12" Foreground="#64748B"/>
                            </StackPanel>
                            <primitives:ToggleButton x:Name="CaptionToggle" Grid.Column="2" Style="{StaticResource SwitchStyle}" Click="CaptionToggle_Click"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="状态与工具" FontSize="17" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <TextBlock Text="建议先确认连接状态，再进入帧水印设置"
                               Margin="0,4,0,14"
                               FontSize="12"
                               Foreground="#64748B"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="帧水印设置"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="WatermarkButton_Click"/>
                        <Button Content="刷新状态"
                                Margin="10,0,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="RefreshButton_Click"/>
                    </StackPanel>

                    <Border Margin="0,14,0,0"
                            BorderThickness="1"
                            BorderBrush="#E2E8F0"
                            Background="#F8FAFC"
                            CornerRadius="10"
                            Padding="12,10,12,10">
                        <TextBlock x:Name="StatusText"
                                   FontSize="13"
                                   Foreground="#334155"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="关闭"
                    Width="96"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
