<Window x:Class="ImageColorChanger.UI.NdiControlCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="NDI网络流控制台"
        Height="580"
        Width="860"
        MinHeight="580"
        MinWidth="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F7FC"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E6EDF5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="14,12,14,12"/>
        </Style>
        <Style x:Key="OptionRowStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#E5ECF4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FBFDFF"/>
            <Setter Property="Padding" Value="10,5,10,5"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="SwitchStyle" TargetType="primitives:ToggleButton">
            <Setter Property="Width" Value="54"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="primitives:ToggleButton">
                        <Grid>
                            <Border x:Name="Track" CornerRadius="15" Background="{TemplateBinding Background}"/>
                            <Border x:Name="Thumb"
                                    Width="24"
                                    Height="24"
                                    CornerRadius="12"
                                    Background="White"
                                    HorizontalAlignment="Left"
                                    Margin="3,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#2563EB"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="132"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="MiniPosButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="58"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SegmentPosButtonLeftStyle" TargetType="Button" BasedOn="{StaticResource MiniPosButtonStyle}">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinWidth" Value="56"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9,0,0,9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SegmentPosButtonMidStyle" TargetType="Button" BasedOn="{StaticResource MiniPosButtonStyle}">
            <Setter Property="Margin" Value="-1,0,0,0"/>
            <Setter Property="MinWidth" Value="56"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SegmentPosButtonRightStyle" TargetType="Button" BasedOn="{StaticResource MiniPosButtonStyle}">
            <Setter Property="Margin" Value="-1,0,0,0"/>
            <Setter Property="MinWidth" Value="56"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0,9,9,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TopRefreshButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="#22345F"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2B467A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1E3A66"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HeaderToolButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#D6E2F0"/>
            <Setter Property="Background" Value="#F8FBFF"/>
            <Setter Property="Foreground" Value="#1E3A8A"/>
        </Style>
        <Style x:Key="WatermarkLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#64748B"/>
        </Style>
        <Style x:Key="WatermarkInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FBFDFF"/>
        </Style>
        <Style x:Key="CompactComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FBFDFF"/>
            <Setter Property="Foreground" Value="#0F172A"/>
        </Style>
        <Style x:Key="ChromeLessScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Hidden"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="PanningMode" Value="VerticalOnly"/>
            <Setter Property="CanContentScroll" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollHintChipStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="10,3,10,3"/>
            <Setter Property="Background" Value="#F8FBFF"/>
            <Setter Property="BorderBrush" Value="#D6E2F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,10,20,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="14"
                Padding="16,10,16,10"
                Background="#0F172A">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="NDI网络流控制台"
                               FontSize="21"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="统一管理投影、透明、字幕、水印"
                               Margin="0,2,0,0"
                               FontSize="12"
                               Foreground="#BFDBFE"/>
                </StackPanel>
                <StackPanel Grid.Row="0"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <Border x:Name="RuntimeBadge"
                            VerticalAlignment="Center"
                            CornerRadius="999"
                            BorderThickness="1"
                            Padding="12,5,12,5">
                        <TextBlock x:Name="RuntimeBadgeText"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <Button Margin="8,0,0,0"
                            Content="↻ 刷新"
                            ToolTip="刷新连接状态"
                            Style="{StaticResource HeaderToolButtonStyle}"
                            Click="RefreshButton_Click"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Margin="0,8,0,0"
                        CornerRadius="10"
                        Background="#142447"
                        BorderBrush="#1D335E"
                        BorderThickness="1"
                        Padding="10,6,10,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="总开关 " FontSize="11.5" Foreground="#93C5FD"/>
                            <TextBlock x:Name="MasterSummaryText" FontSize="13" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="连接数 " FontSize="11.5" Foreground="#93C5FD"/>
                            <TextBlock x:Name="ConnectionSummaryText" FontSize="13" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="投放控制" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <TextBlock Grid.Row="1" Text="按通道独立开关，支持实时生效"
                               Margin="0,2,0,0"
                               FontSize="12"
                               Foreground="#64748B"/>

                    <Grid Grid.Row="3">
                    <ScrollViewer x:Name="ControlListScrollViewer"
                                  Style="{StaticResource ChromeLessScrollViewerStyle}"
                                  ScrollChanged="ControlListScrollViewer_ScrollChanged">
                    <StackPanel x:Name="ControlListStackPanel">
                    <Border Style="{StaticResource OptionRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="⏻" FontSize="17" VerticalAlignment="Center" Foreground="#1D4ED8"/>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="启用 NDI 网络流" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBlock Text="总控" FontSize="11.5" Foreground="#64748B"/>
                            </StackPanel>
                            <primitives:ToggleButton x:Name="MasterToggle" Grid.Column="2" Style="{StaticResource SwitchStyle}" Click="MasterToggle_Click"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource OptionRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="▣" FontSize="17" VerticalAlignment="Center" Foreground="#2563EB"/>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="启用投影 NDI 输出" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBlock Text="统一输出主投影画面" FontSize="11.5" Foreground="#64748B"/>
                            </StackPanel>
                            <primitives:ToggleButton x:Name="SlideToggle" Grid.Column="2" Style="{StaticResource SwitchStyle}" Click="SlideToggle_Click"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource OptionRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="◌" FontSize="17" VerticalAlignment="Center" Foreground="#2563EB"/>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="启用透明 NDI 输出" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBlock Text="独立透明源（歌词/幻灯片）" FontSize="11.5" Foreground="#64748B"/>
                                <TextBlock x:Name="LyricsTransparentStateText"
                                           Margin="0,1,0,0"
                                           FontSize="11.5"
                                           FontWeight="SemiBold"
                                           Foreground="#0EA5E9"/>
                            </StackPanel>
                            <primitives:ToggleButton x:Name="TransparentToggle" Grid.Column="2" Style="{StaticResource SwitchStyle}" Click="TransparentToggle_Click"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource OptionRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="CC" FontSize="13.5" FontWeight="Bold" VerticalAlignment="Center" Foreground="#2563EB"/>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="启用字幕 NDI 输出" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBlock Text="AI 字幕专用通道" FontSize="11.5" Foreground="#64748B"/>
                            </StackPanel>
                            <primitives:ToggleButton x:Name="CaptionToggle" Grid.Column="2" Style="{StaticResource SwitchStyle}" Click="CaptionToggle_Click"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource OptionRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="✦" FontSize="16" VerticalAlignment="Center" Foreground="#2563EB"/>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="启用水印 NDI 输出" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBlock Text="独立水印通道" FontSize="11.5" Foreground="#64748B"/>
                            </StackPanel>
                            <primitives:ToggleButton x:Name="WatermarkToggle" Grid.Column="2" Style="{StaticResource SwitchStyle}" Click="WatermarkToggle_Click"/>
                        </Grid>
                    </Border>
                    </StackPanel>
                    </ScrollViewer>
                        <Grid x:Name="ScrollHintOverlay"
                              VerticalAlignment="Bottom"
                              Height="60"
                              IsHitTestVisible="False"
                              Visibility="Collapsed">
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#00FFFFFF" Offset="0"/>
                                    <GradientStop Color="#F4F7FC" Offset="1"/>
                                </LinearGradientBrush>
                            </Grid.Background>
                            <Border x:Name="ScrollHintChip"
                                    Style="{StaticResource ScrollHintChipStyle}"
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,6"
                                    Opacity="0.92">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="更多"
                                               FontSize="11"
                                               Foreground="#1E3A8A"/>
                                    <TextBlock x:Name="ScrollHintArrow"
                                               Text="⌄"
                                               Margin="6,0,0,0"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#1E3A8A">
                                        <TextBlock.RenderTransform>
                                            <TranslateTransform x:Name="ScrollHintArrowTransform"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="WatermarkTabButton"
                                Grid.Column="0"
                                Content="水印设置"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="40"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Click="WatermarkTabButton_Click"/>
                        <Button x:Name="AudioTabButton"
                                Grid.Column="2"
                                Content="音频设置"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="40"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Click="AudioTabButton_Click"/>
                    </Grid>

                    <StackPanel x:Name="WatermarkSectionPanel" Margin="0,6,0,0">
                            <TextBlock Text="文字" Style="{StaticResource WatermarkLabelStyle}"/>
                            <TextBox x:Name="WatermarkTextTextBox"
                                     Style="{StaticResource WatermarkInputStyle}"
                                     Padding="10,0,10,0"
                                     TextChanged="WatermarkTextTextBox_TextChanged"/>

                            <TextBlock Text="位置" Style="{StaticResource WatermarkLabelStyle}"/>
                            <Border BorderBrush="#CBD5E1" BorderThickness="0" CornerRadius="10" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="PosLeftTopButton" Content="左上" Style="{StaticResource SegmentPosButtonLeftStyle}" Click="PosLeftTopButton_Click"/>
                                    <Button x:Name="PosRightTopButton" Content="右上" Style="{StaticResource SegmentPosButtonMidStyle}" Click="PosRightTopButton_Click"/>
                                    <Button x:Name="PosLeftBottomButton" Content="左下" Style="{StaticResource SegmentPosButtonMidStyle}" Click="PosLeftBottomButton_Click"/>
                                    <Button x:Name="PosRightBottomButton" Content="右下" Style="{StaticResource SegmentPosButtonMidStyle}" Click="PosRightBottomButton_Click"/>
                                    <Button x:Name="PosCenterButton" Content="居中" Style="{StaticResource SegmentPosButtonRightStyle}" Click="PosCenterButton_Click"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="字体" Style="{StaticResource WatermarkLabelStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="WatermarkFontTextBox"
                                         Style="{StaticResource WatermarkInputStyle}"
                                         IsReadOnly="True"
                                         Padding="10,0,10,0"
                                         MinWidth="150"/>
                                <Button Grid.Column="2"
                                        Content="选择字体"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="ChooseFontButton_Click"/>
                            </Grid>

                            <TextBlock Text="字号" Style="{StaticResource WatermarkLabelStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="78"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="WatermarkSizeSlider"
                                        Minimum="10"
                                        Maximum="220"
                                        TickFrequency="2"
                                        VerticalAlignment="Center"
                                        ValueChanged="WatermarkSizeSlider_ValueChanged"/>
                                <TextBox x:Name="WatermarkSizeTextBox"
                                         Grid.Column="2"
                                         Style="{StaticResource WatermarkInputStyle}"
                                         TextAlignment="Center"
                                         TextChanged="WatermarkSizeTextBox_TextChanged"/>
                            </Grid>

                            <TextBlock Text="透明度" Style="{StaticResource WatermarkLabelStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="78"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="WatermarkOpacitySlider"
                                        Minimum="0"
                                        Maximum="100"
                                        TickFrequency="1"
                                        VerticalAlignment="Center"
                                        ValueChanged="WatermarkOpacitySlider_ValueChanged"/>
                                <TextBox x:Name="WatermarkOpacityTextBox"
                                         Grid.Column="2"
                                         Style="{StaticResource WatermarkInputStyle}"
                                         TextAlignment="Center"
                                         TextChanged="WatermarkOpacityTextBox_TextChanged"/>
                            </Grid>
                    </StackPanel>

                    <Border x:Name="AudioSectionPanel"
                            Margin="0,6,0,0"
                            Visibility="Collapsed"
                            Padding="12,8,12,8"
                            CornerRadius="12"
                            Background="#F8FBFF"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="音频"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1E293B"/>
                                        <TextBlock x:Name="AudioSectionSummaryText"
                                                   Margin="0,2,0,0"
                                                   FontSize="11.5"
                                                   Foreground="#64748B"/>
                                    </StackPanel>
                                    <primitives:ToggleButton x:Name="AudioToggle"
                                                             Grid.Column="1"
                                                             Style="{StaticResource SwitchStyle}"
                                                             Click="AudioToggle_Click"/>
                                </Grid>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="116"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="AudioSourceComboBox"
                                              Style="{StaticResource CompactComboBoxStyle}"
                                              SelectedValuePath="Tag"
                                              SelectionChanged="AudioSourceComboBox_SelectionChanged">
                                        <ComboBoxItem Content="系统声音" Tag="system"/>
                                        <ComboBoxItem Content="输入设备" Tag="input"/>
                                    </ComboBox>
                                    <ComboBox x:Name="AudioDeviceComboBox"
                                              Grid.Column="2"
                                              Style="{StaticResource CompactComboBoxStyle}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Id"
                                              SelectionChanged="AudioDeviceComboBox_SelectionChanged"/>
                                </Grid>

                                <TextBlock x:Name="AudioStatusTextBlock"
                                           Margin="0,6,0,0"
                                           FontSize="11.5"
                                           TextWrapping="Wrap"
                                           Foreground="#64748B"/>
                            </StackPanel>
                        </Border>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,2">
            <Button Content="关闭"
                    Width="96"
                    Height="32"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
