<Window x:Class="ImageColorChanger.UI.NdiControlCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="NDI网络流控制台"
        Height="680"
        Width="860"
        MinHeight="680"
        MinWidth="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F7FC"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E6EDF5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18,16,18,16"/>
        </Style>
        <Style x:Key="OptionRowStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#E5ECF4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FBFDFF"/>
            <Setter Property="Padding" Value="10,6,10,6"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="SwitchStyle" TargetType="primitives:ToggleButton">
            <Setter Property="Width" Value="54"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="primitives:ToggleButton">
                        <Grid>
                            <Border x:Name="Track" CornerRadius="15" Background="{TemplateBinding Background}"/>
                            <Border x:Name="Thumb"
                                    Width="24"
                                    Height="24"
                                    CornerRadius="12"
                                    Background="White"
                                    HorizontalAlignment="Left"
                                    Margin="3,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#2563EB"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="132"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="MiniPosButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="58"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SegmentPosButtonLeftStyle" TargetType="Button" BasedOn="{StaticResource MiniPosButtonStyle}">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinWidth" Value="56"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9,0,0,9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SegmentPosButtonMidStyle" TargetType="Button" BasedOn="{StaticResource MiniPosButtonStyle}">
            <Setter Property="Margin" Value="-1,0,0,0"/>
            <Setter Property="MinWidth" Value="56"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SegmentPosButtonRightStyle" TargetType="Button" BasedOn="{StaticResource MiniPosButtonStyle}">
            <Setter Property="Margin" Value="-1,0,0,0"/>
            <Setter Property="MinWidth" Value="56"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0,9,9,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TopRefreshButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="#22345F"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2B467A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1E3A66"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HeaderToolButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#D6E2F0"/>
            <Setter Property="Background" Value="#F8FBFF"/>
            <Setter Property="Foreground" Value="#1E3A8A"/>
        </Style>
        <Style x:Key="WatermarkLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,10,0,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#64748B"/>
        </Style>
        <Style x:Key="WatermarkInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FBFDFF"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="14"
                Padding="16,12,16,12"
                Background="#0F172A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="NDI网络流控制台"
                               FontSize="23"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="统一管理歌词、字幕、水印与连接状态"
                               Margin="0,3,0,0"
                               FontSize="13"
                               Foreground="#BFDBFE"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <Border x:Name="RuntimeBadge"
                            VerticalAlignment="Center"
                            CornerRadius="999"
                            BorderThickness="1"
                            Padding="12,6,12,6">
                        <TextBlock x:Name="RuntimeBadgeText"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="总开关" FontSize="13" Foreground="#64748B"/>
                    <TextBlock x:Name="MasterSummaryText"
                               Margin="0,6,0,0"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#0F172A"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="客户端连接数" FontSize="13" Foreground="#64748B"/>
                    <TextBlock x:Name="ConnectionSummaryText"
                               Margin="0,6,0,0"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#0F172A"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="通道状态" FontSize="13" Foreground="#64748B"/>
                        <Button Grid.Column="1"
                                Content="↻ 刷新"
                                ToolTip="刷新连接状态"
                                Style="{StaticResource HeaderToolButtonStyle}"
                                Click="RefreshButton_Click"/>
                    </Grid>
                    <TextBlock x:Name="ChannelSummaryText"
                               Margin="0,6,0,0"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#0F172A"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="投放控制" FontSize="17" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <TextBlock Text="可先预配置全部选项，再统一开启 NDI"
                               Margin="0,4,0,8"
                               FontSize="12"
                               Foreground="#64748B"/>

                    <Border Style="{StaticResource OptionRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="⏻" FontSize="17" VerticalAlignment="Center" Foreground="#1D4ED8"/>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="启用 NDI 网络流" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBlock Text="控制网络推流总状态" FontSize="11.5" Foreground="#64748B"/>
                            </StackPanel>
                            <primitives:ToggleButton x:Name="MasterToggle" Grid.Column="2" Style="{StaticResource SwitchStyle}" Click="MasterToggle_Click"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource OptionRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="♪" FontSize="17" VerticalAlignment="Center" Foreground="#2563EB"/>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="启用歌词 NDI 输出" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBlock Text="将歌词内容推送到 NDI 网络流" FontSize="11.5" Foreground="#64748B"/>
                            </StackPanel>
                            <primitives:ToggleButton x:Name="LyricsToggle" Grid.Column="2" Style="{StaticResource SwitchStyle}" Click="LyricsToggle_Click"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource OptionRowStyle}" Margin="18,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="◌" FontSize="17" VerticalAlignment="Center" Foreground="#2563EB"/>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="启用歌词透明（NDI）" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBlock Text="仅影响歌词 NDI 输出画面的透明背景" FontSize="11.5" Foreground="#64748B"/>
                                <TextBlock x:Name="LyricsTransparentStateText"
                                           Margin="0,1,0,0"
                                           FontSize="11.5"
                                           FontWeight="SemiBold"
                                           Foreground="#0EA5E9"/>
                            </StackPanel>
                            <primitives:ToggleButton x:Name="TransparentToggle" Grid.Column="2" Style="{StaticResource SwitchStyle}" Click="TransparentToggle_Click"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource OptionRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="CC" FontSize="13.5" FontWeight="Bold" VerticalAlignment="Center" Foreground="#2563EB"/>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="启用字幕 NDI 输出" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBlock Text="将 AI 字幕内容推送到 NDI 网络流" FontSize="11.5" Foreground="#64748B"/>
                            </StackPanel>
                            <primitives:ToggleButton x:Name="CaptionToggle" Grid.Column="2" Style="{StaticResource SwitchStyle}" Click="CaptionToggle_Click"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="水印（实时）" FontSize="17" FontWeight="SemiBold" Foreground="#1E293B"/>

                    <TextBlock Text="位置" Style="{StaticResource WatermarkLabelStyle}"/>
                    <Border BorderBrush="#CBD5E1" BorderThickness="0" CornerRadius="10" Background="Transparent">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="PosLeftTopButton" Content="左上" Style="{StaticResource SegmentPosButtonLeftStyle}" Click="PosLeftTopButton_Click"/>
                            <Button x:Name="PosRightTopButton" Content="右上" Style="{StaticResource SegmentPosButtonMidStyle}" Click="PosRightTopButton_Click"/>
                            <Button x:Name="PosLeftBottomButton" Content="左下" Style="{StaticResource SegmentPosButtonMidStyle}" Click="PosLeftBottomButton_Click"/>
                            <Button x:Name="PosRightBottomButton" Content="右下" Style="{StaticResource SegmentPosButtonMidStyle}" Click="PosRightBottomButton_Click"/>
                            <Button x:Name="PosCenterButton" Content="居中" Style="{StaticResource SegmentPosButtonRightStyle}" Click="PosCenterButton_Click"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="字体" Style="{StaticResource WatermarkLabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="WatermarkFontTextBox"
                                 Style="{StaticResource WatermarkInputStyle}"
                                 IsReadOnly="True"
                                 Padding="10,0,10,0"
                                 MinWidth="150"/>
                        <Button Grid.Column="2"
                                Content="选择字体"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ChooseFontButton_Click"/>
                    </Grid>

                    <TextBlock Text="字号" Style="{StaticResource WatermarkLabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="78"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="WatermarkSizeSlider"
                                Minimum="10"
                                Maximum="220"
                                TickFrequency="2"
                                VerticalAlignment="Center"
                                ValueChanged="WatermarkSizeSlider_ValueChanged"/>
                        <TextBox x:Name="WatermarkSizeTextBox"
                                 Grid.Column="2"
                                 Style="{StaticResource WatermarkInputStyle}"
                                 TextAlignment="Center"
                                 TextChanged="WatermarkSizeTextBox_TextChanged"/>
                    </Grid>

                    <TextBlock Text="透明度" Style="{StaticResource WatermarkLabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="78"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="WatermarkOpacitySlider"
                                Minimum="0"
                                Maximum="100"
                                TickFrequency="1"
                                VerticalAlignment="Center"
                                ValueChanged="WatermarkOpacitySlider_ValueChanged"/>
                        <TextBox x:Name="WatermarkOpacityTextBox"
                                 Grid.Column="2"
                                 Style="{StaticResource WatermarkInputStyle}"
                                 TextAlignment="Center"
                                 TextChanged="WatermarkOpacityTextBox_TextChanged"/>
                    </Grid>

                    <TextBlock x:Name="StatusText"
                               Margin="0,10,0,0"
                               FontSize="12"
                               Foreground="#64748B"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="关闭"
                    Width="96"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
