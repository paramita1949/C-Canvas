<Window x:Class="ImageColorChanger.UI.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="软件更新" 
        Height="420" Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        FontFamily="Microsoft YaHei UI"
        AllowsTransparency="True"
        WindowStyle="None">

    <Window.Resources>
        <Style x:Key="IconPathStyle" TargetType="Path" BasedOn="{StaticResource CommonIconPathStyle}"/>

        <!-- 主按钮样式 -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Background" Value="{StaticResource BrushDialogBrandPrimary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BrushDialogBrandHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#BDBDBD"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 次要按钮样式 -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="#616161"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EEEEEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 外层边框和阴影 -->
    <Border Background="White" CornerRadius="12" BorderBrush="#E0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="20" Opacity="0.15" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 顶部标题栏 -->
            <Border Grid.Row="0" Background="{StaticResource BrushDialogBrandPrimary}" CornerRadius="12,12,0,0" Padding="24,18">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="发现新版本" FontSize="18" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="VersionText" Text="" FontSize="13" Foreground="#E3F2FD" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- 关闭按钮 -->
                    <Button x:Name="CloseButton" 
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Width="28" Height="28"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="16"
                            Cursor="Hand"
                            Click="CloseButton_Click">
                        <Path Data="M18 6L6 18 M6 6L18 18"
                              Style="{StaticResource IconPathStyle}"
                              Margin="0"/>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                                    CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="{StaticResource BrushDialogBrandHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- 中间内容区 -->
            <Grid Grid.Row="1" Margin="24,20,24,20">
                <!-- 下载进度 -->
                <Border x:Name="ProgressPanel" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="ProgressText" Text="正在下载更新..." 
                                   FontSize="14" Foreground="#424242" 
                                   HorizontalAlignment="Center" Margin="0,0,0,14"/>
                        
                        <ProgressBar x:Name="DownloadProgress" 
                                     Height="8" Minimum="0" Maximum="100" Value="0" 
                                     Background="#E0E0E0" Foreground="#4CAF50" 
                                     BorderThickness="0" Margin="0,0,0,12">
                            <ProgressBar.Style>
                                <Style TargetType="ProgressBar">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ProgressBar">
                                                <Grid>
                                                    <Border Background="{TemplateBinding Background}" 
                                                            CornerRadius="4"/>
                                                    <Border x:Name="PART_Track" CornerRadius="4">
                                                        <Border x:Name="PART_Indicator" 
                                                                Background="{TemplateBinding Foreground}"
                                                                HorizontalAlignment="Left"
                                                                CornerRadius="4"/>
                                                    </Border>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ProgressBar.Style>
                        </ProgressBar>
                        
                        <TextBlock x:Name="ProgressDetailText" Text="" 
                                   FontSize="12" Foreground="#757575" 
                                   HorizontalAlignment="Center" Margin="0,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 默认提示信息 -->
                <StackPanel x:Name="InfoPanel" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <TextBlock Text="有新版本可用" 
                               FontSize="15" Foreground="#424242" 
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="建议立即更新以获得最佳体验" 
                               FontSize="12" Foreground="#757575" 
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <Border BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="6" Background="#FCFCFC" Padding="10">
                        <StackPanel>
                            <TextBlock Text="本次更新内容" FontSize="12" FontWeight="SemiBold" Foreground="#616161"/>
                            <TextBox x:Name="ReleaseNotesText"
                                     Margin="0,8,0,0"
                                     Height="120"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="#424242"
                                     Text="修复若干BUG"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- 底部按钮区 -->
            <Border Grid.Row="2" Background="#FAFAFA" CornerRadius="0,0,12,12" 
                    Padding="24,14" BorderBrush="#F0F0F0" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="SkipButton" 
                            Click="SkipButton_Click" 
                            Style="{StaticResource SecondaryButton}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Path Data="M12 5A7 7 0 1 0 12 19A7 7 0 1 0 12 5 M12 8V12H15"
                                  Style="{StaticResource IconPathStyle}"/>
                            <TextBlock Text="稍后提醒" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="UpdateButton" 
                            Click="UpdateButton_Click"
                            Style="{StaticResource PrimaryButton}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Path Data="M12 16V4 M7 9L12 4L17 9 M4 20H20"
                                  Style="{StaticResource IconPathStyle}"/>
                            <TextBlock Text="立即更新" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>



