<Window x:Class="ImageColorChanger.UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="咏慕投影 - 用户中心" 
        Height="450" 
        Width="400"
        MinHeight="520" 
        MinWidth="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        FontFamily="Microsoft YaHei UI"
        Icon="/baodian.ico"
        Loaded="Window_Loaded">
    
    <Window.Resources>
        <Style x:Key="IconPathStyle" TargetType="Path" BasedOn="{StaticResource CommonIconPathStyle}"/>

        <!-- 按钮样式 -->
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="6" Opacity="0.15" Color="#000000"/>
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushDialogBrandPrimary}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushDialogBrandHover}"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.25" Color="{StaticResource ColorDialogBrandPrimary}"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="Selected">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BrushDialogBrandPrimary}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushDialogBrandHover}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="1" BlurRadius="10" Opacity="0.3" Color="{StaticResource ColorDialogBrandPrimary}"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#CCCCCC"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 现代化文本框样式 -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                        Margin="{TemplateBinding Padding}"
                                        VerticalAlignment="Center"
                                        VerticalContentAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushDialogBrandPrimary}"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushDialogBrandPrimary}"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 现代化密码框样式 -->
        <Style x:Key="PasswordBox" TargetType="PasswordBox">
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                        Margin="{TemplateBinding Padding}"
                                        VerticalAlignment="Center"
                                        VerticalContentAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushDialogBrandPrimary}"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushDialogBrandPrimary}"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 主登录按钮样式 -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{StaticResource BrushDialogBrandPrimary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" Color="{StaticResource ColorDialogBrandPrimary}"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BrushDialogBrandHover}"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="3" BlurRadius="12" Opacity="0.4" Color="{StaticResource ColorDialogBrandPrimary}"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BrushDialogBrandPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#BDBDBD"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{StaticResource BrushDialogBrandPrimary}" Padding="20,15">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.2" Color="#000000"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="感谢您使用咏幕投影，登录后解除功能限制" 
                           FontSize="16" 
                           Foreground="#E3F2FD"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,0"/>
                
                <!-- 官方网址链接 -->
                <TextBlock HorizontalAlignment="Center"
                           Margin="0,10,0,0"
                           FontSize="15">
                    <Hyperlink NavigateUri="https://019890311.xyz" 
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="White"
                               TextDecorations="None">
                        <Run Text="官方：019890311.xyz"/>
                    </Hyperlink>
                </TextBlock>
                
                <TextBlock Text="访问官网下载最新版本软件"
                           HorizontalAlignment="Center"
                           Margin="0,3,0,0"
                           FontSize="13"
                           Foreground="#E3F2FD"/>
                
                <!-- 更新提示（在标题栏底部） -->
                <TextBlock x:Name="UpdateNotificationText"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"
                           Visibility="Collapsed">
                    <Run Text=" " FontSize="15"/>
                    <Hyperlink x:Name="UpdateHyperlink"
                               Click="BtnShowUpdate_Click"
                               TextDecorations="None"
                               Foreground="#FFEB3B">
                        <Run Text="发现新版本 " FontSize="14" FontWeight="Bold"/>
                        <Run x:Name="UpdateVersionRun" Text="" FontSize="14" FontWeight="Bold"/>
                        <Run Text="，点击立即更新" FontSize="14" FontWeight="Bold"/>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Background="White">
            <!-- 登录表单（居中显示） -->
            <StackPanel HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        Margin="20">

                <!-- 用户名 -->
                <TextBlock Text="用户名："
                           FontSize="13"
                           Foreground="#333333"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameTextBox" 
                         Style="{StaticResource InputBox}"
                         Width="280"
                         Height="40"
                         TabIndex="1"
                         InputMethod.PreferredImeState="Off"
                         InputMethod.IsInputMethodEnabled="False"
                         Margin="0,0,0,12"/>

                <!-- 密码 -->
                <TextBlock Text="密码："
                           FontSize="13"
                           Foreground="#333333"
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" 
                             Style="{StaticResource PasswordBox}"
                             Width="280"
                             Height="40"
                             TabIndex="2"
                             KeyDown="PasswordBox_KeyDown"
                             Margin="0,0,0,12"/>

                <!-- 状态信息 -->
                <TextBlock x:Name="StatusText" 
                           TextWrapping="Wrap"
                           FontSize="11"
                           Foreground="Red"
                           HorizontalAlignment="Center"
                           Visibility="Collapsed"
                           Margin="0,0,0,10"/>

                <!-- 登录按钮 -->
                <Button x:Name="LoginButton"
                        Style="{StaticResource PrimaryButton}"
                        Width="280"
                        Height="44"
                        Margin="0,0,0,8"
                        Click="LoginButton_Click"
                        TabIndex="3">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Path Data="M12 5A7 7 0 1 0 12 19A7 7 0 1 0 12 5 M12 10V14 M12 8H12.01"
                              Style="{StaticResource IconPathStyle}"/>
                        <TextBlock Text="立即登录" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- 忘记密码 -->
                <TextBlock HorizontalAlignment="Center"
                           Margin="0,0,0,15">
                    <Hyperlink Click="ForgotPassword_Click"
                               TextDecorations="None"
                               Foreground="{StaticResource BrushDialogBrandPrimary}"
                               FontSize="12">
                        <Run Text="忘记密码？"/>
                    </Hyperlink>
                </TextBlock>

                <!-- 注册和付费按钮 -->
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center"
                            Margin="0,0,0,0">
                    <Button x:Name="RegisterButton"
                            Style="{StaticResource TabButtonStyle}"
                            Width="135"
                            Height="40"
                            FontSize="13"
                            Margin="0,0,5,0"
                            Click="RegisterButton_Click"
                            TabIndex="4">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Path Data="M16 4H20V8 M20 4L14 10 M10 6H7A3 3 0 0 0 4 9V17A3 3 0 0 0 7 20H15A3 3 0 0 0 18 17V14"
                                  Style="{StaticResource IconPathStyle}"/>
                            <TextBlock Text="注册账号" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="PaymentButton"
                            Style="{StaticResource TabButtonStyle}"
                            Width="135"
                            Height="40"
                            FontSize="13"
                            Margin="5,0,0,0"
                            Click="PaymentButton_Click"
                            TabIndex="5">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Path Data="M3 7H21V17H3V7Z M3 11H21 M7 15H10"
                                  Style="{StaticResource IconPathStyle}"/>
                            <TextBlock Text="支付" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>



