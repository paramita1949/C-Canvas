<Window x:Class="ImageColorChanger.UI.MainWindow"
        x:Name="MainWindowRoot"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:controls="clr-namespace:ImageColorChanger.UI.Controls"
        Title="咏慕投影"
        Height="1004" Width="1600"
        MinHeight="800" MinWidth="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F5F5F5"
        FontFamily="Microsoft YaHei UI"
        ResizeMode="CanResize"
        Icon="/baodian.ico"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing"
        Activated="Window_Activated"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- 无边框 ContextMenu 样式 -->
        <Style x:Key="NoBorderContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="4"
                                Padding="4">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 紧凑按钮样式 - 倒角方形 -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="contentPresenter"
                                            Margin="{TemplateBinding Padding}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            RecognizesAccessKey="False"
                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- 鼠标悬停效果 - 整个按钮变色 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#1976D2"/>
                                <Setter Property="Foreground" Value="#1976D2"/>
                            </Trigger>
                            <!-- 按下效果 - 整个按钮变深色 -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#BBDEFB"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#0D47A1"/>
                                <Setter Property="Foreground" Value="#0D47A1"/>
                            </Trigger>
                            <!-- 焦点效果 -->
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#64B5F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主要操作按钮样式（如播放、录制） -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1976D2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" 
                                                  BlurRadius="6" 
                                                  Opacity="0.3" 
                                                  Color="#2196F3"/>
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- 悬停效果（但Tag="Locked"时不触发） -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="{x:Null}"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#1E88E5"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="1" BlurRadius="10" Opacity="0.4" Color="#2196F3"/>
                                    </Setter.Value>
                                </Setter>
                            </MultiTrigger>
                            
                            <!-- 按下效果（但Tag="Locked"时不触发） -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsPressed" Value="True"/>
                                    <Condition Property="Tag" Value="{x:Null}"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#1565C0"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.3" Color="#1565C0"/>
                                    </Setter.Value>
                                </Setter>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 警告/录制按钮样式 - 紧凑设计，淡化背景 -->
        <Style x:Key="RecordButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Background" Value="#FFE5E5"/>
            <Setter Property="Foreground" Value="#D32F2F"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- 鼠标悬停效果 - 背景变深 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFCCCC"/>
                                <Setter Property="Foreground" Value="#C62828"/>
                            </Trigger>
                            <!-- 按下效果 -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFB3B3"/>
                                <Setter Property="Foreground" Value="#B71C1C"/>
                            </Trigger>
                            <!-- 焦点效果 -->
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 成功/确认按钮样式 - 紧凑设计，淡化背景 -->
        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Background" Value="#E8F5E9"/>
            <Setter Property="Foreground" Value="#388E3C"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- 鼠标悬停效果 - 背景变深 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C8E6C9"/>
                                <Setter Property="Foreground" Value="#2E7D32"/>
                            </Trigger>
                            <!-- 按下效果 -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#A5D6A7"/>
                                <Setter Property="Foreground" Value="#1B5E20"/>
                            </Trigger>
                            <!-- 焦点效果 -->
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C8E6C9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 危险/删除按钮样式 -->
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Background" Value="#F44336"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#D32F2F"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" 
                                                  BlurRadius="6" 
                                                  Opacity="0.3" 
                                                  Color="#F44336"/>
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E53935"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="1" BlurRadius="10" Opacity="0.4" Color="#F44336"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C62828"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.3" Color="#C62828"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 联系按钮样式 - 橘色 -->
        <Style x:Key="BreathingContactButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Background" Value="#FFE0B2"/>
            <Setter Property="Foreground" Value="#E65100"/>
            <Setter Property="BorderBrush" Value="#FFB74D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <!-- TreeView样式 -->
        <Style x:Key="ProjectTreeStyle" TargetType="TreeView">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- ComboBox样式 - 白色背景 -->
        <Style x:Key="WhiteComboBoxPopup" TargetType="ComboBox">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ComboBoxItem样式 - 白色背景 -->
        <Style x:Key="WhiteComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFF9C4"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFD54F"/>
                                <Setter Property="Foreground" Value="#212121"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#BDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 滚动条滑块（Thumb）紫色样式 -->
        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Background="#CC9C27B0" CornerRadius="6"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 固定颜色的 ScrollBar 样式（防止被动态主题影响）-->
        <Style x:Key="FixedScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Style.Triggers>
                <!-- 垂直滚动条 -->
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="24"/>
                    <Setter Property="MinWidth" Value="24"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                <Grid>
                                    <Border Background="{TemplateBinding Background}" CornerRadius="12"/>
                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumb}" Width="18" Margin="3"/>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <!-- 水平滚动条 -->
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="24"/>
                    <Setter Property="MinHeight" Value="24"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                <Grid>
                                    <Border Background="{TemplateBinding Background}" CornerRadius="12"/>
                                    <Track x:Name="PART_Track" IsDirectionReversed="False">
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumb}" Height="18" Margin="3"/>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="MenuBarRow" Height="Auto"/>
            <!-- 单排按钮菜单栏 -->
            <RowDefinition Height="*"/>
            <!-- 主内容区 -->
            <RowDefinition Height="Auto"/>
            <!-- 媒体播放器控制栏 -->
        </Grid.RowDefinitions>

        <!-- ========== 单排按钮菜单栏 ========== -->
        <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,2" Padding="8,0">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.08" Color="#000000"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：所有按钮在一排 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 基础功能按钮 -->
                    <Button x:Name="BtnImport" Content="文件" Style="{StaticResource MenuButtonStyle}" 
                            ToolTip="导入图片或文件夹" Click="BtnImport_Click"/>

                    <Button x:Name="BtnProjection" Content="🖥 投影" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="开启/关闭投影" Click="BtnProjection_Click"/>

                    <Button x:Name="BtnSync" Content="同步" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="同步所有文件夹" Click="BtnSync_Click"/>

                    <Button x:Name="BtnReset" Content="返回" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="重置视图" Click="BtnReset_Click"/>

                    <Button x:Name="BtnOriginal" Content="原图" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="切换原图模式" Click="BtnOriginal_Click"/>

                    <Button x:Name="BtnZoomReset" Content="缩放" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="重置缩放比例" Click="BtnZoomReset_Click"/>

                    <Button x:Name="BtnColorEffect" Content="变色" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="切换颜色效果" 
                            Click="BtnColorEffect_Click"/>

                    <!-- 分隔线 -->
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0"/>

                    <!-- 关键帧控制按钮 -->
                    <Button x:Name="BtnAddKeyframe" Content="➕ 加帧" Style="{StaticResource SuccessButtonStyle}"
                            ToolTip="在当前位置添加关键帧" Click="BtnAddKeyframe_Click"/>

                    <Button x:Name="BtnClearKeyframes" Content="清帧" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="清除所有关键帧" Click="BtnClearKeyframes_Click"/>

                    <Button x:Name="BtnPrevKeyframe" Content="上帧" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="跳转到上一个关键帧" Click="BtnPrevKeyframe_Click"/>

                    <Button x:Name="BtnNextKeyframe" Content="下帧" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="跳转到下一个关键帧" Click="BtnNextKeyframe_Click"/>

                    <!-- 分隔线 -->
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0"/>
                    <Button x:Name="BtnPlay" Content="播放" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="开始/停止自动播放" Click="BtnPlay_Click"/>

                    <!-- 播放控制按钮 -->
                    <Button x:Name="BtnPlayCount" Content="5次" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="单击循环切换，双击输入数字，滚轮微调 (1-10或∞)" 
                            Click="BtnPlayCount_Click"
                            MouseWheel="BtnPlayCount_MouseWheel"
                            MouseDoubleClick="BtnPlayCount_MouseDoubleClick"/>

                    <Button x:Name="BtnRecord" Content="录制" Style="{StaticResource RecordButtonStyle}"
                            ToolTip="开始/停止时间录制" 
                            Click="BtnRecord_Click"/>
                    <Button x:Name="BtnScript" Content="脚本" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="显示脚本信息" Click="BtnScript_Click"/>

                    <Button x:Name="BtnClearTiming" Content="清时" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="清除时间录制数据" Click="BtnClearTiming_Click"/>

                    <!-- 分隔线 -->
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0"/>
                    <Button x:Name="BtnPauseResume" Content="暂停" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="暂停/继续播放" Click="BtnPauseResume_Click"/>

                    <!-- 倒计时显示 - 无边框，黄色底 -->
                    <Border x:Name="CountdownBorder" Background="#FFFFCC" 
                            BorderThickness="0"
                            CornerRadius="4" Padding="8,2" Margin="3,0" Width="90"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="CountdownText" Text="倒: --" FontSize="16" 
                                   FontWeight="Bold" Foreground="#CC6600" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- 暂停/继续按钮 -->
                    
                    <!-- 登录按钮（使用联系按钮样式） -->
                    <Button x:Name="BtnLogin" Content="登录" Style="{StaticResource BreathingContactButtonStyle}"
                            ToolTip="登录账号解除投影限制" Click="BtnLogin_Click" Margin="15,0,4,0"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ========== 主内容区 ========== -->
        <Grid Grid.Row="1" x:Name="MainContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="NavigationPanelColumn" Width="370"/>
                <!-- 左侧导航栏（圣经模式5列表格需要370宽度） -->
                <ColumnDefinition Width="Auto"/>
                <!-- 分隔条 -->
                <ColumnDefinition Width="*"/>
                <!-- 右侧图片显示区 -->
            </Grid.ColumnDefinitions>

            <!-- 左侧：文件导航栏 -->
            <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- 搜索区域 -->
                        <RowDefinition Height="*"/>
                        <!-- 项目树 -->
                        <RowDefinition Height="Auto"/>
                        <!-- 屏幕选择 -->
                    </Grid.RowDefinitions>

                    <!-- 搜索区域 -->
                    <StackPanel Grid.Row="0" Background="White" Margin="8">
                        <!-- 搜索框 -->
                        <TextBox x:Name="SearchBox"
                                 Height="40"
                                 Margin="0,4,0,8"
                                 Padding="12,8"
                                 materialDesign:HintAssist.Hint="搜索..."
                                 materialDesign:HintAssist.Foreground="#666666"
                                 materialDesign:TextFieldAssist.UnderlineBrush="#2196F3"
                                 Style="{StaticResource MaterialDesignFilledTextBox}"
                                 TextChanged="SearchBox_TextChanged"
                                 MouseDoubleClick="SearchBox_MouseDoubleClick"
                                 FontSize="14"
                                 Foreground="Black"
                                 VerticalContentAlignment="Center"/>

                        <!-- 搜索范围 -->
                        <ComboBox x:Name="SearchScope" 
                                  Style="{StaticResource WhiteComboBoxPopup}"
                                  ItemContainerStyle="{StaticResource WhiteComboBoxItem}">
                            <ComboBoxItem Content="全部" IsSelected="True" Style="{StaticResource WhiteComboBoxItem}"/>
                            <ComboBoxItem Content="当前文件夹" Style="{StaticResource WhiteComboBoxItem}"/>
                        </ComboBox>
                        
                        <!-- 🆕 文件/圣经/幻灯片 切换按钮 -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,8">
                            <Button x:Name="BtnShowFiles" 
                                    Content="文件" 
                                    Width="100" 
                                    Height="32"
                                    FontSize="13"
                                    FontWeight="Medium"
                                    Background="#2196F3"
                                    Foreground="White"
                                    BorderBrush="#1976D2"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    Click="BtnShowFiles_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" 
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="4,0,0,4"
                                                            SnapsToDevicePixels="True">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button x:Name="BtnShowBible" 
                                    Content="圣经" 
                                    Width="100" 
                                    Height="32"
                                    FontSize="13"
                                    FontWeight="Medium"
                                    Background="#FFFFFF"
                                    Foreground="#666666"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="0,1,1,1"
                                    Cursor="Hand"
                                    Click="BtnShowBible_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" 
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="0,0,0,0"
                                                            SnapsToDevicePixels="True">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button x:Name="BtnShowProjects" 
                                    Content="幻灯片" 
                                    Width="100" 
                                    Height="32"
                                    FontSize="13"
                                    FontWeight="Medium"
                                    Background="#FFFFFF"
                                    Foreground="#666666"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="0,1,1,1"
                                    Cursor="Hand"
                                    Click="BtnShowProjects_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" 
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="0,4,4,0"
                                                            SnapsToDevicePixels="True">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- 🆕 圣经导航面板（圣经模式下显示） -->
                    <Grid Grid.Row="1" x:Name="BibleNavigationPanel" Visibility="Collapsed" Background="#2D2D30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>    <!-- 历史记录 -->
                            <RowDefinition Height="Auto"/>    <!-- 历史操作按钮 -->
                            <RowDefinition Height="*"/>       <!-- 经文选择表格 -->
                        </Grid.RowDefinitions>
                        
                        <!-- 历史记录列表（显示1-20号槽位） -->
                        <ScrollViewer x:Name="BibleHistoryScrollViewer" Grid.Row="0" MaxHeight="330" VerticalScrollBarVisibility="Auto" Background="#3C3C3C">
                            <ListBox x:Name="BibleHistoryList" 
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Margin="5"
                                     SelectionChanged="BibleHistoryList_SelectionChanged"
                                     PreviewMouseWheel="BibleHistoryList_PreviewMouseWheel"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#FF5722"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="HistoryItemBorder"
                                                Background="#2D2D30" 
                                                BorderBrush="#4D4D4D" 
                                                BorderThickness="0,0,0,1"
                                                Padding="8,6"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="BibleHistoryItem_Click">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>  <!-- 复选框 -->
                                                    <ColumnDefinition Width="Auto"/>  <!-- 序号 -->
                                                    <ColumnDefinition Width="*"/>     <!-- 内容 -->
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- 复选框 -->
                                                <CheckBox Grid.Column="0" 
                                                          IsChecked="{Binding IsChecked}" 
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,5,0"
                                                          Foreground="White"
                                                          IsHitTestVisible="False"/>
                                                
                                                <!-- 序号 -->
                                                <TextBlock Grid.Column="1" 
                                                           Text="{Binding Index}" 
                                                           Foreground="#FFC107" 
                                                           FontSize="14" 
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,5,0"/>
                                                
                                                <!-- 经文信息 -->
                                                <TextBlock Grid.Column="2" 
                                                           Text="{Binding DisplayText}" 
                                                           Foreground="White" 
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           Margin="0"/>
                                            </Grid>
                                        </Border>
                                        
                                        <!-- DataTemplate Triggers -->
                                        <DataTemplate.Triggers>
                                            <!-- 锁定状态：绿色边框（最高优先级） -->
                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                <Setter TargetName="HistoryItemBorder" Property="BorderBrush" Value="#00FF00"/>
                                                <Setter TargetName="HistoryItemBorder" Property="BorderThickness" Value="3"/>
                                            </DataTrigger>
                                            
                                            <!-- 鼠标悬停：简单的灰色背景高亮（仅在未锁定时生效） -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsLocked}" Value="False"/>
                                                    <Condition Binding="{Binding ElementName=HistoryItemBorder, Path=IsMouseOver}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter TargetName="HistoryItemBorder" Property="Background" Value="#3E3E42"/>
                                            </MultiDataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                        
                        <!-- 历史操作按钮 -->
                        <Border Grid.Row="1" Background="#3C3C3C" BorderBrush="#4D4D4D" BorderThickness="0,0,0,1" Padding="5">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="BtnHistorySelectAll" 
                                        Content="全选" 
                                        Width="80" 
                                        Height="30" 
                                        FontSize="12"
                                        Margin="2"
                                        Style="{StaticResource MenuButtonStyle}"
                                        Click="BtnHistorySelectAll_Click"/>
                                <Button x:Name="BtnHistoryDeselectAll" 
                                        Content="全不选" 
                                        Width="80" 
                                        Height="30" 
                                        FontSize="12"
                                        Margin="2"
                                        Style="{StaticResource MenuButtonStyle}"
                                        Click="BtnHistoryDeselectAll_Click"/>
                                <Button x:Name="BtnHistoryClearSelected" 
                                        Content="清空勾选" 
                                        Width="100" 
                                        Height="30" 
                                        FontSize="12"
                                        Margin="2"
                                        Style="{StaticResource MenuButtonStyle}"
                                        Click="BtnHistoryClearSelected_Click"/>
                                <Button x:Name="BtnBibleSettings" 
                                        Content="⚙ 设置" 
                                        Width="80" 
                                        Height="30" 
                                        FontSize="12"
                                        Margin="2"
                                        Style="{StaticResource MenuButtonStyle}"
                                        Click="BtnBibleSettings_Click"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 经文选择表格 -->
                        <!-- 5列表格布局：分类 | 书卷 | 章 | 起始节 | 结束节 -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>   <!-- 第1列:分类(4个字宽度) -->
                                <ColumnDefinition Width="125"/>  <!-- 第2列:书卷 -->
                                <ColumnDefinition Width="65"/>   <!-- 第3列:章 -->
                                <ColumnDefinition Width="60"/>   <!-- 第4列:起始节 -->
                                <ColumnDefinition Width="60"/>   <!-- 第5列:结束节 -->
                            </Grid.ColumnDefinitions>
                            
                            <!-- 第1列:分类列表 -->
                            <ListBox Grid.Column="0" 
                                     x:Name="BibleCategoryList"
                                     Background="#3C3C3C"
                                     BorderThickness="0,0,1,0"
                                     BorderBrush="#555555"
                                     SelectionChanged="BibleCategory_SelectionChanged"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#FF5722"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4D4D4D"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" 
                                                   TextWrapping="NoWrap" 
                                                   TextTrimming="None"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            
                            <!-- 第2列:书卷列表 -->
                            <ListBox Grid.Column="1" 
                                     x:Name="BibleBookList"
                                     Background="#3C3C3C"
                                     BorderThickness="0,0,1,0"
                                     BorderBrush="#555555"
                                     SelectionChanged="BibleBook_SelectionChanged"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#FF5722"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4D4D4D"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" 
                                                   TextWrapping="NoWrap" 
                                                   TextTrimming="None"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            
                            <!-- 第3列:章列表 -->
                            <ListBox Grid.Column="2" 
                                     x:Name="BibleChapterList"
                                     Background="#3C3C3C"
                                     BorderThickness="0,0,1,0"
                                     BorderBrush="#555555"
                                     SelectionChanged="BibleChapter_SelectionChanged"
                                     MouseDoubleClick="BibleChapter_MouseDoubleClick"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#FF5722"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4D4D4D"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                            
                            <!-- 第4列:起始节 -->
                            <ListBox Grid.Column="3" 
                                     x:Name="BibleStartVerse"
                                     Background="#3C3C3C"
                                     BorderThickness="0,0,1,0"
                                     BorderBrush="#555555"
                                     SelectionChanged="BibleStartVerse_SelectionChanged"
                                     MouseDoubleClick="BibleStartVerse_MouseDoubleClick"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#FF5722"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4D4D4D"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                            
                            <!-- 第5列:结束节 -->
                            <ListBox Grid.Column="4" 
                                     x:Name="BibleEndVerse"
                                     Background="#3C3C3C"
                                     BorderThickness="0"
                                     SelectionChanged="BibleEndVerse_SelectionChanged"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#FF5722"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4D4D4D"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Grid>
                    </Grid>
                    
                    <!-- 项目树（文件模式下显示） -->
                    <TreeView Grid.Row="1" x:Name="ProjectTree" 
                                  Style="{StaticResource ProjectTreeStyle}"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  PreviewKeyDown="Window_PreviewKeyDown"
                                  PreviewMouseLeftButtonUp="ProjectTree_MouseClick"
                                  MouseDoubleClick="ProjectTree_MouseDoubleClick"
                                  PreviewMouseRightButtonDown="ProjectTree_RightClick"
                                  MouseMove="ProjectTree_MouseMove"
                                  AllowDrop="True"
                                  Drop="ProjectTree_ExternalDrop"
                                  DragEnter="ProjectTree_ExternalDragEnter"
                                  DragOver="ProjectTree_ExternalDragOver"
                                  DragLeave="ProjectTree_ExternalDragLeave">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=OneWay}"/>
                                <EventSetter Event="MouseEnter" Handler="TreeViewItem_MouseEnter"/>
                                <EventSetter Event="MouseLeave" Handler="TreeViewItem_MouseLeave"/>
                                <!-- 自定义模板：对于文件节点隐藏展开/折叠按钮 -->
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="0"/>
                                                    <!-- 不显示展开按钮 -->
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition/>
                                                </Grid.RowDefinitions>
                                                
                                                <!-- 展开/折叠按钮（隐藏但保留功能） -->
                                                <ToggleButton x:Name="Expander" 
                                                              Grid.Column="0"
                                                              Width="0"
                                                              Height="0"
                                                              Visibility="Collapsed"
                                                              ClickMode="Press"
                                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"/>
                                                
                                                <!-- 内容区域 -->
                                                <Border x:Name="Bd" Grid.Column="1"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter x:Name="PART_Header"
                                                                      ContentSource="Header"
                                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                </Border>
                                                
                                                <!-- 子项容器 -->
                                                <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Grid.Column="1"/>
                                            </Grid>
                                            
                                            <ControlTemplate.Triggers>
                                                <!-- 未展开时隐藏子项 -->
                                                <Trigger Property="IsExpanded" Value="False">
                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                                <!-- 选中状态 - 黄色高亮 -->
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FFD54F"/>
                                                    <Setter Property="Foreground" Value="#212121"/>
                                                </Trigger>
                                                <!-- 非激活选中状态 - 浅黄色高亮 -->
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="IsSelectionActive" Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Bd" Property="Background" Value="#FFF59D"/>
                                                    <Setter Property="Foreground" Value="#424242"/>
                                                </MultiTrigger>
                                                <!-- 禁用状态 -->
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <!-- 纵向布局：第一行是图标+文件名，第二行是文件夹标签 -->
                                <StackPanel Orientation="Vertical" Margin="0,2">
                                    <!-- 第一行：图标 + 文件/文件夹名称 -->
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="{Binding IconKind}" 
                                                                Foreground="{Binding IconColor}"
                                                                Width="18" 
                                                                Height="18" 
                                                                Margin="0,0,8,0"
                                                                VerticalAlignment="Center">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <!-- 只在文件夹节点显示图标 -->
                                                        <DataTrigger Binding="{Binding Type}" Value="Folder">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <!-- 如果没有IconKind也隐藏 -->
                                                        <DataTrigger Binding="{Binding IconKind}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IconKind}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>

                                        <!-- 文件/文件夹名称 - 支持内联编辑 -->
                                        <Grid>
                                            <!-- 显示模式：TextBlock -->
                                            <TextBlock Text="{Binding Name}" 
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <!-- 默认使用文件字号 -->
                                                        <Setter Property="FontSize" Value="{Binding ElementName=MainWindowRoot, Path=FileFontSize}"/>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <!-- 如果是文件夹，使用文件夹字号 -->
                                                            <DataTrigger Binding="{Binding Type}" Value="Folder">
                                                                <Setter Property="FontSize" Value="{Binding ElementName=MainWindowRoot, Path=FolderFontSize}"/>
                                                            </DataTrigger>
                                                            <!-- 编辑模式时隐藏 -->
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            
                                            <!-- 编辑模式：TextBox (无边框透明背景) -->
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                                     VerticalAlignment="Center"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     Padding="0"
                                                     KeyDown="TreeItemEditBox_KeyDown"
                                                     LostFocus="TreeItemEditBox_LostFocus"
                                                     Loaded="TreeItemEditBox_Loaded"
                                                     IsVisibleChanged="TreeItemEditBox_IsVisibleChanged">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="FontSize" Value="{Binding ElementName=MainWindowRoot, Path=FileFontSize}"/>
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Setter Property="CaretBrush" Value="Black"/>
                                                        <Style.Triggers>
                                                            <!-- 如果是文件夹，使用文件夹字号 -->
                                                            <DataTrigger Binding="{Binding Type}" Value="Folder">
                                                                <Setter Property="FontSize" Value="{Binding ElementName=MainWindowRoot, Path=FolderFontSize}"/>
                                                            </DataTrigger>
                                                            <!-- 编辑模式时显示 -->
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </Grid>
                                    </StackPanel>

                                    <!-- 第二行：文件夹标签（搜索时显示，在名称下方）-->
                                    <Border Background="{Binding FolderColor}" 
                                            CornerRadius="3" 
                                            Padding="6,2" 
                                            Margin="26,2,0,0"
                                            HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowFolderTag}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding FolderName}" 
                                                   FontSize="{Binding ElementName=MainWindowRoot, Path=FolderTagFontSize}" 
                                                   Foreground="White"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                    
                    <!-- 拖拽插入位置指示器 -->
                    <Canvas Grid.Row="1" 
                            x:Name="DragIndicatorCanvas" 
                            IsHitTestVisible="False"
                            Background="Transparent">
                        <Line x:Name="DragIndicatorLine"
                              Stroke="#2196F3"
                              StrokeThickness="2"
                              X1="20" Y1="0" X2="200" Y2="0"
                              Visibility="Collapsed">
                            <Line.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.5" Color="#2196F3"/>
                            </Line.Effect>
                        </Line>
                    </Canvas>
                    
                    <!-- 文件名完整显示提示框 -->
                    <Popup x:Name="FileNameTooltipPopup"
                           AllowsTransparency="True"
                           Placement="Relative"
                           PlacementTarget="{Binding ElementName=ProjectTree}"
                           StaysOpen="True"
                           IsHitTestVisible="False">
                        <Border Background="#E0000000"
                                BorderBrush="#80FFFFFF"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,8"
                                MaxWidth="500">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" 
                                                  BlurRadius="8" 
                                                  Opacity="0.5" 
                                                  Color="#000000"/>
                            </Border.Effect>
                            <TextBlock x:Name="FileNameTooltipText"
                                       Text=""
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Popup>
                    
                    <!-- 屏幕选择器（底部） -->
                    <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="8">
                        <StackPanel>
                            <TextBlock Text="投影屏幕" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="ScreenSelector" Height="32" 
                                      SelectedIndex="0" FontSize="12"
                                      Style="{StaticResource WhiteComboBoxPopup}"
                                      ItemContainerStyle="{StaticResource WhiteComboBoxItem}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 分隔条 -->
            <GridSplitter x:Name="NavigationSplitter" 
                          Grid.Column="1" Width="3" HorizontalAlignment="Stretch" 
                          Background="#E0E0E0" Cursor="SizeWE"
                          DragCompleted="NavigationSplitter_DragCompleted"/>

            <!-- 右侧：图片显示区 -->
            <Grid Grid.Column="2" Background="#000000">
                <!-- 图片显示区域（支持滚动和缩放） -->
                <ScrollViewer x:Name="ImageScrollViewer"
                     HorizontalScrollBarVisibility="Disabled"
                     VerticalScrollBarVisibility="Auto"
                     Background="#000000"
                     BorderThickness="0"
                     PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel"
                     SizeChanged="ImageScrollViewer_SizeChanged"
                     MouseRightButtonUp="ImageScrollViewer_RightClick"
                     PreviewMouseDown="ImageArea_PreviewMouseDown">
                    <ScrollViewer.Resources>
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource FixedScrollBarStyle}"/>
                    </ScrollViewer.Resources>
                    <ScrollViewer.ContextMenu>
                        <ContextMenu x:Name="CanvasContextMenu" Style="{StaticResource NoBorderContextMenuStyle}" Opened="CanvasContextMenu_Opened">
                            <MenuItem Header="滚动速度">
                                <MenuItem Header="0秒 (直接跳转)" Click="SetScrollSpeed_Click" Tag="0" IsCheckable="True"/>
                                <MenuItem Header="0.5秒" Click="SetScrollSpeed_Click" Tag="0.5" IsCheckable="True"/>
                                <MenuItem Header="1.0秒" Click="SetScrollSpeed_Click" Tag="1.0" IsCheckable="True"/>
                                <MenuItem Header="8.0秒" Click="SetScrollSpeed_Click" Tag="8.0" IsCheckable="True" IsChecked="True"/>
                                <MenuItem Header="9.0秒" Click="SetScrollSpeed_Click" Tag="9.0" IsCheckable="True"/>
                                <MenuItem Header="10.0秒" Click="SetScrollSpeed_Click" Tag="10.0" IsCheckable="True"/>
                                <MenuItem Header="11.0秒" Click="SetScrollSpeed_Click" Tag="11.0" IsCheckable="True"/>
                                <MenuItem Header="12.0秒" Click="SetScrollSpeed_Click" Tag="12.0" IsCheckable="True"/>
                                <MenuItem Header="13.0秒" Click="SetScrollSpeed_Click" Tag="13.0" IsCheckable="True"/>
                                <MenuItem Header="14.0秒" Click="SetScrollSpeed_Click" Tag="14.0" IsCheckable="True"/>
                                <MenuItem Header="15.0秒" Click="SetScrollSpeed_Click" Tag="15.0" IsCheckable="True"/>
                            </MenuItem>
                            <MenuItem Header="滚动函数">
                                <MenuItem Header="贝塞尔曲线" Click="SetScrollEasing_Click" Tag="Bezier" IsCheckable="True"/>
                                <MenuItem Header="CSS缓入缓出" Click="SetScrollEasing_Click" Tag="CssEaseInOut" IsCheckable="True"/>
                                <MenuItem Header="超级平滑" Click="SetScrollEasing_Click" Tag="UltraSmooth" IsCheckable="True"/>
                                <MenuItem Header="线性滚动" Click="SetScrollEasing_Click" Tag="Linear" IsCheckable="True" IsChecked="True"/>
                            </MenuItem>
                        </ContextMenu>
                    </ScrollViewer.ContextMenu>
                    <Grid x:Name="ImageContainer" Background="#000000">
                        <Image x:Name="ImageDisplay" 
                               Stretch="Fill"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Top"
                               MouseLeftButtonDown="ImageDisplay_MouseLeftButtonDown"
                               MouseLeftButtonUp="ImageDisplay_MouseLeftButtonUp"
                               MouseMove="ImageDisplay_MouseMove"
                               MouseDown="ImageDisplay_MouseDown"
                               PreviewMouseDown="ImageDisplay_PreviewMouseDown"
                               Cursor="Hand">
                            <Image.LayoutTransform>
                                <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1"/>
                            </Image.LayoutTransform>
                        </Image>

                        <!-- 关键帧预览线容器 - 直接叠加在图片上 -->
                        <Canvas x:Name="KeyframePreviewLinesCanvas"
                                IsHitTestVisible="False"
                                Background="Transparent"
                                Panel.ZIndex="10"/>
                    </Grid>
                </ScrollViewer>
                
                <!-- 视频播放区域（默认隐藏，播放视频时显示） -->
                <Grid x:Name="VideoContainer" Background="#000000" Visibility="Collapsed">
                    <!-- VideoView控件将在代码中动态添加 -->
                    
                    <!-- 媒体文件名称显示（用于纯音频文件，铺满整个区域） -->
                    <Grid x:Name="MediaFileNameBorder" 
                          Background="#000000"
                          Visibility="Collapsed">
                        <!-- 文件名内容，居中显示 -->
                        <StackPanel VerticalAlignment="Center" 
                                    HorizontalAlignment="Center">
                            <TextBlock Text="🎵" 
                                       FontSize="80" 
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,20"
                                       Foreground="White"/>
                            <TextBlock x:Name="MediaFileNameText"
                                       Text="媒体文件"
                                       FontSize="28"
                                       FontWeight="Medium"
                                       Foreground="White"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       MaxWidth="800"
                                       Padding="20,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- 🆕 圣经显示区域（默认隐藏，切换到圣经模式时显示） -->
                <!-- 注意：圣经模式下，左侧ProjectTree会被替换为圣经专用导航 -->
                <Grid x:Name="BibleDisplayContainer" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>      <!-- 经文显示区 -->
                        <RowDefinition Height="Auto"/>   <!-- 底部工具栏 -->
                    </Grid.RowDefinitions>
                    
                    <!-- 圣经经文显示区（标题和内容都可滚动） -->
                    <ScrollViewer Grid.Row="0" x:Name="BibleVerseScrollViewer" 
                                  Background="#000000"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="0"
                                  Focusable="True"
                                  InputMethod.PreferredImeState="Off"
                                  InputMethod.IsInputMethodEnabled="False"
                                  PreviewKeyDown="BibleVerseScrollViewer_PreviewKeyDown"
                                  PreviewMouseDown="BibleVerseScrollViewer_PreviewMouseDown"
                                  PreviewMouseWheel="BibleVerseScrollViewer_PreviewMouseWheel"
                                  ScrollChanged="BibleVerseContentScroller_ScrollChanged">
                        <!-- 🆕 右键菜单：设置滚动节数 -->
                        <ScrollViewer.ContextMenu>
                            <ContextMenu Style="{StaticResource NoBorderContextMenuStyle}">
                                <ContextMenu.Resources>
                                    <!-- 子菜单样式：去掉打勾，选中时文字变红 -->
                                    <Style x:Key="NoCheckMarkMenuItemStyle" TargetType="MenuItem">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="MenuItem">
                                                    <Border x:Name="Border" Background="Transparent" BorderThickness="0" Padding="8,4">
                                                        <ContentPresenter x:Name="Content" ContentSource="Header"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="Content" Property="TextBlock.Foreground" Value="Red"/>
                                                        </Trigger>
                                                        <Trigger Property="IsHighlighted" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="#3A3A3A"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ContextMenu.Resources>
                                <MenuItem Header="滚动节数">
                                    <MenuItem x:Name="MenuScrollCount1" Header="1节" Tag="1" Click="SetScrollVerseCount_Click" IsCheckable="True" IsChecked="True" Style="{StaticResource NoCheckMarkMenuItemStyle}"/>
                                    <MenuItem x:Name="MenuScrollCount2" Header="2节" Tag="2" Click="SetScrollVerseCount_Click" IsCheckable="True" Style="{StaticResource NoCheckMarkMenuItemStyle}"/>
                                    <MenuItem x:Name="MenuScrollCount3" Header="3节" Tag="3" Click="SetScrollVerseCount_Click" IsCheckable="True" Style="{StaticResource NoCheckMarkMenuItemStyle}"/>
                                    <MenuItem x:Name="MenuScrollCount4" Header="4节" Tag="4" Click="SetScrollVerseCount_Click" IsCheckable="True" Style="{StaticResource NoCheckMarkMenuItemStyle}"/>
                                    <MenuItem x:Name="MenuScrollCount5" Header="5节" Tag="5" Click="SetScrollVerseCount_Click" IsCheckable="True" Style="{StaticResource NoCheckMarkMenuItemStyle}"/>
                                    <MenuItem x:Name="MenuScrollCount6" Header="6节" Tag="6" Click="SetScrollVerseCount_Click" IsCheckable="True" Style="{StaticResource NoCheckMarkMenuItemStyle}"/>
                                    <MenuItem x:Name="MenuScrollCount7" Header="7节" Tag="7" Click="SetScrollVerseCount_Click" IsCheckable="True" Style="{StaticResource NoCheckMarkMenuItemStyle}"/>
                                    <MenuItem x:Name="MenuScrollCount8" Header="8节" Tag="8" Click="SetScrollVerseCount_Click" IsCheckable="True" Style="{StaticResource NoCheckMarkMenuItemStyle}"/>
                                    <MenuItem x:Name="MenuScrollCount9" Header="9节" Tag="9" Click="SetScrollVerseCount_Click" IsCheckable="True" Style="{StaticResource NoCheckMarkMenuItemStyle}"/>
                                    <MenuItem x:Name="MenuScrollCount10" Header="10节" Tag="10" Click="SetScrollVerseCount_Click" IsCheckable="True" Style="{StaticResource NoCheckMarkMenuItemStyle}"/>
                                </MenuItem>
                            </ContextMenu>
                        </ScrollViewer.ContextMenu>
                    <StackPanel>
                        <!-- 章节标题（可滚动） -->
                        <Border x:Name="BibleChapterTitleBorder" Background="#000000" Padding="20,15">
                            <TextBlock x:Name="BibleChapterTitle" 
                                       Text="" 
                                       FontSize="32" 
                                       FontWeight="Bold" 
                                       Foreground="#FF5722"/>
                        </Border>
                        
                        <!-- 顶部边距 -->
                        <Border Height="20"/>
                        
                        <!-- 经文列表 -->
                        <ItemsControl x:Name="BibleVerseList" Margin="20,0,20,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="Transparent"
                                            Padding="2"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="BibleVerse_Click"
                                            Tag="{Binding}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#2D2D30"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <!-- 🔧 使用单个 TextBlock，节号和经文在同一行，换行时文字从最左边开始 -->
                                        <!-- 字体大小、行高、颜色等由C#代码动态设置 -->
                                        <TextBlock x:Name="VerseTextBlock"
                                                   FontSize="20" 
                                                   Foreground="White"
                                                   TextWrapping="Wrap"
                                                   IsHitTestVisible="False"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- 底部边距 -->
                        <Border Height="20"/>
                        
                        <!-- 底部扩展空间（支持底部内容向上拉，动态计算高度） -->
                        <Border x:Name="BibleBottomExtension" Height="0" Background="Transparent"/>
                    </StackPanel>
                </ScrollViewer>
                
                <!-- 拼音快速定位提示框（固定在经文区正中央） -->
                <controls:BiblePinyinHintControl x:Name="BiblePinyinHintControl"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Panel.ZIndex="1000"/>
                
                <!-- 🆕 底部工具栏：快速切换译本（鼠标悬停显示）-->
                <!-- 鼠标触发区域（悬浮在经文区底部，不占用布局空间）-->
                <Border Grid.Row="0" 
                        x:Name="BibleVersionTriggerArea"
                        Height="20"
                        VerticalAlignment="Bottom"
                        Background="Transparent"
                        Panel.ZIndex="999"
                        MouseEnter="BibleVersionTrigger_MouseEnter"
                        MouseLeave="BibleVersionTrigger_MouseLeave"/>
                
                <!-- 版本切换工具栏（默认隐藏，悬浮在内容上方）-->
                <Border Grid.Row="0"
                        x:Name="BibleVersionToolbar"
                        Background="#2D2D30" 
                        BorderBrush="#3E3E42" 
                        BorderThickness="0,1,0,0" 
                        Padding="10,8"
                        VerticalAlignment="Bottom"
                        Visibility="Collapsed"
                        Panel.ZIndex="1000"
                        MouseEnter="BibleVersionTrigger_MouseEnter"
                        MouseLeave="BibleVersionTrigger_MouseLeave">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <TextBlock Text="译本:" Foreground="#A0A0A0" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        
                        <!-- 和合本 -->
                        <RadioButton x:Name="RadioBibleVersionSimplified" 
                                     Content="和合本" 
                                     Tag="bible.db"
                                     GroupName="BibleVersion"
                                     IsChecked="True"
                                     Click="BibleVersionRadio_Click"
                                     Foreground="White"
                                     FontSize="12"
                                     VerticalAlignment="Center"
                                     Margin="0,0,15,0">
                            <RadioButton.Style>
                                <Style TargetType="RadioButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="RadioButton">
                                                <Border x:Name="Border" 
                                                        Background="Transparent" 
                                                        BorderBrush="#555555" 
                                                        BorderThickness="1" 
                                                        CornerRadius="3"
                                                        Padding="8,4"
                                                        Cursor="Hand">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#FF5722"/>
                                                        <Setter TargetName="Border" Property="BorderBrush" Value="#FF5722"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#3A3A3A"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsChecked" Value="True"/>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="Border" Property="Background" Value="#E64A19"/>
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </RadioButton.Style>
                        </RadioButton>
                        
                        <!-- 和合本繁体 -->
                        <RadioButton x:Name="RadioBibleVersionTraditional" 
                                     Content="和合本繁体" 
                                     Tag="hehebenfanti.db"
                                     GroupName="BibleVersion"
                                     Click="BibleVersionRadio_Click"
                                     Foreground="White"
                                     FontSize="12"
                                     VerticalAlignment="Center"
                                     Margin="0,0,0,0">
                            <RadioButton.Style>
                                <Style TargetType="RadioButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="RadioButton">
                                                <Border x:Name="Border" 
                                                        Background="Transparent" 
                                                        BorderBrush="#555555" 
                                                        BorderThickness="1" 
                                                        CornerRadius="3"
                                                        Padding="8,4"
                                                        Cursor="Hand">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#FF5722"/>
                                                        <Setter TargetName="Border" Property="BorderBrush" Value="#FF5722"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#3A3A3A"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsChecked" Value="True"/>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="Border" Property="Background" Value="#E64A19"/>
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </RadioButton.Style>
                        </RadioButton>
                    </StackPanel>
                </Border>
            </Grid>

                <!-- 🆕 文本编辑器面板（默认隐藏，类似PPT的布局） -->
                <Grid x:Name="TextEditorPanel" Visibility="Collapsed" Background="#F0F0F0"
                      Focusable="True" PreviewKeyDown="TextEditorPanel_KeyDown"
                      PreviewMouseDown="TextEditorPanel_PreviewMouseDown"
                      Panel.ZIndex="100">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- 工具栏 -->
                        <RowDefinition Height="Auto"/>  <!-- 🆕 圣经经文工具栏 -->
                        <RowDefinition Height="*"/>     <!-- 主内容区 -->
                    </Grid.RowDefinitions>

                    <!-- 工具栏 -->
                    <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E0E0E0" 
                            BorderThickness="0,0,0,2" Padding="8">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.08" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <!-- 文本和背景操作 -->
                            <Button x:Name="BtnAddText" Content="➕ 文本" 
                                    Style="{StaticResource SuccessButtonStyle}"
                                    ToolTip="添加文本框" Click="BtnAddText_Click"/>
                            
                            <!-- 导入按钮 -->
                            <Button x:Name="BtnBackgroundImage" Content="📥 导入"
                                    Style="{StaticResource MenuButtonStyle}"
                                    ToolTip="导入图片为幻灯片"
                                    Click="BtnBackgroundImage_Click"/>
                            
                            <!-- 背景颜色按钮 -->
                            <Button x:Name="BtnBackgroundColor" Content="🎨 背景色" 
                                    Style="{StaticResource MenuButtonStyle}"
                                    ToolTip="选择背景颜色"
                                    Click="BtnBackgroundColor_Click"/>
                            
                            <!-- 分割按钮 -->
                            <Button x:Name="BtnSplitView" Content="🖼 分割" 
                                    Style="{StaticResource MenuButtonStyle}"
                                    ToolTip="画面分割设置"
                                    Click="BtnSplitView_Click"/>
                            
                            <!-- 原图模式切换按钮 -->
                            <Button x:Name="BtnSplitStretchMode" Content="📐 适中" 
                                    Style="{StaticResource MenuButtonStyle}"
                                    ToolTip="切换图片拉伸模式（适中/拉伸）"
                                    Click="BtnSplitStretchMode_Click"/>

                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0"/>

                            <!-- 字体设置 -->
                            <ComboBox x:Name="FontFamilySelector" Width="150" Height="32"
                                      SelectedIndex="0"
                                      SelectionChanged="FontFamily_Changed"
                                      MaxDropDownHeight="400"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      GotFocus="FontFamilySelector_GotFocus"
                                      VerticalContentAlignment="Center"
                                      HorizontalContentAlignment="Left"
                                      Padding="8,0,0,0"
                                      FontSize="13"
                                      Style="{StaticResource WhiteComboBoxPopup}"
                                      ItemContainerStyle="{StaticResource WhiteComboBoxItem}">
                                <ComboBox.Resources>
                                    <!-- 深灰色滚动条样式 -->
                                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{x:Null}">
                                        <Setter Property="Background" Value="#E0E0E0"/>
                                        <Setter Property="Width" Value="12"/>
                                        <Setter Property="MinWidth" Value="12"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ScrollBar}">
                                                    <Grid>
                                                        <Border Background="#E0E0E0" CornerRadius="6"/>
                                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                            <Track.Thumb>
                                                                <Thumb>
                                                                    <Thumb.Style>
                                                                        <Style TargetType="Thumb">
                                                                            <Setter Property="Background" Value="#5C5C5C"/>
                                                                            <Setter Property="Template">
                                                                                <Setter.Value>
                                                                                    <ControlTemplate TargetType="Thumb">
                                                                                        <Border Background="{TemplateBinding Background}"
                                                                                                CornerRadius="6"
                                                                                                Margin="2"/>
                                                                                    </ControlTemplate>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                            <Style.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter Property="Background" Value="#7C7C7C"/>
                                                                                </Trigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Thumb.Style>
                                                                </Thumb>
                                                            </Track.Thumb>
                                                        </Track>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ComboBox.Resources>
                                <!-- 字体将在代码中动态加载 -->
                            </ComboBox>

                            <!-- 字号选择框 -->
                            <ComboBox x:Name="FontSizeSelector" Width="80" Height="32"
                                      SelectedIndex="5"
                                      SelectionChanged="FontSize_Changed"
                                      MouseWheel="FontSizeSelector_MouseWheel"
                                      IsEditable="True"
                                      VerticalContentAlignment="Center"
                                      HorizontalContentAlignment="Center"
                                      FontSize="13"
                                      FontWeight="Bold"
                                      Style="{StaticResource WhiteComboBoxPopup}"
                                      ItemContainerStyle="{StaticResource WhiteComboBoxItem}">
                                <ComboBox.Resources>
                                    <!-- 深灰色滚动条样式 -->
                                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{x:Null}">
                                        <Setter Property="Background" Value="#E0E0E0"/>
                                        <Setter Property="Width" Value="12"/>
                                        <Setter Property="MinWidth" Value="12"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ScrollBar}">
                                                    <Grid>
                                                        <Border Background="#E0E0E0" CornerRadius="6"/>
                                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                            <Track.Thumb>
                                                                <Thumb>
                                                                    <Thumb.Style>
                                                                        <Style TargetType="Thumb">
                                                                            <Setter Property="Background" Value="#5C5C5C"/>
                                                                            <Setter Property="Template">
                                                                                <Setter.Value>
                                                                                    <ControlTemplate TargetType="Thumb">
                                                                                        <Border Background="{TemplateBinding Background}"
                                                                                                CornerRadius="6"
                                                                                                Margin="2"/>
                                                                                    </ControlTemplate>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                            <Style.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter Property="Background" Value="#7C7C7C"/>
                                                                                </Trigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Thumb.Style>
                                                                </Thumb>
                                                            </Track.Thumb>
                                                        </Track>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ComboBox.Resources>
                                <ComboBoxItem Content="10"/>
                                <ComboBoxItem Content="12"/>
                                <ComboBoxItem Content="14"/>
                                <ComboBoxItem Content="16"/>
                                <ComboBoxItem Content="18"/>
                                <ComboBoxItem Content="20"/>
                                <ComboBoxItem Content="24"/>
                                <ComboBoxItem Content="28"/>
                                <ComboBoxItem Content="30"/>
                                <ComboBoxItem Content="32"/>
                                <ComboBoxItem Content="36"/>
                                <ComboBoxItem Content="40"/>
                                <ComboBoxItem Content="48"/>
                                <ComboBoxItem Content="56"/>
                                <ComboBoxItem Content="64"/>
                                <ComboBoxItem Content="72"/>
                                <ComboBoxItem Content="80"/>
                                <ComboBoxItem Content="88"/>
                                <ComboBoxItem Content="96"/>
                                <ComboBoxItem Content="104"/>
                                <ComboBoxItem Content="112"/>
                                <ComboBoxItem Content="120"/>
                            </ComboBox>
                            
                            <!-- 字号增大按钮 A+ -->
                            <Button x:Name="BtnIncreaseFontSize" Content="A+" 
                                    Width="32" Height="32"
                                    FontWeight="Bold"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="BtnIncreaseFontSize_Click"
                                    ToolTip="增大字号"/>
                            
                            <!-- 字号减小按钮 A- -->
                            <Button x:Name="BtnDecreaseFontSize" Content="A-" 
                                    Width="32" Height="32"
                                    FontWeight="Bold"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="BtnDecreaseFontSize_Click"
                                    ToolTip="减小字号"/>

                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0"/>

                            <!-- 加粗按钮 -->
                            <Button x:Name="BtnBold" Content="B"
                                    Width="40" Height="40"
                                    FontFamily="Segoe UI"
                                    FontWeight="Bold" FontSize="20"
                                    Margin="8,0,0,0"
                                    Padding="0"
                                    Style="{StaticResource MenuButtonStyle}"
                                    ToolTip="加粗 (B)" Click="BtnBold_Click"/>



                            <!-- 文字颜色按钮 -->
                            <Button x:Name="BtnTextColor" Content="A"
                                    Width="40" Height="40"
                                    FontFamily="Segoe UI"
                                    FontWeight="Bold" FontSize="20"
                                    Margin="4,0,0,0"
                                    Padding="0"
                                    Style="{StaticResource MenuButtonStyle}"
                                    ToolTip="文字颜色 (A)" Click="BtnTextColor_Click"/>

                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0"/>

                            <!-- 保存和投影 -->
                            <Button x:Name="BtnSaveTextProject" Content="💾 保存"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Foreground="#333333"
                                    ToolTip="保存项目" Click="BtnSaveTextProject_Click"/>
                            
                            <Button x:Name="BtnLockProjection" Content="🔓 锁定投影"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    ToolTip="锁定投影：开启后切换幻灯片不会自动更新投影" Click="BtnLockProjection_Click"/>
                            
                            <Button x:Name="BtnUpdateProjection" Content="🔄 更新投影"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    ToolTip="立即更新投影内容" Click="BtnUpdateProjection_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- 🆕 圣经导航面板（在幻灯片编辑模式下显示，与主界面共享同一个面板） -->
                    <!-- 通过代码动态移动 BibleNavigationPanel 到这里 -->

                    <!-- 主内容区：左侧幻灯片列表 + 右侧编辑区 -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190"/>  <!-- 左侧幻灯片列表 -->
                            <ColumnDefinition Width="Auto"/> <!-- 分隔线 -->
                            <ColumnDefinition Width="*"/>    <!-- 右侧编辑区 -->
                        </Grid.ColumnDefinitions>

                        <!-- 左侧：幻灯片列表面板 -->
                        <Border x:Name="SlidePanelBorder" Grid.Column="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>  <!-- 标题栏 -->
                                    <RowDefinition Height="*"/>     <!-- 幻灯片列表 -->
                                </Grid.RowDefinitions>

                                <!-- 标题栏 - 退出编辑按钮 -->
                                <Border Grid.Row="0" Background="#FAFAFA" Padding="8" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                    <Button x:Name="BtnCloseTextEditorInPanel" 
                                            Content="❌ 退出" 
                                            Height="36"
                                            Width="80"
                                            FontSize="14" 
                                            FontWeight="SemiBold"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="#D32F2F"
                                            HorizontalAlignment="Left"
                                            HorizontalContentAlignment="Left"
                                            Cursor="Hand"
                                            Click="BtnCloseTextEditor_Click"
                                            ToolTip="退出文本编辑器，返回图片/视频浏览">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    Padding="4,0">
                                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Foreground" Value="#F44336"/>
                                                                    <Setter Property="FontSize" Value="15"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Border>

                                <!-- 幻灯片列表 -->
                                <ScrollViewer x:Name="SlideScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                              PreviewMouseWheel="SlideScrollViewer_PreviewMouseWheel">
                                    <ScrollViewer.Resources>
                                        <!-- 深灰色滚动条样式（覆盖全局样式） -->
                                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{x:Null}">
                                            <Setter Property="Background" Value="#2C2C2C"/>
                                            <Setter Property="Foreground" Value="#5C5C5C"/>
                                            <Setter Property="Width" Value="12"/>
                                            <Setter Property="MinWidth" Value="12"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                                                        <Grid>
                                                            <Border Background="#2C2C2C" CornerRadius="6"/>
                                                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                                <Track.Thumb>
                                                                    <Thumb>
                                                                        <Thumb.Style>
                                                                            <Style TargetType="Thumb">
                                                                                <Setter Property="Background" Value="#5C5C5C"/>
                                                                                <Setter Property="Template">
                                                                                    <Setter.Value>
                                                                                        <ControlTemplate TargetType="Thumb">
                                                                                            <Border Background="{TemplateBinding Background}"
                                                                                                    CornerRadius="6"
                                                                                                    Margin="2"/>
                                                                                        </ControlTemplate>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                                <Style.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter Property="Background" Value="#7C7C7C"/>
                                                                                    </Trigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Thumb.Style>
                                                                    </Thumb>
                                                                </Track.Thumb>
                                                            </Track>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ScrollViewer.Resources>
                                    <ListBox x:Name="SlideListBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="0"
                                             SelectionMode="Single"
                                             AllowDrop="True"
                                             SelectionChanged="SlideListBox_SelectionChanged"
                                             MouseRightButtonUp="SlideListBox_RightClick"
                                             PreviewMouseLeftButtonDown="SlideListBox_PreviewMouseLeftButtonDown"
                                             PreviewMouseMove="SlideListBox_PreviewMouseMove"
                                             Drop="SlideListBox_Drop"
                                             DragOver="SlideListBox_DragOver"
                                             KeyDown="SlideListBox_KeyDown">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Margin" Value="0,0,0,8"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderBrush" Value="#2196F3"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <!-- 缩略图预览区域 -->
                                                <Border Background="White" 
                                                        BorderBrush="#CCCCCC" 
                                                        BorderThickness="1"
                                                        Width="180"
                                                        Height="120"
                                                        HorizontalAlignment="Center">
                                                    <Grid>
                                                        <!-- 背景色 -->
                                                        <Rectangle Fill="{Binding BackgroundColor, TargetNullValue=#FFFFFF}"/>
                                                        
                                                        <!-- 缩略图图片（如果有） -->
                                                        <Image Source="{Binding ThumbnailImage}" 
                                                               Stretch="Uniform"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"/>
                                                        
                                                        <!-- 占位符（如果没有缩略图） - 已隐藏 -->
                                                        <!--
                                                        <StackPanel HorizontalAlignment="Center" 
                                                                   VerticalAlignment="Center">
                                                            <StackPanel.Style>
                                                                <Style TargetType="StackPanel">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ThumbnailImage}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>
                                                            <TextBlock Text="📝" 
                                                                       FontSize="32" 
                                                                       HorizontalAlignment="Center" 
                                                                       Foreground="#666666"
                                                                       Margin="0,0,0,4"/>
                                                            <TextBlock Text="{Binding DisplayInfo}" 
                                                                       FontSize="11" 
                                                                       HorizontalAlignment="Center" 
                                                                       Foreground="#999999"/>
                                                        </StackPanel>
                                                        -->
                                                        
                                                        <!-- 序号标签（左下角，贴在内容区域内） -->
                                                        <Border Background="#FF6600" 
                                                                CornerRadius="0,4,0,0"
                                                                Padding="6,2"
                                                                Margin="1,0,0,1"
                                                                HorizontalAlignment="Left" 
                                                                VerticalAlignment="Bottom">
                                                            <TextBlock Text="{Binding SortOrder}" 
                                                                       FontSize="12" 
                                                                       FontWeight="Bold"
                                                                       Foreground="White"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- 分隔线（可拖动调整大小） -->
                        <GridSplitter Grid.Column="1" 
                                      Width="5" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Stretch" 
                                      Background="Transparent"
                                      ShowsPreview="False"/>

                        <!-- 右侧：编辑画布区域 -->
                        <Grid Grid.Column="2" Background="#F5F5F5">
                            <Border Background="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                                <Viewbox Stretch="Uniform" StretchDirection="DownOnly" ClipToBounds="True">
                                    <Grid x:Name="EditorCanvasContainer" Width="1080" Height="700" Background="White">
                            <Canvas x:Name="EditorCanvas"
                                    Width="1080" Height="700"
                                    Background="White"
                                    MouseLeftButtonDown="EditorCanvas_MouseDown"
                                    KeyDown="EditorCanvas_KeyDown"
                                    Focusable="True"
                                    AllowDrop="True"
                                    ClipToBounds="True">

                                <!-- 背景图通过 Canvas.Background 的 ImageBrush 设置，不再使用 Image 控件 -->
                                <!-- 文本框将动态添加到这里 -->
                            </Canvas>
                            
                            <!-- 🆕 圣经经文工具栏（悬浮在画布上方中央） -->
                            <Popup x:Name="BibleToolbar"
                                   AllowsTransparency="True"
                                   StaysOpen="True"
                                   Placement="Center"
                                   PlacementTarget="{Binding ElementName=EditorCanvas}"
                                   HorizontalOffset="0"
                                   VerticalOffset="-375"
                                   IsOpen="False">
                                <Border Background="#F0FFFFFF"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        Padding="4">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.15" Color="#000000"/>
                                    </Border.Effect>
                                    <StackPanel Orientation="Horizontal">
                                        <!-- 经文样式设置按钮 -->
                                        <Button x:Name="BtnBibleStyleIcon"
                                                Width="28" Height="28"
                                                Margin="2"
                                                Background="Transparent"
                                                Foreground="#2196F3"
                                                BorderThickness="0"
                                                ToolTip="经文样式设置"
                                                Click="BtnBibleInsertStyleSettings_Click"
                                                Cursor="Hand">
                                            <TextBlock Text="✝️" FontSize="14"/>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="border"
                                                                        Background="{TemplateBinding Background}"
                                                                        CornerRadius="14">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#BBDEFB"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- 分隔线 -->
                                        <Rectangle Width="1" Height="20" Fill="#D0D0D0" Margin="4,0"/>

                                        <!-- 边框按钮 -->
                                        <Button x:Name="BtnFloatingBorder"
                                                Width="48" Height="28"
                                                Margin="2"
                                                Background="Transparent"
                                                Foreground="#2196F3"
                                                BorderThickness="0"
                                                ToolTip="边框"
                                                Click="BtnFloatingBorder_Click"
                                                Cursor="Hand">
                                            <TextBlock Text="边框" FontSize="16" FontWeight="Bold"/>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="border"
                                                                        Background="{TemplateBinding Background}"
                                                                        CornerRadius="14">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#BBDEFB"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- 背景按钮 -->
                                        <Button x:Name="BtnFloatingBackground"
                                                Width="48" Height="28"
                                                Margin="2"
                                                Background="Transparent"
                                                Foreground="#2196F3"
                                                BorderThickness="0"
                                                ToolTip="背景"
                                                Click="BtnFloatingBackground_Click"
                                                Cursor="Hand">
                                            <TextBlock Text="文字" FontSize="16" FontWeight="Bold"/>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="border"
                                                                        Background="{TemplateBinding Background}"
                                                                        CornerRadius="14">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#BBDEFB"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- 阴影按钮 -->
                                        <Button x:Name="BtnFloatingShadow"
                                                Width="48" Height="28"
                                                Margin="2"
                                                Background="Transparent"
                                                Foreground="#2196F3"
                                                BorderThickness="0"
                                                ToolTip="阴影"
                                                Click="BtnFloatingShadow_Click"
                                                Cursor="Hand">
                                            <TextBlock Text="阴影" FontSize="16" FontWeight="Bold"/>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="border"
                                                                        Background="{TemplateBinding Background}"
                                                                        CornerRadius="14">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#BBDEFB"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- 间距按钮 -->
                                        <Button x:Name="BtnFloatingSpacing"
                                                Width="48" Height="28"
                                                Margin="2"
                                                Background="Transparent"
                                                Foreground="#2196F3"
                                                BorderThickness="0"
                                                ToolTip="间距"
                                                Click="BtnFloatingSpacing_Click"
                                                Cursor="Hand">
                                            <TextBlock Text="间距" FontSize="16" FontWeight="Bold"/>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="border"
                                                                        Background="{TemplateBinding Background}"
                                                                        CornerRadius="14">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#BBDEFB"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- 动画按钮 -->
                                        <Button x:Name="BtnFloatingAnimation"
                                                Width="48" Height="28"
                                                Margin="2"
                                                Background="Transparent"
                                                Foreground="#2196F3"
                                                BorderThickness="0"
                                                ToolTip="动画"
                                                Click="BtnFloatingAnimation_Click"
                                                Cursor="Hand">
                                            <TextBlock Text="动画" FontSize="16" FontWeight="Bold"/>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="border"
                                                                        Background="{TemplateBinding Background}"
                                                                        CornerRadius="14">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#BBDEFB"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- 分隔线 -->
                                        <Rectangle Width="1" Height="20" Fill="#D0D0D0" Margin="4,0"/>

                                        <!-- 斜体按钮 -->
                                        <Button x:Name="BtnFloatingItalic" Content="/"
                                                Width="28" Height="28" Margin="2"
                                                Background="Transparent" Foreground="#2196F3"
                                                BorderThickness="0" FontSize="16" FontWeight="Bold"
                                                ToolTip="斜体" Cursor="Hand"
                                                Click="BtnFloatingItalic_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="14">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#BBDEFB"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- 下划线按钮 -->
                                        <Button x:Name="BtnFloatingUnderline" Content="U"
                                                Width="28" Height="28" Margin="2"
                                                Background="Transparent" Foreground="#2196F3"
                                                BorderThickness="0" FontSize="16" FontWeight="Bold"
                                                ToolTip="下划线" Cursor="Hand"
                                                Click="BtnUnderline_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="14">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#BBDEFB"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- 左对齐按钮 -->
                                        <Button x:Name="BtnFloatingAlignLeft"
                                                Width="28" Height="28" Margin="2"
                                                Background="Transparent" Foreground="#2196F3"
                                                BorderThickness="0"
                                                ToolTip="左对齐" Cursor="Hand"
                                                Click="BtnAlignLeft_Click">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Width="16">
                                                <Rectangle Fill="#2196F3" Height="2" Margin="0,1" HorizontalAlignment="Left" Width="16"/>
                                                <Rectangle Fill="#2196F3" Height="2" Margin="0,1" HorizontalAlignment="Left" Width="12"/>
                                                <Rectangle Fill="#2196F3" Height="2" Margin="0,1" HorizontalAlignment="Left" Width="14"/>
                                            </StackPanel>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="14">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#BBDEFB"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- 居中对齐按钮 -->
                                        <Button x:Name="BtnFloatingAlignCenter"
                                                Width="28" Height="28" Margin="2"
                                                Background="Transparent" Foreground="#2196F3"
                                                BorderThickness="0"
                                                ToolTip="居中" Cursor="Hand"
                                                Click="BtnAlignCenter_Click">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="16">
                                                <Rectangle Fill="#2196F3" Height="2" Margin="0,1" HorizontalAlignment="Center" Width="16"/>
                                                <Rectangle Fill="#2196F3" Height="2" Margin="0,1" HorizontalAlignment="Center" Width="10"/>
                                                <Rectangle Fill="#2196F3" Height="2" Margin="0,1" HorizontalAlignment="Center" Width="13"/>
                                            </StackPanel>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="14">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#BBDEFB"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- 右对齐按钮 -->
                                        <Button x:Name="BtnFloatingAlignRight"
                                                Width="28" Height="28" Margin="2"
                                                Background="Transparent" Foreground="#2196F3"
                                                BorderThickness="0"
                                                ToolTip="右对齐" Cursor="Hand"
                                                Click="BtnAlignRight_Click">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right" Width="16">
                                                <Rectangle Fill="#2196F3" Height="2" Margin="0,1" HorizontalAlignment="Right" Width="16"/>
                                                <Rectangle Fill="#2196F3" Height="2" Margin="0,1" HorizontalAlignment="Right" Width="12"/>
                                                <Rectangle Fill="#2196F3" Height="2" Margin="0,1" HorizontalAlignment="Right" Width="14"/>
                                            </StackPanel>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="14">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#BBDEFB"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Popup>

                            <!-- 🆕 边框设置侧边面板 -->
                            <Popup x:Name="BorderSettingsPopup"
                                   AllowsTransparency="True"
                                   StaysOpen="True"
                                   Placement="Left"
                                   PlacementTarget="{Binding ElementName=SlidePanelBorder}"
                                   HorizontalOffset="-160"
                                   VerticalOffset="0"
                                   IsOpen="False">
                                <Border Background="#2D2D30"
                                        BorderBrush="#3F3F46"
                                        BorderThickness="1,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.3" Color="#000000"/>
                                    </Border.Effect>
                                    <controls:BorderSettingsPanel x:Name="BorderSettingsPanel"/>
                                </Border>
                            </Popup>

                            <!-- 🆕 背景设置侧边面板 -->
                            <Popup x:Name="BackgroundSettingsPopup"
                                   AllowsTransparency="True"
                                   StaysOpen="True"
                                   Placement="Left"
                                   PlacementTarget="{Binding ElementName=SlidePanelBorder}"
                                   HorizontalOffset="-160"
                                   VerticalOffset="0"
                                   IsOpen="False">
                                <Border Background="White"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.3" Color="#000000"/>
                                    </Border.Effect>
                                    <controls:BackgroundSettingsPanel x:Name="BackgroundSettingsPanel"/>
                                </Border>
                            </Popup>

                            <!-- 🆕 文本颜色设置侧边面板 -->
                            <Popup x:Name="TextColorSettingsPopup"
                                   AllowsTransparency="True"
                                   StaysOpen="True"
                                   Placement="Left"
                                   PlacementTarget="{Binding ElementName=SlidePanelBorder}"
                                   HorizontalOffset="-160"
                                   VerticalOffset="0"
                                   IsOpen="False">
                                <Border Background="White"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.3" Color="#000000"/>
                                    </Border.Effect>
                                    <controls:TextColorSettingsPanel x:Name="TextColorSettingsPanel"/>
                                </Border>
                            </Popup>

                            <!-- 🆕 阴影设置侧边面板 -->
                            <Popup x:Name="ShadowSettingsPopup"
                                   AllowsTransparency="True"
                                   StaysOpen="True"
                                   Placement="Left"
                                   PlacementTarget="{Binding ElementName=SlidePanelBorder}"
                                   HorizontalOffset="-160"
                                   VerticalOffset="0"
                                   IsOpen="False">
                                <Border Background="White"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.3" Color="#000000"/>
                                    </Border.Effect>
                                    <controls:ShadowSettingsPanel x:Name="ShadowSettingsPanel"/>
                                </Border>
                            </Popup>

                            <!-- 🆕 间距设置侧边面板 -->
                            <Popup x:Name="SpacingSettingsPopup"
                                   AllowsTransparency="True"
                                   StaysOpen="True"
                                   Placement="Left"
                                   PlacementTarget="{Binding ElementName=SlidePanelBorder}"
                                   HorizontalOffset="-160"
                                   VerticalOffset="0"
                                   IsOpen="False">
                                <Border Background="#2D2D30"
                                        BorderBrush="#3F3F46"
                                        BorderThickness="1,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.3" Color="#000000"/>
                                    </Border.Effect>
                                    <controls:SpacingSettingsPanel x:Name="SpacingSettingsPanel"/>
                                </Border>
                            </Popup>

                            <!-- 🆕 动画设置侧边面板 -->
                            <Popup x:Name="AnimationSettingsPopup"
                                   AllowsTransparency="True"
                                   StaysOpen="True"
                                   Placement="Left"
                                   PlacementTarget="{Binding ElementName=SlidePanelBorder}"
                                   HorizontalOffset="-220"
                                   VerticalOffset="0"
                                   IsOpen="False">
                                <Border Background="#2D2D30"
                                        BorderBrush="#3F3F46"
                                        BorderThickness="1,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.3" Color="#000000"/>
                                    </Border.Effect>
                                    <controls:AnimationSettingsPanel x:Name="AnimationSettingsPanel"/>
                                </Border>
                            </Popup>

                            <!-- 辅助线（叠加在Canvas上方）-->
                            <Canvas x:Name="AlignmentGuidesCanvas" 
                                    Width="1080" Height="700"
                                    IsHitTestVisible="False"
                                    Panel.ZIndex="1000">
                                <!-- 垂直中心线 -->
                                <Line x:Name="VerticalCenterLine" 
                                      X1="540" Y1="0" X2="540" Y2="700"
                                      Stroke="#FF2196F3" StrokeThickness="2" 
                                      StrokeDashArray="8,4"
                                      Visibility="Collapsed">
                                    <Line.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.5" Color="#2196F3"/>
                                    </Line.Effect>
                                </Line>
                                
                                <!-- 水平中心线 -->
                                <Line x:Name="HorizontalCenterLine" 
                                      X1="0" Y1="350" X2="1080" Y2="350"
                                      Stroke="#FF2196F3" StrokeThickness="2" 
                                      StrokeDashArray="8,4"
                                      Visibility="Collapsed">
                                    <Line.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.5" Color="#2196F3"/>
                                    </Line.Effect>
                                </Line>
                                
                                <!-- 垂直对齐线（与其他文本框对齐）-->
                                <Line x:Name="VerticalAlignLine" 
                                      X1="0" Y1="0" X2="0" Y2="700"
                                      Stroke="#FFFF9800" StrokeThickness="1.5" 
                                      StrokeDashArray="4,2"
                                      Visibility="Collapsed"/>
                                
                                <!-- 水平对齐线（与其他文本框对齐）-->
                                <Line x:Name="HorizontalAlignLine" 
                                      X1="0" Y1="0" X2="1080" Y2="0"
                                      Stroke="#FFFF9800" StrokeThickness="1.5" 
                                      StrokeDashArray="4,2"
                                      Visibility="Collapsed"/>
                            </Canvas>
                        </Grid>
                    </Viewbox>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- 🆕 歌词编辑器面板（极简黑色版） -->
                <Grid x:Name="LyricsEditorPanel" 
                      Visibility="Collapsed" 
                      Background="#000000" 
                      Panel.ZIndex="100">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- 工具栏 -->
                        <RowDefinition Height="*"/>     <!-- 编辑区域 -->
                    </Grid.RowDefinitions>

                    <!-- 极简工具栏 -->
                    <Border Grid.Row="0" 
                            Background="#1A1A1A" 
                            BorderBrush="#333333" 
                            BorderThickness="0,0,0,1" 
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Left">
                            
                            <!-- 退出按钮 -->
                            <Button x:Name="BtnCloseLyricsEditor" 
                                    Content="❌ 退出"
                                    Width="100" Height="40"
                                    Margin="0,0,12,0"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="BtnCloseLyricsEditor_Click"
                                    ToolTip="退出歌词模式"/>

                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" 
                                       Margin="0,0,12,0"/>

                            <!-- 字号显示和滚轮调整 -->
                            <Border Background="#2D2D2D" 
                                    BorderBrush="#555555" 
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12,6"
                                    Margin="0,0,8,0"
                                    ToolTip="鼠标滚轮调整字号">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="字号:" 
                                               Foreground="#AAAAAA"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"
                                               FontSize="14"/>
                                    <TextBlock x:Name="LyricsFontSizeDisplay" 
                                               Text="48" 
                                               Width="40" 
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#FFFFFF"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               MouseWheel="LyricsFontSizeDisplay_MouseWheel"/>
                                </StackPanel>
                            </Border>

                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" 
                                       Margin="0,0,12,0"/>

                            <!-- 文字颜色 -->
                            <Button x:Name="BtnLyricsTextColor" 
                                    Content="🎨 颜色"
                                    Width="110" Height="40"
                                    Margin="0,0,12,0"
                                    FontSize="16"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="BtnLyricsTextColor_Click"
                                    ToolTip="选择文字颜色"/>

                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" 
                                       Margin="0,0,12,0"/>

                            <!-- 对齐方式 - 重新设计的按钮 -->
                            <Button x:Name="BtnLyricsAlignLeft" 
                                    Width="56" Height="40"
                                    Margin="0,0,8,0"
                                    Click="BtnLyricsAlignLeft_Click"
                                    ToolTip="左对齐"
                                    Background="#2C2C2C"
                                    BorderBrush="#444"
                                    BorderThickness="1">
                                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                    <Line X1="3" Y1="0" X2="22" Y2="0" Stroke="#AAA" StrokeThickness="2.5"/>
                                    <Line X1="3" Y1="6" X2="17" Y2="6" Stroke="#AAA" StrokeThickness="2.5"/>
                                    <Line X1="3" Y1="12" X2="22" Y2="12" Stroke="#AAA" StrokeThickness="2.5"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnLyricsAlignCenter" 
                                    Width="56" Height="40"
                                    Margin="0,0,8,0"
                                    Click="BtnLyricsAlignCenter_Click"
                                    ToolTip="居中对齐"
                                    Background="#2C2C2C"
                                    BorderBrush="#444"
                                    BorderThickness="1">
                                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                    <Line X1="3" Y1="0" X2="22" Y2="0" Stroke="#AAA" StrokeThickness="2.5"/>
                                    <Line X1="6" Y1="6" X2="19" Y2="6" Stroke="#AAA" StrokeThickness="2.5"/>
                                    <Line X1="3" Y1="12" X2="22" Y2="12" Stroke="#AAA" StrokeThickness="2.5"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnLyricsAlignRight" 
                                    Width="56" Height="40"
                                    Margin="0,0,12,0"
                                    Click="BtnLyricsAlignRight_Click"
                                    ToolTip="右对齐"
                                    Background="#2C2C2C"
                                    BorderBrush="#444"
                                    BorderThickness="1">
                                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                    <Line X1="3" Y1="0" X2="22" Y2="0" Stroke="#AAA" StrokeThickness="2.5"/>
                                    <Line X1="8" Y1="6" X2="22" Y2="6" Stroke="#AAA" StrokeThickness="2.5"/>
                                    <Line X1="3" Y1="12" X2="22" Y2="12" Stroke="#AAA" StrokeThickness="2.5"/>
                                </StackPanel>
                            </Button>

                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" 
                                       Margin="0,0,12,0"/>

                            <!-- 清空内容 -->
                            <Button x:Name="BtnLyricsClear" 
                                    Content="🗑 清空"
                                    Width="100" Height="40"
                                    Margin="0,0,12,0"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Click="BtnLyricsClear_Click"
                                    Style="{StaticResource RecordButtonStyle}"
                                    ToolTip="清空所有内容"/>
                        </StackPanel>
                    </Border>

                    <!-- 编辑区域 - 黑色背景，白色文字 -->
                    <Grid Grid.Row="1" Background="#000000">
                        <!-- 可滚动的编辑区域 -->
                        <ScrollViewer x:Name="LyricsScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Background="#000000"
                                      Padding="60,40"
                                      ScrollChanged="LyricsScrollViewer_ScrollChanged"
                                      MouseRightButtonUp="LyricsScrollViewer_RightClick">
                            <ScrollViewer.Resources>
                                <Style TargetType="{x:Type ScrollBar}" 
                                       BasedOn="{StaticResource FixedScrollBarStyle}"/>
                            </ScrollViewer.Resources>
                            <TextBox x:Name="LyricsTextBox"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="48"
                                     FontFamily="Microsoft YaHei UI"
                                     Foreground="White"
                                     TextAlignment="Center"
                                     MinHeight="600"
                                     CaretBrush="White"
                                     VerticalAlignment="Top"
                                     TextChanged="LyricsTextBox_TextChanged"
                                     PreviewKeyDown="LyricsTextBox_PreviewKeyDown"
                                     PreviewMouseWheel="LyricsTextBox_PreviewMouseWheel">
                                <!-- 🔧 水印提示 -->
                                <TextBox.Resources>
                                    <!-- ✅ 不设置行高，使用WPF默认（投影也用WPF TextBlock渲染，自动对齐） -->
                                    <VisualBrush x:Key="HintBrush" 
                                                 TileMode="None" 
                                                 Opacity="0.3" 
                                                 Stretch="None" 
                                                 AlignmentX="Left" 
                                                 AlignmentY="Top">
                                        <VisualBrush.Visual>
                                            <TextBlock Text="在此粘贴或输入歌谱文字内容...&#x0a;&#x0a;支持 Ctrl+V 粘贴"
                                                       FontSize="28"
                                                       FontStyle="Italic"
                                                       Foreground="#666666"
                                                       TextAlignment="Left"
                                                       Margin="0,20,0,0"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </TextBox.Resources>
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <ScrollViewer x:Name="PART_ContentHost" 
                                                                  Focusable="False"
                                                                  HorizontalScrollBarVisibility="Disabled"
                                                                  VerticalScrollBarVisibility="Disabled"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background" 
                                                        Value="{StaticResource HintBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- 关键帧位置提示区域 - 灰色条（叠加在ScrollViewer上方） -->
                <Border x:Name="ScrollbarIndicatorsBorder"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Width="18.5"
                        Margin="0,0,24,0"
                        Background="Transparent"
                        Panel.ZIndex="200">
                    <Canvas x:Name="ScrollbarIndicatorsCanvas"
                            Background="Transparent"
                            MouseLeftButtonDown="ScrollbarIndicatorsCanvas_Click"
                            MouseRightButtonDown="ScrollbarIndicatorsCanvas_Click"
                            ToolTip="左键：跳转到关键帧  |  右键：设置循环次数"/>
                </Border>
                <!-- 🎬 浮动合成播放按钮组（左上角） -->
                <StackPanel x:Name="CompositePlaybackPanel"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="15,45,0,0"
                            Orientation="Vertical"
                            Panel.ZIndex="300"
                            Visibility="Collapsed">
                    <Button x:Name="BtnFloatingCompositePlay"
                            Content="🎬 合成播放"
                            Padding="15,8"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Background="#2196F3"
                            Foreground="White"
                            BorderBrush="#1976D2"
                            BorderThickness="0"
                            Cursor="Hand"
                            Opacity="0.75"
                            Click="BtnCompositePlay_Click"
                            MouseRightButtonUp="BtnCompositePlay_RightClick"
                            ToolTip="左键：开始/停止播放 | 右键：快捷设置时长">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" 
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="20"
                                                    Padding="{TemplateBinding Padding}">
                                                <Border.Effect>
                                                    <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" Color="Black"/>
                                                </Border.Effect>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#1976D2"/>
                                                    <Setter Property="Opacity" Value="1.0"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#0D47A1"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <!-- ⚡ 速度控制按钮（仅在播放时显示） -->
                    <Button x:Name="BtnCompositeSpeed"
                            Content="⚡ 1.0x"
                            Padding="12,6"
                            Margin="0,8,0,0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Background="#FF9800"
                            Foreground="White"
                            BorderBrush="#F57C00"
                            BorderThickness="0"
                            Cursor="Hand"
                            Opacity="0.75"
                            Visibility="Collapsed"
                            MouseRightButtonUp="BtnCompositeSpeed_RightClick"
                            ToolTip="右键：选择播放速度">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" 
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="20"
                                                    Padding="{TemplateBinding Padding}">
                                                <Border.Effect>
                                                    <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" Color="Black"/>
                                                </Border.Effect>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#F57C00"/>
                                                    <Setter Property="Opacity" Value="1.0"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#E65100"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ========== 媒体播放器控制栏（默认隐藏） ========== -->
        <Border Grid.Row="2" x:Name="MediaPlayerPanel" Background="#2C2C2C" 
                BorderBrush="#404040" BorderThickness="0,1,0,0" Padding="15,10"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 播放控制按钮 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnMediaPrev" Content="⏮" Width="40" Height="40"
                            ToolTip="上一首" Click="BtnMediaPrev_Click"
                            Style="{StaticResource MaterialDesignFloatingActionMiniButton}"/>

                    <Button x:Name="BtnMediaPlayPause" Content="▶" Width="50" Height="50" Margin="10,0"
                            ToolTip="播放/暂停" Click="BtnMediaPlayPause_Click"
                            Style="{StaticResource MaterialDesignFloatingActionButton}"/>

                    <Button x:Name="BtnMediaNext" Content="⏭" Width="40" Height="40"
                            ToolTip="下一首" Click="BtnMediaNext_Click"
                            Style="{StaticResource MaterialDesignFloatingActionMiniButton}"/>

                    <Button x:Name="BtnMediaStop" Content="⏹" Width="40" Height="40" Margin="10,0,0,0"
                            ToolTip="停止" Click="BtnMediaStop_Click"
                            Style="{StaticResource MaterialDesignFloatingActionMiniButton}"/>
                </StackPanel>

                <!-- 进度条和时间 -->
                <Grid Grid.Column="1" Margin="20,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Slider x:Name="MediaProgressSlider" Grid.Row="0" 
                            VerticalAlignment="Center" Margin="0,0,0,5"
                            Minimum="0" Maximum="100" Value="0"
                            ValueChanged="MediaProgressSlider_ValueChanged"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock x:Name="MediaCurrentTime" Text="00:00" Foreground="White" FontSize="12"/>
                        <TextBlock Text=" / " Foreground="#999999" FontSize="12" Margin="5,0"/>
                        <TextBlock x:Name="MediaTotalTime" Text="00:00" Foreground="White" FontSize="12"/>
                    </StackPanel>
                </Grid>

                <!-- 音量控制和播放模式 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnPlayMode" Content="🔀" Width="40" Height="40"
                            ToolTip="播放模式：随机 (默认)" Click="BtnPlayMode_Click"
                            Style="{StaticResource MaterialDesignFloatingActionMiniButton}"/>

                    <TextBlock Text="🔊" FontSize="16" VerticalAlignment="Center" 
                               Foreground="White" Margin="15,0,5,0"/>

                    <Slider x:Name="VolumeSlider" Width="100" VerticalAlignment="Center"
                            Minimum="0" Maximum="100" Value="50"
                            ValueChanged="VolumeSlider_ValueChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== Toast 通知容器（悬浮提示，显示在合成播放按钮下方） ========== -->
        <Border x:Name="ToastNotification" 
                Grid.RowSpan="3"
                Background="#CC000000"
                CornerRadius="8"
                Padding="20,12"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,110,50,0"
                Visibility="Collapsed"
                Panel.ZIndex="9999"
                IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="3" BlurRadius="10" Opacity="0.5"/>
            </Border.Effect>
            <TextBlock x:Name="ToastMessage" 
                       FontSize="14"
                       FontWeight="Medium"
                       Foreground="White"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="200"/>
        </Border>
    </Grid>
</Window>
