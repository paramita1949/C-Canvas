<Window x:Class="ImageColorChanger.UI.MainWindow"
        x:Name="MainWindowRoot"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:controls="clr-namespace:ImageColorChanger.UI.Controls"
        xmlns:converters="clr-namespace:ImageColorChanger.UI.Converters"
        xmlns:views="clr-namespace:ImageColorChanger.UI.Views"
        Title="咏慕投影"
        Height="1004" Width="1600"
        MinHeight="800" MinWidth="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F5F5F5"
        FontFamily="Microsoft YaHei UI"
        ResizeMode="CanResize"
        Icon="/baodian.ico"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing"
        Activated="Window_Activated"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="MenuBarRow" Height="Auto"/>
            <!-- 单排按钮菜单栏 -->
            <RowDefinition Height="*"/>
            <!-- 主内容区 -->
            <RowDefinition Height="Auto"/>
            <!-- 媒体播放器控制栏 -->
        </Grid.RowDefinitions>

        <!-- ========== 单排按钮菜单栏 ========== -->
        <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,2" Padding="8,0">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.08" Color="#000000"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：所有按钮在一排 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 基础功能按钮 -->
                    <Button x:Name="BtnImport" Style="{StaticResource MenuButtonStyle}" 
                            ToolTip="导入图片或文件夹" Click="BtnImport_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLucideFolderOpen}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="文件" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnProjection" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="开启/关闭投影" Click="BtnProjection_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLucideMonitor}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="投影" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnSync" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="同步所有文件夹" Click="BtnSync_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLucideRefreshCw}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="同步" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnReset" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="重置视图" Click="BtnReset_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLucideUndo2}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="返回" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnOriginal" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="切换原图模式" Click="BtnOriginal_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLucideImage}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="原图" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnZoomReset" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="重置缩放比例" Click="BtnZoomReset_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLucideSearch}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="缩放" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnColorEffect" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="切换颜色效果" 
                            Click="BtnColorEffect_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLucideWand2}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="变色" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 分隔线 -->
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0"/>

                    <!-- 关键帧控制按钮 -->
                    <Button x:Name="BtnAddKeyframe" Style="{StaticResource SuccessButtonStyle}"
                            ToolTip="在当前位置添加关键帧" Click="BtnAddKeyframe_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLucidePlus}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="加帧" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnClearKeyframes" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="清除所有关键帧" Click="BtnClearKeyframes_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLucideTrash2}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="清帧" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnPrevKeyframe" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="跳转到上一个关键帧" Click="BtnPrevKeyframe_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLucideChevronLeft}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="上帧" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnNextKeyframe" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="跳转到下一个关键帧" Click="BtnNextKeyframe_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLucideChevronRight}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="下帧" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 分隔线 -->
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0"/>
                    <Button x:Name="BtnPlay" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="开始/停止自动播放" Click="BtnPlay_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLucidePlay}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="播放" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 播放控制按钮 -->
                    <Button x:Name="BtnPlayCount" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="单击循环切换，双击输入数字，滚轮微调 (1-10或∞)" 
                            Click="BtnPlayCount_Click"
                            MouseWheel="BtnPlayCount_MouseWheel"
                            MouseDoubleClick="BtnPlayCount_MouseDoubleClick">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLucideRepeat}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="5次" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnRecord" Content="录制" Style="{StaticResource RecordButtonStyle}"
                            ToolTip="开始/停止时间录制" 
                            Click="BtnRecord_Click"/>
                    <Button x:Name="BtnScript" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="显示脚本信息" Click="BtnScript_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLucideFileText}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="脚本" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnClearTiming" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="清除时间录制数据" Click="BtnClearTiming_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLucideTimerReset}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="清时" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 分隔线 -->
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0"/>
                    <Button x:Name="BtnPauseResume" Style="{StaticResource MenuButtonStyle}"
                            ToolTip="暂停/继续播放" Click="BtnPauseResume_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLucidePause}" Style="{StaticResource LucideIconPathStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="暂停" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 倒计时显示 - 无边框，黄色底 -->
                    <Border x:Name="CountdownBorder" Background="#FFFFCC" 
                            BorderThickness="0"
                            CornerRadius="4" Padding="8,2" Margin="3,0" Width="90"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="CountdownText" Text="倒: --" FontSize="18" 
                                   FontWeight="Bold" Foreground="#CC6600" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- 暂停/继续按钮 -->
                    
                    <!-- 登录按钮（使用联系按钮样式） -->
                    <Button x:Name="BtnLogin" Content="登录" Style="{StaticResource BreathingContactButtonStyle}"
                            ToolTip="登录账号解除投影限制" Click="BtnLogin_Click" Margin="15,0,4,0"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ========== 主内容区 ========== -->
        <Grid Grid.Row="1" x:Name="MainContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="NavigationPanelColumn" Width="370"/>
                <!-- 左侧导航栏（圣经模式5列表格需要370宽度） -->
                <ColumnDefinition Width="Auto"/>
                <!-- 分隔条 -->
                <ColumnDefinition Width="*"/>
                <!-- 右侧图片显示区 -->
            </Grid.ColumnDefinitions>

            <!-- 左侧：文件导航栏 -->
            <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- 搜索区域 -->
                        <RowDefinition Height="*"/>
                        <!-- 项目树 -->
                        <RowDefinition Height="Auto"/>
                        <!-- 屏幕选择 -->
                    </Grid.RowDefinitions>

                    <!-- 搜索区域 -->
                    <StackPanel Grid.Row="0" Background="White" Margin="8">
                        <Grid Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 搜索框 -->
                            <TextBox x:Name="SearchBox"
                                     Grid.Column="0"
                                     Height="40"
                                     Margin="0"
                                     Padding="12,8"
                                     materialDesign:HintAssist.Hint="搜索..."
                                     materialDesign:HintAssist.Foreground="#666666"
                                     materialDesign:TextFieldAssist.UnderlineBrush="#2196F3"
                                     Style="{StaticResource MaterialDesignFilledTextBox}"
                                     TextChanged="SearchBox_TextChanged"
                                     PreviewKeyDown="SearchBox_PreviewKeyDown"
                                     MouseDoubleClick="SearchBox_MouseDoubleClick"
                                     FontSize="14"
                                     Foreground="Black"
                                     VerticalContentAlignment="Center"/>

                            <StackPanel x:Name="BibleSearchModePanel"
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <TextBlock x:Name="BibleSearchModeFloatingText"
                                           Text="悬浮"
                                           FontSize="18"
                                           Cursor="Hand"
                                           Margin="0,0,4,0"
                                           VerticalAlignment="Center"
                                           MouseLeftButtonDown="BibleSearchModeFloatingText_MouseLeftButtonDown"/>
                                <TextBlock Text="|"
                                           FontSize="18"
                                           Foreground="#9E9E9E"
                                           Margin="0,0,4,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="BibleSearchModeEmbeddedText"
                                           Text="内嵌"
                                           FontSize="18"
                                           Cursor="Hand"
                                           VerticalAlignment="Center"
                                           MouseLeftButtonDown="BibleSearchModeEmbeddedText_MouseLeftButtonDown"/>
                            </StackPanel>
                        </Grid>

                        <Popup x:Name="BibleSearchPopup"
                               PlacementTarget="{Binding ElementName=SearchBox}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border Background="#FFFFFF"
                                    BorderBrush="#D6D6D6"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8"
                                    MinWidth="420"
                                    MaxWidth="980"
                                    MaxHeight="720">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock x:Name="BibleSearchResultStatus"
                                               Foreground="#666666"
                                               FontSize="12"
                                               Margin="2,0,2,6"/>

                                    <WrapPanel x:Name="BibleSearchFilterTagsPanel"
                                               Grid.Row="1"
                                               Margin="0,0,0,6"/>

                                    <ListBox x:Name="BibleSearchResultsList"
                                             Grid.Row="2"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                             ScrollViewer.HorizontalScrollBarVisibility="Hidden">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="2,2"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Foreground="#111111"
                                                           FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                           TextWrapping="Wrap">
                                                    <Run Text="{Binding RowNumber}"/>
                                                    <Run Text=". "/>
                                                    <Run Text="["/>
                                                    <Run Text="{Binding Reference}"/>
                                                    <Run Text="] "/>
                                                    <Run Text="{Binding FullPrefix}"/>
                                                    <Run Text="{Binding FullMatch}"
                                                         Foreground="#1E88E5"
                                                         FontWeight="Bold"/>
                                                    <Run Text="{Binding FullSuffix}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <StackPanel Grid.Row="3"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Margin="0,6,0,0">
                                        <Button x:Name="BibleSearchPrevPageButton"
                                                Content="上一页"
                                                Padding="8,2"
                                                Margin="0,0,8,0"/>
                                        <TextBlock x:Name="BibleSearchPageInfoText"
                                                   VerticalAlignment="Center"
                                                   Foreground="#666666"
                                                   Margin="0,0,8,0"/>
                                        <Button x:Name="BibleSearchNextPageButton"
                                                Content="下一页"
                                                Padding="8,2"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Popup>

                        <!-- 搜索范围 -->
                        <ComboBox x:Name="SearchScope" 
                                  Style="{StaticResource WhiteComboBoxPopup}"
                                  ItemContainerStyle="{StaticResource WhiteComboBoxItem}">
                            <ComboBoxItem Content="全部" IsSelected="True" Style="{StaticResource WhiteComboBoxItem}"/>
                            <ComboBoxItem Content="当前文件夹" Style="{StaticResource WhiteComboBoxItem}"/>
                        </ComboBox>
                        
                        <!--  文件/圣经/幻灯片 切换按钮 -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,8">
                            <Button x:Name="BtnShowFiles"
                                    Content="文件"
                                    Style="{StaticResource NavToggleButtonLeft}"
                                    Background="#2196F3"
                                    Foreground="White"
                                    BorderBrush="#1976D2"
                                    BorderThickness="1"
                                    Click="BtnShowFiles_Click"/>
                            <Button x:Name="BtnShowBible"
                                    Content="圣经"
                                    Style="{StaticResource NavToggleButtonMiddle}"
                                    Background="#FFFFFF"
                                    Foreground="#666666"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="0,1,1,1"
                                    Click="BtnShowBible_Click"/>
                            <Button x:Name="BtnShowProjects"
                                    Content="幻灯片"
                                    Style="{StaticResource NavToggleButtonRight}"
                                    Background="#FFFFFF"
                                    Foreground="#666666"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="0,1,1,1"
                                    Click="BtnShowProjects_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!--  圣经导航面板（圣经模式下显示） -->
                    <Grid Grid.Row="1" x:Name="BibleNavigationPanel" Visibility="Collapsed" Background="#2D2D30">
                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="BibleHistoryAndButtonRow" Height="*" MinHeight="150"/>    <!-- 历史记录+按钮（可调整高度，最小150像素） -->
                            <RowDefinition Height="3"/>       <!-- 分隔条（可拖拽调整） -->
                            <RowDefinition x:Name="BibleSelectionTableRow" Height="*" MinHeight="180"/>       <!-- 经文选择表格（可调整高度，最小180像素，约显示5个记录） -->
                        </Grid.RowDefinitions>
                        
                        <!-- 历史记录和按钮容器 -->
                        <Grid Grid.Row="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>    <!-- 历史记录（占用剩余空间） -->
                                <RowDefinition Height="Auto"/>    <!-- 历史操作按钮（固定） -->
                            </Grid.RowDefinitions>
                        
                        <!-- 历史记录列表（显示1-20号槽位） -->
                        <ScrollViewer x:Name="BibleHistoryScrollViewer" Grid.Row="0" VerticalScrollBarVisibility="Auto" Background="#3C3C3C">
                            <ListBox x:Name="BibleHistoryList" 
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Margin="5"
                                     SelectionChanged="BibleHistoryList_SelectionChanged"
                                     PreviewMouseWheel="BibleHistoryList_PreviewMouseWheel"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#FF5722"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="HistoryItemBorder"
                                                Background="#2D2D30" 
                                                BorderBrush="#4D4D4D" 
                                                BorderThickness="0,0,0,1"
                                                Padding="8,6"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="BibleHistoryItem_Click">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>  <!-- 复选框 -->
                                                    <ColumnDefinition Width="Auto"/>  <!-- 序号 -->
                                                    <ColumnDefinition Width="*"/>     <!-- 内容 -->
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- 复选框 -->
                                                <CheckBox Grid.Column="0" 
                                                          IsChecked="{Binding IsChecked}" 
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,5,0"
                                                          Foreground="White"
                                                          IsHitTestVisible="False"/>
                                                
                                                <!-- 序号 -->
                                                <TextBlock Grid.Column="1" 
                                                           Text="{Binding Index}" 
                                                           Foreground="#FFC107" 
                                                           FontSize="14" 
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,5,0"/>
                                                
                                                <!-- 经文信息 -->
                                                <TextBlock Grid.Column="2" 
                                                           Text="{Binding DisplayText}" 
                                                           Foreground="White" 
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           Margin="0"/>
                                            </Grid>
                                        </Border>
                                        
                                        <!-- DataTemplate Triggers -->
                                        <DataTemplate.Triggers>
                                            <!-- 锁定状态：绿色边框（最高优先级） -->
                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                <Setter TargetName="HistoryItemBorder" Property="BorderBrush" Value="#00FF00"/>
                                                <Setter TargetName="HistoryItemBorder" Property="BorderThickness" Value="3"/>
                                            </DataTrigger>
                                            
                                            <!-- 鼠标悬停：简单的灰色背景高亮（仅在未锁定时生效） -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsLocked}" Value="False"/>
                                                    <Condition Binding="{Binding ElementName=HistoryItemBorder, Path=IsMouseOver}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter TargetName="HistoryItemBorder" Property="Background" Value="#3E3E42"/>
                                            </MultiDataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                            
                            <!-- 历史操作按钮 -->
                            <Border Grid.Row="1" Background="#3C3C3C" BorderBrush="#4D4D4D" BorderThickness="0,0,0,1" Padding="5">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="BtnHistorySelectAll" 
                                        Content="全选" 
                                        Width="80" 
                                        Height="30" 
                                        FontSize="12"
                                        Margin="2"
                                        Style="{StaticResource MenuButtonStyle}"
                                        Click="BtnHistorySelectAll_Click"/>
                                <Button x:Name="BtnHistoryDeselectAll" 
                                        Content="全不选" 
                                        Width="80" 
                                        Height="30" 
                                        FontSize="12"
                                        Margin="2"
                                        Style="{StaticResource MenuButtonStyle}"
                                        Click="BtnHistoryDeselectAll_Click"/>
                                <Button x:Name="BtnHistoryClearSelected" 
                                        Content="清空勾选" 
                                        Width="100" 
                                        Height="30" 
                                        FontSize="12"
                                        Margin="2"
                                        Style="{StaticResource MenuButtonStyle}"
                                        Click="BtnHistoryClearSelected_Click"/>
                                <Button x:Name="BtnBibleSettings" 
                                        Width="80" 
                                        Height="30" 
                                        FontSize="12"
                                        Margin="2"
                                        Style="{StaticResource MenuButtonStyle}"
                                        Click="BtnBibleSettings_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconLucideBookSliders}" Style="{StaticResource LucideIconPathStyle}" Width="14" Height="14" Margin="0,0,4,0"/>
                                        <TextBlock Text="设置" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                        </Grid>
                        
                        <!-- 分隔条（可拖拽调整历史记录+按钮区域和经文选择表格之间的高度） -->
                        <GridSplitter x:Name="BibleNavigationSplitter"
                                     Grid.Row="1" 
                                     Height="3" 
                                     HorizontalAlignment="Stretch" 
                                     Background="#555555" 
                                     Cursor="SizeNS"
                                     ResizeDirection="Rows"
                                     ShowsPreview="False"
                                     DragCompleted="BibleNavigationSplitter_DragCompleted"/>
                        
                        <!-- 经文选择表格 -->
                        <!-- 5列表格布局：分类 | 书卷 | 章 | 起始节 | 结束节 -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="85"/>   <!-- 第1列:分类(4个字宽度) -->
                                <ColumnDefinition Width="120"/>  <!-- 第2列:书卷 -->
                                <ColumnDefinition Width="65"/>   <!-- 第3列:章 -->
                                <ColumnDefinition Width="60"/>   <!-- 第4列:起始节 -->
                                <ColumnDefinition Width="60"/>   <!-- 第5列:结束节 -->
                            </Grid.ColumnDefinitions>
                            
                            <!-- 第1列:分类列表 -->
                            <ListBox Grid.Column="0" 
                                     x:Name="BibleCategoryList"
                                     Background="#3C3C3C"
                                     BorderThickness="0,0,1,0"
                                     BorderBrush="#555555"
                                     SelectionChanged="BibleCategory_SelectionChanged"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#FF5722"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4D4D4D"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" 
                                                   TextWrapping="NoWrap" 
                                                   TextTrimming="None"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            
                            <!-- 第2列:书卷列表 -->
                            <ListBox Grid.Column="1" 
                                     x:Name="BibleBookList"
                                     Background="#3C3C3C"
                                     BorderThickness="0,0,1,0"
                                     BorderBrush="#555555"
                                     SelectionChanged="BibleBook_SelectionChanged"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#FF5722"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4D4D4D"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" 
                                                   TextWrapping="NoWrap" 
                                                   TextTrimming="None"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            
                            <!-- 第3列:章列表 -->
                            <ListBox Grid.Column="2" 
                                     x:Name="BibleChapterList"
                                     Background="#3C3C3C"
                                     BorderThickness="0,0,1,0"
                                     BorderBrush="#555555"
                                     SelectionChanged="BibleChapter_SelectionChanged"
                                     MouseDoubleClick="BibleChapter_MouseDoubleClick"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#FF5722"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4D4D4D"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                            
                            <!-- 第4列:起始节 -->
                            <ListBox Grid.Column="3" 
                                     x:Name="BibleStartVerse"
                                     Background="#3C3C3C"
                                     BorderThickness="0,0,1,0"
                                     BorderBrush="#555555"
                                     SelectionChanged="BibleStartVerse_SelectionChanged"
                                     MouseDoubleClick="BibleStartVerse_MouseDoubleClick"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#FF5722"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4D4D4D"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                            
                            <!-- 第5列:结束节 -->
                            <ListBox Grid.Column="4" 
                                     x:Name="BibleEndVerse"
                                     Background="#3C3C3C"
                                     BorderThickness="0"
                                     SelectionChanged="BibleEndVerse_SelectionChanged"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#FF5722"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4D4D4D"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Grid>
                    </Grid>
                    
                    <!-- 项目树（文件模式下显示） -->
                    <TreeView Grid.Row="1" x:Name="ProjectTree" 
                                  Style="{StaticResource ProjectTreeStyle}"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  PreviewKeyDown="Window_PreviewKeyDown"
                                  PreviewMouseLeftButtonUp="ProjectTree_MouseClick"
                                  MouseDoubleClick="ProjectTree_MouseDoubleClick"
                                  PreviewMouseRightButtonDown="ProjectTree_RightClick"
                                  MouseMove="ProjectTree_MouseMove"
                                  AllowDrop="True"
                                  Drop="ProjectTree_ExternalDrop"
                                  DragEnter="ProjectTree_ExternalDragEnter"
                                  DragOver="ProjectTree_ExternalDragOver"
                                  DragLeave="ProjectTree_ExternalDragLeave">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=OneWay}"/>
                                <EventSetter Event="MouseEnter" Handler="TreeViewItem_MouseEnter"/>
                                <EventSetter Event="MouseLeave" Handler="TreeViewItem_MouseLeave"/>
                                <!-- 自定义模板：对于文件节点隐藏展开/折叠按钮 -->
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="0"/>
                                                    <!-- 不显示展开按钮 -->
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition/>
                                                </Grid.RowDefinitions>
                                                
                                                <!-- 展开/折叠按钮（隐藏但保留功能） -->
                                                <ToggleButton x:Name="Expander" 
                                                              Grid.Column="0"
                                                              Width="0"
                                                              Height="0"
                                                              Visibility="Collapsed"
                                                              ClickMode="Press"
                                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"/>
                                                
                                                <!-- 内容区域 -->
                                                <Border x:Name="Bd" Grid.Column="1"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter x:Name="PART_Header"
                                                                      ContentSource="Header"
                                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                </Border>
                                                
                                                <!-- 子项容器 -->
                                                <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Grid.Column="1"/>
                                            </Grid>
                                            
                                            <ControlTemplate.Triggers>
                                                <!-- 未展开时隐藏子项 -->
                                                <Trigger Property="IsExpanded" Value="False">
                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                                <!-- 选中状态 - 黄色高亮 -->
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FFD54F"/>
                                                    <Setter Property="Foreground" Value="#212121"/>
                                                </Trigger>
                                                <!-- 非激活选中状态 - 浅黄色高亮 -->
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="IsSelectionActive" Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Bd" Property="Background" Value="#FFF59D"/>
                                                    <Setter Property="Foreground" Value="#424242"/>
                                                </MultiTrigger>
                                                <!-- 禁用状态 -->
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <!-- 纵向布局：第一行是图标+文件名，第二行是文件夹标签 -->
                                <StackPanel Orientation="Vertical" Margin="0,2">
                                    <!-- 第一行：图标 + 文件/文件夹名称 -->
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding IconImagePath, Converter={StaticResource ThumbnailPathToImageSourceConverter}}"
                                               Width="22"
                                               Height="22"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasIconImagePath}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>

                                        <materialDesign:PackIcon Kind="{Binding IconKind}" 
                                                                Foreground="{DynamicResource BrushGlobalIcon}"
                                                                Width="22" 
                                                                Height="22" 
                                                                Margin="0,0,10,0"
                                                                VerticalAlignment="Center">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <!-- 文件夹/歌词分组/歌词歌曲显示图标 -->
                                                        <DataTrigger Binding="{Binding Type}" Value="Folder">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="LyricsGroup">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="LyricsSong">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <!-- 如果没有IconKind也隐藏 -->
                                                        <DataTrigger Binding="{Binding IconKind}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IconKind}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding HasIconImagePath}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>

                                        <!-- 文件/文件夹名称 - 支持内联编辑 -->
                                        <Grid>
                                            <!-- 显示模式：TextBlock -->
                                            <TextBlock Text="{Binding Name}" 
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <!-- 默认使用文件字号 -->
                                                        <Setter Property="FontSize" Value="{Binding ElementName=MainWindowRoot, Path=FileFontSize}"/>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <!-- 如果是文件夹，使用文件夹字号 -->
                                                            <DataTrigger Binding="{Binding Type}" Value="Folder">
                                                                <Setter Property="FontSize" Value="{Binding ElementName=MainWindowRoot, Path=FolderFontSize}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="LyricsRoot">
                                                                <Setter Property="FontSize" Value="{Binding ElementName=MainWindowRoot, Path=FolderFontSize}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="LyricsGroup">
                                                                <Setter Property="FontSize" Value="{Binding ElementName=MainWindowRoot, Path=FolderFontSize}"/>
                                                            </DataTrigger>
                                                            <!-- 编辑模式时隐藏 -->
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            
                                            <!-- 编辑模式：TextBox (无边框透明背景) -->
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                                     VerticalAlignment="Center"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     Padding="0"
                                                     KeyDown="TreeItemEditBox_KeyDown"
                                                     LostFocus="TreeItemEditBox_LostFocus"
                                                     Loaded="TreeItemEditBox_Loaded"
                                                     IsVisibleChanged="TreeItemEditBox_IsVisibleChanged">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="FontSize" Value="{Binding ElementName=MainWindowRoot, Path=FileFontSize}"/>
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Setter Property="CaretBrush" Value="Black"/>
                                                        <Style.Triggers>
                                                            <!-- 如果是文件夹，使用文件夹字号 -->
                                                            <DataTrigger Binding="{Binding Type}" Value="Folder">
                                                                <Setter Property="FontSize" Value="{Binding ElementName=MainWindowRoot, Path=FolderFontSize}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="LyricsRoot">
                                                                <Setter Property="FontSize" Value="{Binding ElementName=MainWindowRoot, Path=FolderFontSize}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="LyricsGroup">
                                                                <Setter Property="FontSize" Value="{Binding ElementName=MainWindowRoot, Path=FolderFontSize}"/>
                                                            </DataTrigger>
                                                            <!-- 编辑模式时显示 -->
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </Grid>
                                    </StackPanel>

                                    <!-- 第二行：文件夹标签（搜索时显示，在名称下方）-->
                                    <Border Background="{Binding FolderColor}" 
                                            CornerRadius="3" 
                                            Padding="6,2" 
                                            Margin="26,2,0,0"
                                            HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowFolderTag}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding FolderName}" 
                                                   FontSize="{Binding ElementName=MainWindowRoot, Path=FolderTagFontSize}" 
                                                   Foreground="White"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                    
                    <!-- 拖拽插入位置指示器 -->
                    <Canvas Grid.Row="1" 
                            x:Name="DragIndicatorCanvas" 
                            IsHitTestVisible="False"
                            Background="Transparent">
                        <Line x:Name="DragIndicatorLine"
                              Stroke="#2196F3"
                              StrokeThickness="2"
                              X1="20" Y1="0" X2="200" Y2="0"
                              Visibility="Collapsed">
                            <Line.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.5" Color="#2196F3"/>
                            </Line.Effect>
                        </Line>
                    </Canvas>
                    
                    <!-- 文件名完整显示提示框 -->
                    <Popup x:Name="FileNameTooltipPopup"
                           AllowsTransparency="True"
                           Placement="Relative"
                           PlacementTarget="{Binding ElementName=ProjectTree}"
                           StaysOpen="True"
                           IsHitTestVisible="False">
                        <Border Background="#E0000000"
                                BorderBrush="#80FFFFFF"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,8"
                                MaxWidth="500">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" 
                                                  BlurRadius="8" 
                                                  Opacity="0.5" 
                                                  Color="#000000"/>
                            </Border.Effect>
                            <TextBlock x:Name="FileNameTooltipText"
                                       Text=""
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Popup>
                    
                    <!-- 屏幕选择器（底部） -->
                    <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="8">
                        <StackPanel>
                            <TextBlock Text="投影屏幕" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                            <ComboBox x:Name="ScreenSelector" Height="32" 
                                      SelectedIndex="0" FontSize="12"
                                      Style="{StaticResource WhiteComboBoxPopup}"
                                      ItemContainerStyle="{StaticResource WhiteComboBoxItem}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 分隔条 -->
            <GridSplitter x:Name="NavigationSplitter" 
                          Grid.Column="1" Width="3" HorizontalAlignment="Stretch" 
                          Background="#E0E0E0" Cursor="SizeWE"
                          DragCompleted="NavigationSplitter_DragCompleted"/>

            <!-- 右侧：图片显示区 -->
            <Grid Grid.Column="2" Background="#000000">
                <!-- 图片显示区域（支持滚动和缩放） -->
                <ScrollViewer x:Name="ImageScrollViewer"
                     HorizontalScrollBarVisibility="Disabled"
                     VerticalScrollBarVisibility="Auto"
                     Background="#000000"
                     BorderThickness="0"
                     PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel"
                     SizeChanged="ImageScrollViewer_SizeChanged"
                     MouseRightButtonUp="ImageScrollViewer_RightClick"
                     PreviewMouseDown="ImageArea_PreviewMouseDown">
                    <ScrollViewer.Resources>
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource FixedScrollBarStyle}"/>
                    </ScrollViewer.Resources>
                    <ScrollViewer.ContextMenu>
                        <ContextMenu x:Name="CanvasContextMenu" Style="{StaticResource NoBorderContextMenuStyle}" Opened="CanvasContextMenu_Opened">
                            <MenuItem Header="滚动速度">
                                <MenuItem Header="0秒 (直接跳转)" Click="SetScrollSpeed_Click" Tag="0" IsCheckable="True"/>
                                <MenuItem Header="0.5秒" Click="SetScrollSpeed_Click" Tag="0.5" IsCheckable="True"/>
                                <MenuItem Header="1.0秒" Click="SetScrollSpeed_Click" Tag="1.0" IsCheckable="True"/>
                                <MenuItem Header="8.0秒" Click="SetScrollSpeed_Click" Tag="8.0" IsCheckable="True" IsChecked="True"/>
                                <MenuItem Header="9.0秒" Click="SetScrollSpeed_Click" Tag="9.0" IsCheckable="True"/>
                                <MenuItem Header="10.0秒" Click="SetScrollSpeed_Click" Tag="10.0" IsCheckable="True"/>
                                <MenuItem Header="11.0秒" Click="SetScrollSpeed_Click" Tag="11.0" IsCheckable="True"/>
                                <MenuItem Header="12.0秒" Click="SetScrollSpeed_Click" Tag="12.0" IsCheckable="True"/>
                                <MenuItem Header="13.0秒" Click="SetScrollSpeed_Click" Tag="13.0" IsCheckable="True"/>
                                <MenuItem Header="14.0秒" Click="SetScrollSpeed_Click" Tag="14.0" IsCheckable="True"/>
                                <MenuItem Header="15.0秒" Click="SetScrollSpeed_Click" Tag="15.0" IsCheckable="True"/>
                            </MenuItem>
                            <MenuItem Header="滚动函数">
                                <MenuItem Header="贝塞尔曲线" Click="SetScrollEasing_Click" Tag="Bezier" IsCheckable="True"/>
                                <MenuItem Header="CSS缓入缓出" Click="SetScrollEasing_Click" Tag="CssEaseInOut" IsCheckable="True"/>
                                <MenuItem Header="超级平滑" Click="SetScrollEasing_Click" Tag="UltraSmooth" IsCheckable="True"/>
                                <MenuItem Header="线性滚动" Click="SetScrollEasing_Click" Tag="Linear" IsCheckable="True" IsChecked="True"/>
                            </MenuItem>
                        </ContextMenu>
                    </ScrollViewer.ContextMenu>
                    <Grid x:Name="ImageContainer" Background="#000000">
                        <Image x:Name="ImageDisplay" 
                               Stretch="Fill"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Top"
                               MouseLeftButtonDown="ImageDisplay_MouseLeftButtonDown"
                               MouseLeftButtonUp="ImageDisplay_MouseLeftButtonUp"
                               MouseMove="ImageDisplay_MouseMove"
                               MouseDown="ImageDisplay_MouseDown"
                               PreviewMouseDown="ImageDisplay_PreviewMouseDown"
                               Cursor="Hand">
                            <Image.LayoutTransform>
                                <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1"/>
                            </Image.LayoutTransform>
                        </Image>

                        <!-- 关键帧预览线容器 - 直接叠加在图片上 -->
                        <Canvas x:Name="KeyframePreviewLinesCanvas"
                                IsHitTestVisible="False"
                                Background="Transparent"
                                Panel.ZIndex="10"/>
                    </Grid>
                </ScrollViewer>
                
                <!-- 视频播放区域（默认隐藏，播放视频时显示） -->
                <Grid x:Name="VideoContainer" Background="#000000" Visibility="Collapsed">
                    <!-- VideoView控件将在代码中动态添加 -->
                    
                    <!-- 媒体文件名称显示（用于纯音频文件，铺满整个区域） -->
                    <Grid x:Name="MediaFileNameBorder" 
                          Background="#000000"
                          Visibility="Collapsed">
                        <!-- 文件名内容，居中显示 -->
                        <StackPanel VerticalAlignment="Center" 
                                    HorizontalAlignment="Center">
                            <Viewbox Width="80"
                                     Height="80"
                                     HorizontalAlignment="Center"
                                     Margin="0,0,0,20">
                                <Path Data="{StaticResource IconLucideMusic}"
                                      Style="{StaticResource LucideIconPathStyle}"
                                      Stroke="White"/>
                            </Viewbox>
                            <TextBlock x:Name="MediaFileNameText"
                                       Text="媒体文件"
                                       FontSize="28"
                                       FontWeight="Medium"
                                       Foreground="White"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       MaxWidth="800"
                                       Padding="20,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!--  圣经显示区域（默认隐藏，切换到圣经模式时显示） -->
                <!-- 注意：圣经模式下，左侧ProjectTree会被替换为圣经专用导航 -->
                <views:BibleSectionView x:Name="BibleSectionView"/>

                <!--  文本编辑器面板（默认隐藏，类似PPT的布局） -->
                <views:TextEditorSectionView x:Name="TextEditorSectionView"/>

                <!--  歌词编辑器面板（极简黑色版） -->
                <views:LyricsSectionView x:Name="LyricsSectionView"/>

                <!-- 关键帧位置提示区域 - 灰色条（叠加在ScrollViewer上方） -->
                <Border x:Name="ScrollbarIndicatorsBorder"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Width="18.5"
                        Margin="0,0,24,0"
                        Background="Transparent"
                        Panel.ZIndex="200">
                    <Canvas x:Name="ScrollbarIndicatorsCanvas"
                            Background="Transparent"
                            MouseLeftButtonDown="ScrollbarIndicatorsCanvas_Click"
                            MouseRightButtonDown="ScrollbarIndicatorsCanvas_Click"
                            ToolTip="左键：跳转到关键帧  |  右键：设置循环次数"/>
                </Border>
                <!--  浮动合成播放按钮组（左上角） -->
                <StackPanel x:Name="CompositePlaybackPanel"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="15,45,0,0"
                            Orientation="Vertical"
                            Panel.ZIndex="300"
                            Visibility="Collapsed">
                    <Button x:Name="BtnFloatingCompositePlay"
                            Padding="15,8"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Background="{StaticResource BrushBrandPrimary}"
                            Foreground="White"
                            BorderBrush="{StaticResource BrushBrandPrimary}"
                            BorderThickness="0"
                            Cursor="Hand"
                            Opacity="0.75"
                            Click="BtnCompositePlay_Click"
                            MouseRightButtonUp="BtnCompositePlay_RightClick"
                            ToolTip="左键：开始/停止播放 | 右键：快捷设置时长">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLucideClapperboard}"
                                  Style="{StaticResource LucideIconPathStyle}"
                                  Stroke="White"
                                  Margin="0,0,8,0"/>
                            <TextBlock Text="合成播放" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" 
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="20"
                                                    Padding="{TemplateBinding Padding}">
                                                <Border.Effect>
                                                    <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" Color="Black"/>
                                                </Border.Effect>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#1976D2"/>
                                                    <Setter Property="Opacity" Value="1.0"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#0D47A1"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <!--  速度控制按钮（仅在播放时显示） -->
                    <Button x:Name="BtnCompositeSpeed"
                            Padding="12,6"
                            Margin="0,8,0,0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Background="{StaticResource BrushBrandWarning}"
                            Foreground="White"
                            BorderBrush="{StaticResource BrushBrandWarning}"
                            BorderThickness="0"
                            Cursor="Hand"
                            Opacity="0.75"
                            Visibility="Collapsed"
                            Click="BtnCompositeSpeed_Click"
                            MouseRightButtonUp="BtnCompositeSpeed_RightClick"
                            ToolTip="右键：选择播放速度">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLucideZap}"
                                  Style="{StaticResource LucideIconPathStyle}"
                                  Stroke="White"
                                  Margin="0,0,6,0"/>
                            <TextBlock Text="1.0x" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" 
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="20"
                                                    Padding="{TemplateBinding Padding}">
                                                <Border.Effect>
                                                    <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" Color="Black"/>
                                                </Border.Effect>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#F57C00"/>
                                                    <Setter Property="Opacity" Value="1.0"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#E65100"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ========== 媒体播放器控制栏（默认隐藏） ========== -->
        <views:MediaPlayerSectionView x:Name="MediaPlayerSectionView" Grid.Row="2"/>

        <!-- ========== Toast 通知容器（悬浮提示，显示在合成播放按钮下方） ========== -->
        <Border x:Name="ToastNotification" 
                Grid.RowSpan="3"
                Background="#CC000000"
                CornerRadius="8"
                Padding="20,12"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,110,50,0"
                Visibility="Collapsed"
                Panel.ZIndex="9999"
                IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="3" BlurRadius="10" Opacity="0.5"/>
            </Border.Effect>
            <TextBlock x:Name="ToastMessage" 
                       FontSize="14"
                       FontWeight="Medium"
                       Foreground="White"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="200"/>
        </Border>
    </Grid>
</Window>



