<Window x:Class="ImageColorChanger.UI.NdiWatermarkSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="帧水印设置"
        Height="640"
        Width="860"
        MinHeight="640"
        MinWidth="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F7FC"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E6EDF5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18,16,18,16"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
        </Style>
        <Style x:Key="TextInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,6,12,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FBFDFF"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="116"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22,18,22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="14" Padding="16,12,16,12" Background="#0F172A">
            <StackPanel>
                <TextBlock Text="帧水印设置" FontSize="23" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="统一设置文字、位置、字号、透明度与字体" Margin="0,3,0,0" FontSize="13" Foreground="#BFDBFE"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="0.8*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource LabelStyle}" Text="文字"/>
                    <TextBox x:Name="WatermarkTextBox" Grid.Row="2" Style="{StaticResource TextInputStyle}" ToolTip="留空表示关闭水印"/>

                    <StackPanel Grid.Row="4">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="位置"/>
                        <UniformGrid x:Name="PositionGrid" Margin="0,6,0,0" Rows="1" Columns="5"/>
                    </StackPanel>

                    <StackPanel Grid.Row="6">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="字号"/>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="72"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="FontSizeSlider" Minimum="10" Maximum="220" TickFrequency="2" VerticalAlignment="Center" ValueChanged="FontSizeSlider_ValueChanged"/>
                            <TextBox x:Name="FontSizeTextBox" Grid.Column="2" Style="{StaticResource TextInputStyle}" Height="34" TextAlignment="Center" TextChanged="FontSizeTextBox_TextChanged"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="8">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="透明度"/>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="72"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="OpacitySlider" Minimum="0" Maximum="100" TickFrequency="1" VerticalAlignment="Center" ValueChanged="OpacitySlider_ValueChanged"/>
                            <TextBox x:Name="OpacityTextBox" Grid.Column="2" Style="{StaticResource TextInputStyle}" Height="34" TextAlignment="Center" TextChanged="OpacityTextBox_TextChanged"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource LabelStyle}" Text="字体"/>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="FontFamilyTextBox" Style="{StaticResource TextInputStyle}" IsReadOnly="True"/>
                        <Button Grid.Column="2" Content="选择字体" Style="{StaticResource PrimaryButtonStyle}" Click="ChooseFontButton_Click"/>
                    </Grid>

                    <Border x:Name="FontSizePreviewHost"
                            Grid.Row="4"
                            BorderThickness="1"
                            BorderBrush="#E2E8F0"
                            Background="#0F172A"
                            CornerRadius="12"
                            Padding="14"
                            SizeChanged="FontSizePreviewHost_SizeChanged">
                        <StackPanel>
                            <TextBlock Text="字号预览" FontSize="12" Foreground="#93C5FD"/>
                            <Border Margin="0,10,0,0" CornerRadius="10" Background="#111827" Padding="14">
                                <TextBlock x:Name="FontSizePreviewText"
                                           Text="字号预览 123ABC"
                                           Foreground="#FFFFFF"
                                           TextWrapping="NoWrap"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderTransformOrigin="0.5,0.5"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Width="96" Style="{StaticResource SecondaryButtonStyle}" Click="CancelButton_Click"/>
            <Button Content="保存" Width="96" Margin="10,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
