<Window x:Class="ImageColorChanger.UI.ContactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="咏慕投影 - 付费购买" 
        Height="750" Width="900"
        MinHeight="700" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        FontFamily="Microsoft YaHei UI"
        ResizeMode="CanResize"
        Icon="/baodian.ico">

    <Window.Resources>
        <!-- 按钮样式 -->
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="6" Opacity="0.15" Color="#000000"/>
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushDialogBrandPrimary}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushDialogBrandHover}"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.25" Color="{StaticResource ColorDialogBrandPrimary}"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="Selected">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BrushDialogBrandPrimary}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushDialogBrandHover}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="1" BlurRadius="10" Opacity="0.3" Color="{StaticResource ColorDialogBrandPrimary}"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 标题栏 -->
            <RowDefinition Height="*"/>
            <!-- 内容区 -->
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{StaticResource BrushDialogBrandPrimary}" Padding="20,15">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.2" Color="#000000"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="付费购买 - 咏幕投影" 
                           FontSize="26" 
                           FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock FontSize="16" 
                           FontWeight="Medium"
                           Foreground="#E3F2FD"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,8,0,0">
                    <Run Text="小团队年费:168元/3台电脑授权，大团队年费:278元/7台电脑授权"/>
                </TextBlock>
                <TextBlock Text="扫描下方二维码联系咨询" 
                           FontSize="13" 
                           Foreground="#B3E5FC"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
                <TextBlock FontSize="13" 
                           Foreground="#B3E5FC"
                           HorizontalAlignment="Center"
                           Margin="0,3,0,0">
                    <Run Text="邮箱: "/>
                    <Run Text="irenminbi@vip.qq.com" FontWeight="Medium"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 内容区 - 两张图片并排 -->
        <Grid Grid.Row="1" Background="White" Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：微信联系 -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,40,0,0">
                <TextBlock Text=" 微信联系" 
                           FontSize="20" 
                           FontWeight="Medium"
                           Foreground="#333333"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>
                
                <Border Background="White" 
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1" 
                        CornerRadius="8"
                        Padding="15"
                        HorizontalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="0" BlurRadius="15" Opacity="0.15" Color="#000000"/>
                    </Border.Effect>
                    <Image x:Name="WeixinImage"
                           Stretch="None"
                           UseLayoutRounding="True"
                           SnapsToDevicePixels="True"/>
                </Border>
                
                <TextBlock Text="扫描二维码添加微信交流" 
                           FontSize="14" 
                           Foreground="#666666"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"/>
            </StackPanel>

            <!-- 右侧：付款码 -->
            <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,40,0,0">
                <TextBlock Text="付款码" 
                           FontSize="20" 
                           FontWeight="Medium"
                           Foreground="#333333"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>
                
                <Border Background="White" 
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1" 
                        CornerRadius="8"
                        Padding="15"
                        HorizontalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="0" BlurRadius="15" Opacity="0.15" Color="#000000"/>
                    </Border.Effect>
                    <Image x:Name="PayImage"
                           Stretch="None"
                           UseLayoutRounding="True"
                           SnapsToDevicePixels="True"/>
                </Border>
                
                <TextBlock Text="扫描二维码完成付款" 
                           FontSize="14" 
                           Foreground="#666666"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>


